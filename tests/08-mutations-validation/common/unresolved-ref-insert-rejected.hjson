{
  // §5.6: a ref "MUST resolve to an existing row"; reference validity is a
  // state constraint (§22.1). Inserting a row whose ref does not resolve
  // rejects the complete transition.
  format: 1
  name: unresolved-ref-insert-rejected
  suite: scenario
  spec: ["#mutations", "§8.7", "§5.6", "§22.1"]

  package: {
    "$liasse": 1
    "$app": "t.badref@1.0.0"
    "$model": {
      "accounts": {
        "$key": "id"
        "id": "text"
      }
      "tasks": {
        "$key": "id"
        "id": "text"
        "owner": { "$ref": "/accounts" }
      }
      "$mut": {
        "add_task": ".tasks + { id: @id, owner: @owner }"
      }
      "$public": {
        "tasks": { "$mut": { "add": ".add_task" } }
      }
    }
    "$data": {
      "accounts": { "a1": {} }
    }
  }

  steps: [
    {
      call: "public.tasks.add"
      args: { id: "t1", owner: "a1" }
      expect: { outcome: ok }
    }
    {
      call: "public.tasks.add"
      args: { id: "t2", owner: "zz" }
      expect: {
        outcome: rejected
        violates: ["§5.6", "§22.1"]
        detail: "owner references an /accounts row that does not exist"
      }
    }
  ]
}

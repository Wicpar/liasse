{
  // Spec gap with security weight: an external call supplying an argument
  // name that is not a declared parameter. §8.11 says "The argument object
  // maps parameter names to values", and §2.5 makes unknown members invalid
  // only in DECLARATION objects. Nothing states whether a runtime must
  // reject a call carrying an undeclared argument or may silently ignore it.
  // Silent dropping of hostile extra members and strict rejection are both
  // defensible readings, so the outcome is unspecified.
  format: 1
  name: unknown-argument-name-unspecified
  suite: scenario
  spec: ["#mutations", "§8.11", "§8.3", "§2.5"]
  tags: ["boundary"]
  note: "§8.3 makes the inferred parameter shape 'part of the external surface contract' and §8.11 defines the argument object as a map from parameter names to values, but no rule assigns an outcome to a call whose argument object contains an undeclared member. §2.5's unknown-member rule is scoped to declaration objects in the package source, not to wire calls."

  package: {
    $liasse: 1
    $app: "t.extraarg@1.0.0"
    $model: {
      profiles: {
        $key: "id"
        id: "text"
        name: "text"
      }
      $mut: {
        rename: ".profiles[@id] { name = @name }"
      }
      $public: {
        profiles: { $mut: { rename: ".rename" } }
      }
    }
    $data: {
      profiles: { p1: { name: "old" } }
    }
  }

  steps: [
    {
      call: "public.profiles.rename"
      args: { id: "p1", name: "new", debug: "1" }
      expect: { outcome: unspecified }
    }
  ]
}

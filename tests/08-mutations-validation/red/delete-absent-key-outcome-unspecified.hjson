{
  // Pinned (SPEC-ISSUES #7): `.tasks - @id` where @id names no existing row.
  // §8.9 now states that delete by key is a set operation, not a single-row
  // receiver context: `collection - keys` removes each key naming a live row and
  // contributes nothing for an absent key, exactly as `$set - values` ignores an
  // absent member (§8.5). Deleting a key that names no live row stages no change,
  // so with no other change the call returns `unchanged` (never a missing-target
  // rejection). This differs from a keyed patch, whose exactly-one-row receiver
  // (§6.3) rejects an absent target.
  format: 1
  name: delete-absent-key-outcome-unspecified
  suite: scenario
  spec: ["#mutations", "§8.9", "§8.5", "§6.3"]
  note: "Pinned (SPEC-ISSUES #7). Delete-by-key of an absent key stages no change; with no other change in the program the call returns ok with completion unchanged, mirroring §8.5's absent-member set removal."

  package: {
    $liasse: 1
    $app: "t.delabsent@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "text"
      }
      $mut: {
        remove: ".tasks - @id"
      }
      $public: {
        tasks: { $mut: { remove: ".remove" } }
      }
    }
    $data: {
      tasks: { t1: {} }
    }
  }

  steps: [
    {
      call: "public.tasks.remove"
      args: { id: "zz" }
      expect: { outcome: ok, completion: unchanged }
    }
  ]
}

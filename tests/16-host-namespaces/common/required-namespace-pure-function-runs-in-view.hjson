{
  format: 1
  name: required-namespace-pure-function-runs-in-view
  suite: scenario
  spec: ["#host-namespaces"]
  note: '''
    §16.2: the local $requires key is the expression namespace and the value
    identifies the semantic contract and compatible major; at load time the
    context supplies the descriptor and the install record pins it. §16.3:
    pure functions MAY run during views. The simulated pure function `double`
    (see NOTES.md) doubles its integer argument, so the expected view value
    14 is deduced from this case file, not from an implementation.
  '''

  package: {
    $liasse: 1
    $app: "t.pureview@1.0.0"
    $requires: {
      util: "test.util@1"
    }
    $model: {
      n: "int = 0"
      doubled: { $view: "util.double(.n)" }
      $public: {
        stats: { $view: ".doubled" }
      }
    }
    $data: { n: 7 }
  }

  hosts: {
    namespaces: [
      {
        id: "test.util"
        version: "1.2.0"
        interface_hash: "ih-util-1"
        functions: {
          double: { signature: "(int) -> int", effect: "pure", op: "double" }
        }
      }
    ]
  }

  steps: [
    { watch: "public.stats", id: "w1", expect_init: { value: "14" } }
  ]
}

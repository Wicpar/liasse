{
  format: 1
  name: required-namespace-pure-function-runs-in-view
  suite: scenario
  spec: ["#host-namespaces", "§16.5", "§16.2", "§16.3"]
  note: '''
    §16.2: the local $requires key is the expression namespace and the value
    identifies the semantic contract and compatible major; at load time the
    context supplies the descriptor and the install record pins it. §16.3/
    §16.5: a registered pure function runs inside a mutation program. The
    simulated pure function `double` (see NOTES.md) doubles its integer
    argument, so the mutation `add` computes `double(7) = 14`, stores it, and
    the database-evaluated view reads the stored field — the expected value 14
    is deduced from this case file, not from an implementation. (Recast per
    §16.5: the pure app call moved out of the former `util.double(.n)` view
    into the mutation body that produces the stored value.)
  '''

  package: {
    $liasse: 1
    $app: "t.pureview@1.0.0"
    $requires: {
      util: "test.util@1"
    }
    $model: {
      nums: {
        $key: "id"
        id: "text"
        n: "int"
        doubled: "int = 0"
      }
      $mut: {
        add: [
          "d = util.double(@n)"
          "row = .nums + { id: @id, n: @n, doubled: d }"
          "return row { id, n, doubled }"
        ]
      }
      $public: {
        nums: { $view: ".nums { id, n, doubled }", $mut: { add: ".add" } }
      }
    }
  }

  hosts: {
    namespaces: [
      {
        id: "test.util"
        version: "1.2.0"
        interface_hash: "ih-util-1"
        functions: {
          double: { signature: "(int) -> int", effect: "pure", op: "double" }
        }
      }
    ]
  }

  steps: [
    { call: "public.nums.add", args: { id: "r1", n: "7" },
      expect: { outcome: ok, value: { id: "r1", n: "7", doubled: "14" } } }
    { watch: "public.nums", id: "w1",
      expect_init: { value: [ { id: "r1", n: "7", doubled: "14" } ] } }
  ]
}

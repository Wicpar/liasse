{
  format: 1
  name: app-function-in-computed-value-rejected
  suite: static
  spec: ["#host-namespaces", "§16.5", "#state-model", "§5.2"]
  note: '''
    §16.5: a computed value (§5.2) is database-evaluated, so an app-registered
    namespace call in it is a load-time error. The escape is to derive the
    value in a mutation statement and store it. The pure `double` isolates
    §16.5 (namespace origin) from the §16.3 effect-class rule.
  '''

  package: {
    $liasse: 1
    $app: "t.appcomputed@1.0.0"
    $requires: {
      util: "test.util@1"
    }
    $model: {
      nums: {
        $key: "id"
        id: "text"
        n: "int"
        doubled: "= util.double(.n)"
      }
      $public: {
        nums: { $view: ".nums { id, n, doubled }" }
      }
    }
  }

  hosts: {
    namespaces: [
      {
        id: "test.util"
        version: "1.2.0"
        interface_hash: "ih-util-1"
        functions: {
          double: { signature: "(int) -> int", effect: "pure", op: "double" }
        }
      }
    ]
  }

  expect: {
    outcome: invalid
    violates: ["#host-namespaces", "§16.5", "#state-model"]
    detail: "an app-registered namespace call in a database-evaluated computed value is a load-time error (§16.5)"
  }
}

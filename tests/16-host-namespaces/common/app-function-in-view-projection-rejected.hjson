{
  format: 1
  name: app-function-in-view-projection-rejected
  suite: static
  spec: ["#host-namespaces", "§16.5", "#views", "§7.1"]
  note: '''
    §16.5: a `$view` projection output is database-evaluated, so an
    app-registered namespace call in it is a load-time error. The pure
    `double` isolates §16.5 (namespace origin) from the §16.3 effect-class
    rule.
  '''

  package: {
    $liasse: 1
    $app: "t.appproj@1.0.0"
    $requires: {
      util: "test.util@1"
    }
    $model: {
      nums: {
        $key: "id"
        id: "text"
        n: "int"
      }
      doubled: { $view: ".nums { id, d: util.double(.n) }" }
      $public: {
        doubled: { $view: ".doubled" }
      }
    }
  }

  hosts: {
    namespaces: [
      {
        id: "test.util"
        version: "1.2.0"
        interface_hash: "ih-util-1"
        functions: {
          double: { signature: "(int) -> int", effect: "pure", op: "double" }
        }
      }
    ]
  }

  expect: {
    outcome: invalid
    violates: ["#host-namespaces", "§16.5", "#views"]
    detail: "an app-registered namespace call in a database-evaluated view projection is a load-time error (§16.5)"
  }
}

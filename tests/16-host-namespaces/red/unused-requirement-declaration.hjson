{
  format: 1
  name: unused-requirement-declaration
  suite: static
  spec: ["#host-namespaces"]
  tags: ["pedantic"]
  note: '''
    The package declares a requirement it never calls. §16.2 (SPEC-ISSUES
    #17) makes "A package declares only the non-core namespaces it USES"
    normative: "Every declared requirement MUST be used — invoked by at
    least one expression call site, or supplying a named value type the
    model references; an unused requirement rejects loading." An unused
    requirement pins a dead descriptor into the install record and widens
    the §E.8 compatibility/attack surface without any expression exercising
    it, so the load is rejected.
  '''

  package: {
    $liasse: 1
    $app: "t.unusedreq@1.0.0"
    $requires: {
      cbor: "liasse.cbor@1"   // resolvable, never used below
    }
    $model: {
      n: "int = 0"
      $public: {
        stats: { $view: ".n" }
      }
    }
  }

  hosts: {
    namespaces: [
      {
        id: "liasse.cbor"
        version: "1.2.0"
        interface_hash: "ih-cbor-1"
        functions: {
          encode: { signature: "(int) -> bytes", effect: "pure", op: "double" }
        }
      }
    ]
  }

  expect: {
    outcome: invalid
    violates: ["#host-namespaces", "§16.2"]
    detail: "a declared but unused namespace requirement rejects loading (§16.2 declares only what it uses)"
  }
}

{
  format: 1
  name: requires-key-collides-with-model-name
  suite: static
  spec: ["#host-namespaces", "#expressions", "#conformance"]
  tags: ["aliasing", "shadowing"]
  note: '''
    Attack probe: declare a $requires key equal to the name of a top-level
    model collection ("tasks") so a bare expression head like
    tasks.double(...) could mean either the namespace function or a member
    access on the collection. SPEC.md attests bare-identifier access to
    root model members in expression positions (e.g. "api_keys.verify(
    $credential)" in §11.3 resolves a model-level keyring), and §16.2 makes
    the same bare identifier the expression namespace. §16.2 (SPEC-ISSUES #17)
    pins the single-meaning discipline: "A requirement's local key MUST be
    distinct from every core namespace name (§16.1) and from every top-level
    model declaration name; a colliding key rejects loading, so every bare
    identifier in an expression names exactly one thing." The collision with
    the "tasks" collection therefore rejects the load.
  '''

  package: {
    $liasse: 1
    $app: "t.nscollide@1.0.0"
    $requires: {
      tasks: "test.util@1"
    }
    $model: {
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        weight: "int = 0"
      }
      // ambiguous head: namespace function or collection member?
      probe: { $view: "tasks.double(2)" }
      $public: {
        stats: { $view: ".probe" }
      }
    }
  }

  hosts: {
    namespaces: [
      {
        id: "test.util"
        version: "1.2.0"
        interface_hash: "ih-util-1"
        functions: {
          double: { signature: "(int) -> int", effect: "pure", op: "double" }
        }
      }
    ]
  }

  expect: {
    outcome: invalid
    violates: ["#host-namespaces", "§16.2"]
    detail: "a $requires key colliding with a top-level model declaration name is rejected (single meaning per identifier)"
  }
}

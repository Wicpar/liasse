{
  format: 1
  name: peer-multiple-candidates-need-explicit-binding
  suite: scenario
  spec: ["#modules", "§13.3", "§13.5"]
  note: '''
    §13.5: several compatible candidates require an explicit operator
    binding. §13.3: when peer resolution finds several compatible
    candidates, the install request MUST bind that handle explicitly under
    $use, naming one concrete sibling instance. Without the binding the
    install is rejected; with it, the named sibling's data is used.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "people": { "$view": { "$key": "id", "id": "text", "name": "text" } }
                "roster": { "$view": { "$key": "id", "id": "text", "name": "text" } }
              }
            }
          }
        }
        "$public": {
          "roster": {
            "$view": '/companies["acme"].modules["sales"]::roster'
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    people: {
      "$liasse": 1
      "$module": "t.people@1.0.0"
      "$model": {
        "members": { "$key": "id", "id": "text", "name": "text" }
      }
      "$expose": {
        "people": { "$view": ".members { id, name }" }
      }
    }
    sales: {
      "$liasse": 1
      "$module": "t.sales@1.0.0"
      "$use": {
        "people": "t.people/people@1"
      }
      "$expose": {
        "roster": { "$view": "#people { id, name }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules"
        request: { "$name": "people1", "$module": "t.people@1.0.0"
                   "$data": { "members": { "p1": { "name": "Alice" } } } } }
      expect: { outcome: ok } }
    { module_install: { space: "/companies/acme/modules"
        request: { "$name": "people2", "$module": "t.people@1.0.0"
                   "$data": { "members": { "p2": { "name": "Bob" } } } } }
      expect: { outcome: ok } }
    // two compatible candidates and no explicit binding
    { module_install: { space: "/companies/acme/modules", request: { "$name": "sales", "$module": "t.sales@1.0.0" } }
      expect: { outcome: rejected, violates: ["§13.3", "§13.5"]
                detail: "several compatible candidates require an explicit binding under $use" } }
    // explicit binding to one concrete sibling
    { module_install: { space: "/companies/acme/modules"
        request: { "$name": "sales", "$module": "t.sales@1.0.0"
                   "$use": { "people": "/companies/acme/modules/people2" } } }
      expect: { outcome: ok } }
    { watch: "public.roster", id: "w1"
      expect_init: { value: [ { id: "p2", name: "Bob" } ] } }
  ]
}

{
  format: 1
  name: install-duplicate-instance-name-rejected
  suite: scenario
  spec: ["#modules", "§13.3"]
  note: '''
    §13.3: the instance name is unique within its module space and forms the
    local component of instance identity. A second install under the same
    name in the same space must be rejected; a different name in the same
    space is fine.
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.mod.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          modules: {
            $modules: {
              $interfaces: {
                templates: { $view: { $key: "id", id: "text", label: "text" } }
              }
            }
          }
        }
      }
      $data: { companies: { acme: { name: "Acme" } } }
    }
    tpl: {
      $liasse: 1
      $module: "t.tpl@1.0.0"
      $model: {
        templates: { $key: "id", id: "text", label: "text" }
      }
      $expose: {
        templates: { $view: ".templates { id, label }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { $name: "kit", $module: "t.tpl@1.0.0" } }
      expect: { outcome: ok } }
    { module_install: { space: "/companies/acme/modules", request: { $name: "kit", $module: "t.tpl@1.0.0" } }
      expect: { outcome: rejected, violates: ["§13.3"]
                detail: "instance name must be unique within its module space" } }
    { module_install: { space: "/companies/acme/modules", request: { $name: "kit2", $module: "t.tpl@1.0.0" } }
      expect: { outcome: ok } }
  ]
}

{
  format: 1
  name: interface-mutation-contract-shapes
  suite: scenario
  spec: ["#modules", "§13.8"]
  note: '''
    §13.8: a mutation contract name carries its explicit parameter
    prototype; $return states the required response shape and its omission
    declares a response-free mutation. Calling create through the boundary
    returns exactly the declared shape; calling remove returns no value.
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.mod.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          modules: {
            $modules: {
              $interfaces: {
                templates: {
                  $view: { $key: "id", id: "text", label: "text" }
                  $mut: {
                    "create({ id: text, label: text })": {
                      $return: { id: "text", label: "text" }
                    }
                    "remove({ id: text })": {}
                  }
                }
              }
            }
          }
          catalog: {
            $view: ".modules::templates { module: modules.$key, id, label, $sort: [module, id] }"
          }
        }
        $public: {
          catalog: {
            $params: { company: "text" }
            $view: "/companies[@company].catalog"
          }
          admin: {
            $mut: {
              create: '/companies["acme"].modules["kit"]::templates.create'
              remove: '/companies["acme"].modules["kit"]::templates.remove'
            }
          }
        }
      }
      $data: { companies: { acme: { name: "Acme" } } }
    }
    tpl: {
      $liasse: 1
      $module: "t.tpl@1.0.0"
      $model: {
        templates: { $key: "id", id: "text", label: "text" }
        $mut: {
          create_template: [
            "t = .templates + { id: @id, label: @label }"
            "return t { id, label }"
          ]
          remove_template: [
            ".templates - @id"
          ]
        }
      }
      $expose: {
        templates: {
          $view: ".templates { id, label }"
          $mut: {
            create: ".create_template"
            remove: ".remove_template"
          }
        }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { $name: "kit", $module: "t.tpl@1.0.0" } }
      expect: { outcome: ok } }
    // exactly the declared $return shape: no extra members allowed
    { call: "public.admin.create", args: { id: "t1", label: "Alpha" }
      expect: { outcome: ok, value: { id: "t1", label: "Alpha" } } }
    // response-free contract: omission of $return means no response value
    { call: "public.admin.remove", args: { id: "t1" }
      expect: { outcome: ok, value: "$absent" } }
    { watch: "public.catalog", args: { company: "acme" }, id: "w1"
      expect_init: { value: [] } }
  ]
}

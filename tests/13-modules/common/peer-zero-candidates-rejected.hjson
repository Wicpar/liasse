{
  format: 1
  name: peer-zero-candidates-rejected
  suite: scenario
  spec: ["#modules", "§13.5"]
  note: '''
    §13.5 resolution table: zero candidates reject a required binding. The
    sales module requires t.people/people@1 and no sibling instance exposes
    it, so the install is rejected.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "people": { "$view": { "$key": "id", "id": "text", "name": "text" } }
                "roster": { "$view": { "$key": "id", "id": "text", "name": "text" } }
              }
            }
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    sales: {
      "$liasse": 1
      "$module": "t.sales@1.0.0"
      "$use": {
        "people": "t.people/people@1"
      }
      "$expose": {
        "roster": { "$view": "#people { id, name }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { "$name": "sales", "$module": "t.sales@1.0.0" } }
      expect: { outcome: rejected, violates: ["§13.5"]
                detail: "required peer binding has zero compatible candidates in the module space" } }
  ]
}

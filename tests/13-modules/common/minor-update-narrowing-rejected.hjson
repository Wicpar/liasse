{
  format: 1
  name: minor-update-narrowing-rejected
  suite: scenario
  spec: ["#modules", "§13.14"]
  note: '''
    §13.14: within one package major, minor and patch releases MUST preserve
    or widen the exposed compatibility surface, and package loading rejects
    a narrowing release. Version 1.1.0 drops the exposed create mutation, so
    the update is rejected and the instance keeps operating at 1.0.0.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "templates": {
                  "$view": { "$key": "id", "id": "text", "label": "text" }
                  "$mut": {
                    "create({ id: text, label: text })": {
                      "$return": { "id": "text", "label": "text" }
                    }
                  }
                }
              }
            }
          }
        }
        "$public": {
          "admin": {
            "$mut": { "create": '/companies["acme"].modules["kit"]::templates.create' }
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    tpln1: {
      "$liasse": 1
      "$module": "t.tpln@1.0.0"
      "$model": {
        "templates": { "$key": "id", "id": "text", "label": "text" }
        "$mut": {
          "create_template": [
            "t = .templates + { id: @id, label: @label }"
            "return t { id, label }"
          ]
        }
      }
      "$expose": {
        "templates": {
          "$view": ".templates { id, label }"
          "$mut": { "create": ".create_template" }
        }
      }
    }
    tpln2: {
      "$liasse": 1
      "$module": "t.tpln@1.1.0"
      "$model": {
        "templates": { "$key": "id", "id": "text", "label": "text" }
      }
      "$expose": {
        // narrowing: the create binding is gone in a minor release
        "templates": { "$view": ".templates { id, label }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { "$name": "kit", "$module": "t.tpln@1.0.0" } }
      expect: { outcome: ok } }
    { module_update: { instance: "/companies/acme/modules/kit", to: "t.tpln@1.1.0" }
      expect: { outcome: rejected, violates: ["§13.14"]
                detail: "a minor release narrowing the exposed compatibility surface is rejected" } }
    // the prior instance remains active and fully functional
    { call: "public.admin.create", args: { id: "t1", label: "Alpha" }
      expect: { outcome: ok, value: { id: "t1", label: "Alpha" } } }
  ]
}

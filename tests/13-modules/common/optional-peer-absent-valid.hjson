{
  format: 1
  name: optional-peer-absent-valid
  suite: scenario
  spec: ["#modules", "§13.5"]
  note: '''
    §13.5: the $optional object groups handles whose absence is valid, and
    has(#billing) tests presence in an ordinary runtime expression, choosing
    a value without adding or removing declarations. Installing the consumer
    with no billing sibling succeeds and the expression evaluates the absent
    branch.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "flags": { "$view": { "$key": "id", "id": "text", "billed": "bool" } }
              }
            }
          }
        }
        "$public": {
          "flags": {
            "$view": '/companies["acme"].modules["report"]::flags'
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    report: {
      "$liasse": 1
      "$module": "t.report@1.0.0"
      "$use": {
        "$optional": {
          "billing": "t.billing/summary@1"
        }
      }
      "$model": {
        "flags": { "$key": "id", "id": "text" }
      }
      "$data": { "flags": { "f1": {} } }
      "$expose": {
        "flags": { "$view": ".flags { id, billed: has(#billing) }" }
      }
    }
  }
  root: host

  steps: [
    // no billing sibling exists; the optional handle stays absent and the install succeeds
    { module_install: { space: "/companies/acme/modules", request: { "$name": "report", "$module": "t.report@1.0.0" } }
      expect: { outcome: ok } }
    { watch: "public.flags", id: "w1"
      expect_init: { value: [ { id: "f1", billed: false } ] } }
  ]
}

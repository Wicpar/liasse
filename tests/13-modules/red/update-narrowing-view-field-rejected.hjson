{
  format: 1
  name: update-narrowing-view-field-rejected
  suite: scenario
  spec: ["#modules", "§13.14"]
  note: '''
    §13.14: within one package major, minor and patch releases MUST preserve
    or widen the exposed compatibility surface, and package loading rejects a
    narrowing release. Version 1.0.0 exposes { id, label }; version 1.1.0
    drops "label" from the same exposed view. Even though the host interface
    contract only needs { id }, the module has narrowed its own exposed
    compatibility surface within one major, so the update is rejected and the
    instance keeps running at 1.0.0.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                // permissive contract: only "id" is required, so the drop of
                // "label" is not a contract-satisfaction failure — it is a
                // narrowing of the module's own exposed surface (§13.14).
                "templates": { "$view": { "$key": "id", "id": "text" } }
              }
            }
          }
          "catalog": {
            "$view": ".modules::templates { module: modules.$key, id, $sort: [module, id] }"
          }
        }
        "$public": {
          "catalog": {
            "$params": { "company": "text" }
            "$view": "/companies[@company].catalog"
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    tplw1: {
      "$liasse": 1
      "$module": "t.tplw@1.0.0"
      "$model": {
        "templates": { "$key": "id", "id": "text", "label": "text" }
      }
      "$data": { "templates": { "std": { "label": "Standard" } } }
      "$expose": {
        "templates": { "$view": ".templates { id, label }" }
      }
    }
    tplw2: {
      "$liasse": 1
      "$module": "t.tplw@1.1.0"
      "$model": {
        "templates": { "$key": "id", "id": "text", "label": "text" }
      }
      "$data": { "templates": { "std": { "label": "Standard" } } }
      "$expose": {
        // narrowing: the exposed view drops "label" in a minor release
        "templates": { "$view": ".templates { id }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { "$name": "kit", "$module": "t.tplw@1.0.0" } }
      expect: { outcome: ok } }
    { module_update: { instance: "/companies/acme/modules/kit", to: "t.tplw@1.1.0" }
      expect: { outcome: rejected, violates: ["§13.14"]
                detail: "a minor release that removes an exposed view field narrows the compatibility surface and is rejected" } }
    // the instance still runs at 1.0.0
    { watch: "public.catalog", args: { company: "acme" }, id: "w1"
      expect_init: { value: [ { module: "kit", id: "std" } ] } }
  ]
}

{
  format: 1
  name: interface-mutation-param-contract-mismatch-invalid
  suite: scenario
  spec: ["#modules", "§13.8"]
  note: '''
    §13.8: a mutation contract name carries its explicit parameter prototype,
    and mutation bindings MUST satisfy their declared parameter and response
    contracts. The interface contract declares create({ id: text }) — only an
    "id" parameter is available across the boundary. The bound private
    mutation create_template reads @label as well, a parameter the contract
    never supplies, so the binding cannot satisfy the declared parameter
    prototype and the install fails validation. (The response-contract
    direction is covered by common/expose-binding-contract-mismatch-invalid;
    this isolates the parameter-contract direction.)
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.mod.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          modules: {
            $modules: {
              $interfaces: {
                templates: {
                  $view: { $key: "id", id: "text", label: "text" }
                  $mut: {
                    // the boundary supplies only "id" to create
                    "create({ id: text })": {
                      $return: { id: "text" }
                    }
                  }
                }
              }
            }
          }
        }
      }
      $data: { companies: { acme: { name: "Acme" } } }
    }
    tplp: {
      $liasse: 1
      $module: "t.tplp@1.0.0"
      $model: {
        templates: { $key: "id", id: "text", label: "text" }
        $mut: {
          // needs @label, which the interface parameter prototype does not declare
          create_template: [
            "t = .templates + { id: @id, label: @label }"
            "return t { id }"
          ]
        }
      }
      $expose: {
        templates: {
          $view: ".templates { id, label }"
          $mut: { create: ".create_template" }
        }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { $name: "kit", $module: "t.tplp@1.0.0" } }
      expect: { outcome: invalid, violates: ["§13.8"]
                detail: "the bound mutation requires a parameter the interface contract does not declare; parameter contracts must be satisfied" } }
  ]
}

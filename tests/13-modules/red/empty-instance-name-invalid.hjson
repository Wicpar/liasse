{
  format: 1
  name: empty-instance-name-invalid
  suite: scenario
  spec: ["#modules", "§13.3"]
  note: '''
    §13.3: the instance name is a non-empty text value and forms the local
    component of instance identity. An install request supplying an empty
    "$name" violates that rule and is rejected before the instance becomes
    active.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "templates": { "$view": { "$key": "id", "id": "text", "label": "text" } }
              }
            }
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    tpl: {
      "$liasse": 1
      "$module": "t.tpl@1.0.0"
      "$model": {
        "templates": { "$key": "id", "id": "text", "label": "text" }
      }
      "$expose": {
        "templates": { "$view": ".templates { id, label }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { "$name": "", "$module": "t.tpl@1.0.0" } }
      expect: { outcome: invalid, violates: ["§13.3"]
                detail: "the instance name must be a non-empty text value" } }
  ]
}

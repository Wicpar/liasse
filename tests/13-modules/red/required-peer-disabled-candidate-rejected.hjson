{
  format: 1
  name: required-peer-disabled-candidate-rejected
  suite: scenario
  spec: ["#modules", "§13.3", "§13.5", "§13.12"]
  note: '''
    §13.12: disabling an instance removes its peer availability while
    retaining private state. §13.5: a required peer needs a compatible
    candidate in the sibling space. The only "people" sibling is disabled
    before "sales" is installed, so its interface is unavailable for
    resolution and the required binding is rejected.
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.mod.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          modules: {
            $modules: {
              $interfaces: {
                people: { $view: { $key: "id", id: "text", name: "text" } }
                roster: { $view: { $key: "id", id: "text", name: "text" } }
              }
            }
          }
        }
      }
      $data: { companies: { acme: { name: "Acme" } } }
    }
    people: {
      $liasse: 1
      $module: "t.people@1.0.0"
      $model: {
        members: { $key: "id", id: "text", name: "text" }
      }
      $expose: {
        people: { $view: ".members { id, name }" }
      }
    }
    sales: {
      $liasse: 1
      $module: "t.sales@1.0.0"
      $use: {
        people: "t.people/people@1"
      }
      $expose: {
        roster: { $view: "#people { id, name }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules"
        request: { $name: "people", $module: "t.people@1.0.0"
                   $data: { members: { p1: { name: "Alice" } } } } }
      expect: { outcome: ok } }
    // disabling removes the peer availability
    { module_disable: { instance: "/companies/acme/modules/people" }
      expect: { outcome: ok } }
    // the only candidate is disabled: the required binding has no available candidate
    { module_install: { space: "/companies/acme/modules", request: { $name: "sales", $module: "t.sales@1.0.0" } }
      expect: { outcome: rejected, violates: ["§13.5", "§13.12"]
                detail: "a disabled sibling exposes no peer availability; the required binding has no candidate" } }
  ]
}

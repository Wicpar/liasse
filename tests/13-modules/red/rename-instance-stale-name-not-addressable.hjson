{
  format: 1
  name: rename-instance-stale-name-not-addressable
  suite: scenario
  spec: ["#modules", "§13.3"]
  note: '''
    §13.3: the instance name forms the local component of instance identity,
    and renaming an instance is a rekey that updates refs and bindings under
    the ordinary key-mutation rule. After renaming "kit" to "kit2", the row's
    data moves with its incarnation to the new identity: a view selecting the
    old name "kit" now selects nothing, while the aggregation and the new
    name carry the same rows.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "templates": { "$view": { "$key": "id", "id": "text", "label": "text" } }
              }
            }
          }
          "catalog": {
            "$view": ".modules::templates { module: modules.$key, id, label, $sort: [module, id] }"
          }
        }
        "$public": {
          "catalog": {
            "$params": { "company": "text" }
            "$view": "/companies[@company].catalog"
          }
          // statically bound to the literal old name "kit"
          "kit_view": {
            "$view": '/companies["acme"].modules["kit"]::templates'
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    tpl: {
      "$liasse": 1
      "$module": "t.tpl@1.0.0"
      "$model": {
        "templates": { "$key": "id", "id": "text", "label": "text" }
      }
      "$data": { "templates": { "t1": { "label": "Alpha" } } }
      "$expose": {
        "templates": { "$view": ".templates { id, label }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { "$name": "kit", "$module": "t.tpl@1.0.0" } }
      expect: { outcome: ok } }
    // before rename: both the fixed "kit" view and the aggregation see the row
    { watch: "public.kit_view", id: "wk", expect_init: { value: [ { id: "t1", label: "Alpha" } ] } }
    { watch: "public.catalog", args: { company: "acme" }, id: "wc"
      expect_init: { value: [ { module: "kit", id: "t1", label: "Alpha" } ] } }
    // rekey the instance to a new name
    { module_rename: { instance: "/companies/acme/modules/kit", to: "kit2" }
      expect: { outcome: ok } }
    // the old literal name resolves to nothing; the data moved with the incarnation
    { expect_view: { watch: "wk", value: [] } }
    { expect_view: { watch: "wc", value: [ { module: "kit2", id: "t1", label: "Alpha" } ] } }
  ]
}

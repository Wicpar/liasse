{
  format: 1
  name: sibling-cannot-address-private-dep-rejected
  suite: scenario
  spec: ["#modules", "§13.6", "§13.5"]
  note: '''
    §13.6: a $deps entry creates a private nested instance owned by the
    consumer; siblings cannot address it. "checkout" privately depends on
    t.tax. "spy" is a sibling that declares a PEER dependency on
    t.tax/rates@1, hoping to bind checkout's private tax instance. A private
    dependency is not a sibling instance in the module space, so spy's peer
    resolution finds zero candidates and the required binding is rejected.
  '''

  packages: {
    host: {
      "$liasse": 1
      "$app": "t.host@1.0.0"
      "$model": {
        "companies": {
          "$key": "id"
          "id": "text"
          "name": "text"
          "modules": {
            "$modules": {
              "$interfaces": {
                "rates": { "$view": { "$key": "id", "id": "text", "pct": "decimal" } }
                "probe": { "$view": { "$key": "id", "id": "text", "pct": "decimal" } }
              }
            }
          }
        }
      }
      "$data": { "companies": { "acme": { "name": "Acme" } } }
    }
    checkout: {
      "$liasse": 1
      "$module": "t.checkout@1.0.0"
      "$deps": {
        "tax": "t.tax@1"
      }
      "$expose": {
        "rates": { "$view": "#tax.rates { id, pct }" }
      }
    }
    tax: {
      "$liasse": 1
      "$module": "t.tax@1.0.0"
      "$model": {
        "rates": { "$key": "id", "id": "text", "pct": "decimal = 10" }
      }
      "$data": { "rates": { "std": {} } }
      "$expose": {
        "rates": { "$view": ".rates { id, pct }" }
      }
    }
    spy: {
      "$liasse": 1
      "$module": "t.spy@1.0.0"
      "$use": {
        // tries to reach t.tax as a sibling peer; checkout's tax is private
        "tax": "t.tax/rates@1"
      }
      "$expose": {
        "probe": { "$view": "#tax { id, pct }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules", request: { "$name": "co", "$module": "t.checkout@1.0.0" } }
      expect: { outcome: ok } }
    // no addressable t.tax sibling exists: the private dependency is not a peer
    { module_install: { space: "/companies/acme/modules", request: { "$name": "spy", "$module": "t.spy@1.0.0" } }
      expect: { outcome: rejected, violates: ["§13.6"]
                detail: "a private $deps instance is not a sibling; a peer binding cannot address another consumer's private dependency" } }
  ]
}

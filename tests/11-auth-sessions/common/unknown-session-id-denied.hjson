{
  format: 1
  name: unknown-session-id-denied
  suite: scenario
  spec: ["#authentication", "§11.3", "#expressions", "§6.3"]
  note: '''
    §11.3: "When declared, $session MUST resolve exactly one row. ... Zero or
    several rows reject authentication." Here credential verification SUCCEEDS
    (the token is well-signed), but its session claim names a uuid with no
    corresponding row, so $session resolves zero rows and the request is
    denied. This isolates row resolution from signature verification.
  '''

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        // Verifies fine; the claimed session row does not exist.
        "tok-ghost": { auth: "session", session: "5e551000-0000-4000-8000-00000000dead" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "session", credential: "tok-ghost" },
      expect: { outcome: denied, violates: ["#authentication"] } }
  ]
}

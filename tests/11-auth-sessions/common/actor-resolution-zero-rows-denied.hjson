{
  format: 1
  name: actor-resolution-zero-rows-denied
  suite: scenario
  spec: ["#authentication", "§11.3", "#expressions", "§6.3"]
  note: '''
    §11.3: "$actor MUST resolve exactly one row. Zero or several rows reject
    authentication." The api_key authenticator declares no $session, so this
    isolates the $actor binding: the credential verifies, but its account
    claim names no existing account row, so $actor resolves zero rows.
  '''

  package: {
    $liasse: 1
    $app: "t.auth.key@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        api_key: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $actor: "/accounts[$proof.account]"
          $check: "$proof.auth == $auth_name"
        }
      }
      $roles: {
        automation: {
          $auth: "api_key"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        // Verifies fine; the claimed account row does not exist.
        "key-ghost": { auth: "api_key", account: "aaaaaaaa-0000-4000-8000-00000000dead" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { call: "automation.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "api_key", credential: "key-ghost" },
      expect: { outcome: denied, violates: ["#authentication"] } }
  ]
}

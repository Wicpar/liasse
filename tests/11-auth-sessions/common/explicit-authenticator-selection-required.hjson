{
  format: 1
  name: explicit-authenticator-selection-required
  suite: scenario
  spec: ["#authentication", "§11.4"]
  note: '''
    §11.4: "Every authenticated request names both the role and one accepted
    authenticator, including roles that accept exactly one." The member role
    accepts exactly one authenticator, and the credential itself is valid, but
    the request does not name an authenticator, so it must not authenticate.
    There is no implicit or defaulted authenticator selection.
  '''

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    // A valid credential without an authenticator name: the request fails
    // authentication because selection is explicit at every request (§11.4).
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { credential: "tok-alice" },
      expect: { outcome: denied, violates: ["#authentication"] } }
    // Sanity: the same credential with the authenticator named succeeds,
    // isolating the missing selection as the only cause of the denial.
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "x"
      } } }
  ]
}

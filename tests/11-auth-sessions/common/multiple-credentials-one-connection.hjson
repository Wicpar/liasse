{
  format: 1
  name: multiple-credentials-one-connection
  suite: scenario
  spec: ["#authentication", "§11.8"]
  note: '''
    §11.8: "A client MAY hold several credentials at once. ... Each call
    selects a compatible credential for the targeted role. Liasse defines no
    global current session." One logical connection interleaves calls under
    two different sessions; each call is attributed to the credential it
    names, and using Bob's credential does not displace Alice's.
  '''

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
        "bbbbbbbb-0000-4000-8000-000000000002": { name: "bob" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
        "5e551000-0000-4000-8000-000000000002": {
          account: "bbbbbbbb-0000-4000-8000-000000000002"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
        "tok-bob": { auth: "session", session: "5e551000-0000-4000-8000-000000000002" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { call: "member.notes.add", args: { body: "from alice" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "from alice"
      } } }
    { call: "member.notes.add", args: { body: "from bob" }, on: "c1",
      auth: { auth: "session", credential: "tok-bob" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "bbbbbbbb-0000-4000-8000-000000000002"
        body: "from bob"
      } } }
    // No global current session: Alice's credential still selects Alice.
    { call: "member.notes.add", args: { body: "alice again" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "alice again"
      } } }
  ]
}

{
  format: 1
  name: role-auth-list-accepts-any-listed
  suite: scenario
  spec: ["#authentication", "§11.4"]
  note: '''
    §11.4: "A string $auth accepts one named authenticator. A sequence accepts
    any listed authenticator." The automation role lists both authenticators;
    a request may select either one, and both resolve the same actor row here.
  '''

  package: {
    $liasse: 1
    $app: "t.auth.two@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
        api_key: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $actor: "/accounts[$proof.account]"
          $check: "$proof.auth == $auth_name"
        }
      }
      $roles: {
        automation: {
          $auth: ["session", "api_key"]
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
        "key-alice": { auth: "api_key", account: "aaaaaaaa-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { call: "automation.notes.add", args: { body: "via session" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "via session"
      } } }
    { call: "automation.notes.add", args: { body: "via api key" }, on: "c1",
      auth: { auth: "api_key", credential: "key-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "via api key"
      } } }
  ]
}

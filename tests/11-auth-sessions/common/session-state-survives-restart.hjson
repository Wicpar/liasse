{
  format: 1
  name: session-state-survives-restart
  suite: scenario
  spec: ["#authentication", "§11.2", "#runtime"]
  note: '''
    §11.2: accounts, logins, and sessions "remain ordinary application state"
    — application rows, not runtime-local memory. A restart replays the
    runtime (FORMAT.md: durable state must survive), so a session committed
    before the restart still authenticates the same token afterwards. An
    implementation keeping sessions only in process memory fails this case.
  '''

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "2026-02-01T00:00:00Z"
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1", authenticate: { auth: "session", credential: "tok-alice" } }
    { call: "member.notes.add", args: { body: "before restart" }, on: "c1",
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "before restart"
      } } }
    { restart: {} }
    { connect: "c2", authenticate: { auth: "session", credential: "tok-alice" } }
    { call: "member.notes.add", args: { body: "after restart" }, on: "c2",
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "after restart"
      } } }
  ]
}

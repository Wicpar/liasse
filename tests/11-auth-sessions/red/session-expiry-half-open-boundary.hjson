{
  format: 1
  name: session-expiry-half-open-boundary
  suite: scenario
  spec: ["#authentication", "§11.7", "#buckets", "§14.1"]
  tags: ["boundary"]
  note: '''
    §14.1: every bucket interval is half-open, [$from, $until), and "At the
    upper bound, the row is no longer active." One second before expires_at
    the session authenticates; at exactly expires_at it must not. An
    implementation using an inclusive upper bound ("<=") authenticates one
    instant too long and fails the last step.
  '''

  // Pedantic-implementer probe: off-by-one on the interval's upper bound.
  // Clock starts 2026-01-01T00:00:00Z; the session expires at 01:00:00Z.

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "1767229200000000"  // 2026-01-01T01:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1", authenticate: { auth: "session", credential: "tok-alice" } }
    // 2026-01-01T00:59:59Z — strictly inside [created, expires_at).
    { advance_time: "PT59M59S" }
    { call: "member.notes.add", args: { body: "one second left" }, on: "c1",
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "one second left"
      } } }
    // 2026-01-01T01:00:00Z — exactly the upper bound: no longer active.
    { advance_time: "PT1S" }
    { call: "member.notes.add", args: { body: "at the bound" }, on: "c1",
      expect: { outcome: denied, violates: ["#authentication", "#buckets"] } }
  ]
}

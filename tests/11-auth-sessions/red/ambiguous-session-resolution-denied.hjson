{
  format: 1
  name: ambiguous-session-resolution-denied
  suite: scenario
  spec: ["#authentication", "§11.3", "#expressions", "§6.3"]
  tags: ["fixation", "aliasing"]
  note: '''
    §11.3: "When declared, $session MUST resolve exactly one row. Zero or
    several rows reject authentication." The authenticator resolves the
    session by a NON-key predicate (device label). Two active sessions share
    the label, so $session resolves two rows. The runtime must fail closed —
    picking the first, newest, or "matching account" row would silently bind
    the attacker-controlled row.
  '''

  // Attack: session-fixation flavored collision. Mallory registers a session
  // whose device label equals the label embedded in kiosk tokens. Any request
  // authenticating by that label now resolves two candidate session rows:
  // Alice's and Mallory's. An implementation that picks one instead of
  // rejecting can be steered into Mallory's session.

  package: {
    $liasse: 1
    $app: "t.auth.device@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        device: "text?"
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        device: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[:s | s.device == $proof.device]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "device"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
        "cccccccc-0000-4000-8000-000000000003": { name: "mallory" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          device: "kiosk-1"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
        "5e551000-0000-4000-8000-000000000003": {
          account: "cccccccc-0000-4000-8000-000000000003"
          device: "kiosk-1"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-kiosk": { auth: "device", device: "kiosk-1" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "device", credential: "tok-kiosk" },
      expect: { outcome: denied, violates: ["#authentication"] } }
  ]
}

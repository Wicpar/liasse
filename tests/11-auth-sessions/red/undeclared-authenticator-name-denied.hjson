{
  format: 1
  name: undeclared-authenticator-name-denied
  suite: scenario
  spec: ["#authentication", "§11.4", "§11.3"]
  tags: ["authz"]
  note: '''
    §11.4: "Each role names every authenticator it accepts, and each request
    names one of them." The request names an authenticator that the package
    does not declare in $auth at all (not merely one the role rejects). There
    is no authenticator to invoke, so the request is denied. This differs from
    authenticator-not-accepted-by-role, where the named authenticator exists
    but the role does not list it.
  '''

  // Attack: name a nonexistent authenticator ("ghost"), pairing it with a
  // credential that is perfectly valid under the real "session" authenticator,
  // to probe whether an unknown selector falls back to some default or to the
  // credential's own embedded auth claim.

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "1769904000000000"  // 2026-02-01T00:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    // "ghost" is not a member of $auth: no authenticator to select.
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "ghost", credential: "tok-alice" },
      expect: { outcome: denied, violates: ["#authentication"] } }
    // Sanity: the same credential under the real authenticator succeeds,
    // isolating the undeclared name as the only cause of the denial.
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "x"
      } } }
  ]
}

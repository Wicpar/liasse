{
  format: 1
  name: forged-token-fails-verification
  suite: scenario
  spec: ["#authentication", "§11.3", "#host-namespaces", "§16.3"]
  tags: ["forgery"]
  note: '''
    §11.3: $verify validates the credential; §16.3: a verifier "validates
    untrusted input against declared keys/configuration and returns a typed
    proof or diagnostic". Credentials not produced by the application's signer
    (and not pre-issued) yield a diagnostic instead of a proof, so no binding
    resolves and authentication fails.
  '''

  // Attack: the attacker has no signing key. They submit (a) a self-crafted
  // token, (b) a truncated/tampered variant of a real token's shape, and
  // (c) the empty string. None was produced by token.sign and none is listed
  // in hosts.token.tokens, so all must fail verification.

  package: {
    $liasse: 1
    $app: "t.auth@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          expires_at: "2026-02-01T00:00:00Z"
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "session", credential: "self-signed-by-attacker" },
      expect: { outcome: denied, violates: ["#authentication"] } }
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice-tampered" },
      expect: { outcome: denied, violates: ["#authentication"] } }
    { call: "member.notes.add", args: { body: "x" }, on: "c1",
      auth: { auth: "session", credential: "" },
      expect: { outcome: denied, violates: ["#authentication"] } }
  ]
}

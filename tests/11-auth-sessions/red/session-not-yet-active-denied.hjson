{
  format: 1
  name: session-not-yet-active-denied
  suite: scenario
  spec: ["#authentication", "§11.3", "#buckets", "§14.1", "§14.2"]
  tags: ["boundary"]
  note: '''
    §14.2/§14.1: a bucket interval is half-open [$from, $until); an explicit
    $from delays activation, and "Ordinary selectors on the collection still
    return only rows active at their evaluation time." Before $from the session
    row is not active, so /sessions[$proof.session] yields zero rows, $session
    resolves zero rows, and §11.3 rejects. At exactly $from (lower bound
    inclusive) the same token authenticates, with no state change between.
  '''

  // Attack: present a token for a session whose activation window has not
  // opened yet (post-dated / staged session), probing whether the runtime
  // honors only $until and ignores $from.

  package: {
    $liasse: 1
    $app: "t.auth.staged@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        $bucket: { $from: ".starts_at", $until: ".expires_at" }
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        starts_at: "timestamp"
        expires_at: "timestamp"
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "note = .notes + { author: $actor, body: @body }"
          "return note { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $view: ".notes[:n | n.author == $actor] { id, body }"
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        // Activation opens 2026-06-01; clock starts 2026-01-01.
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
          starts_at: "1780272000000000"  // 2026-06-01T00:00:00Z
          expires_at: "1782864000000000"  // 2026-07-01T00:00:00Z
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1" }
    // 2026-01-01: before $from, the session is not active.
    { call: "member.notes.add", args: { body: "too early" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: denied, violates: ["#authentication", "#buckets"] } }
    // Advance to exactly $from (2026-06-01); lower bound is inclusive.
    { advance_time: "P5M" }
    { call: "member.notes.add", args: { body: "now active" }, on: "c1",
      auth: { auth: "session", credential: "tok-alice" },
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "now active"
      } } }
  ]
}

{
  format: 1
  name: empty-surface-declaration-unspecified
  suite: static
  spec: ["#interfaces", "§10.1"]
  tags: ["boundary"]
  note: '''
    Boundary probe: a surface declaring neither $params, $view, nor $mut.
    Annex C.10 marks all three members optional ($params?, $view?, $mut?),
    which admits the empty object, while §10.1 says a surface "MAY expose a
    parameterized view, named mutations, or both", suggesting at least one
    exposing member. The spec neither forbids the empty surface nor gives it
    any meaning (nothing can be called or watched through it). Whether the
    package loads is unspecified.
  '''

  package: {
    "$liasse": 1
    "$app": "t.empty_surface@1.0.0"
    "$model": {
      "tasks": {
        "$key": "id"
        "id": "text"
        "title": "text"
      }
      "$public": {
        "void": {}
      }
    }
  }

  expect: {
    outcome: unspecified
    detail: "grammar admits an empty surface; prose implies a surface exposes something"
  }
}

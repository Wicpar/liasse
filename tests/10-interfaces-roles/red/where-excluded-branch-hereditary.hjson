{
  format: 1
  name: where-excluded-branch-hereditary
  suite: scenario
  spec: ["#interfaces", "§10.5"]
  tags: ["recursive"]
  note: '''
    SPEC-ISSUES #11(b), pinned. §10.5 now makes $where hereditary exactly like
    $except: recursion descends only into INCLUDED candidates (satisfying
    $where and not $except), and a $where-excluded (or $except-pruned) node
    contributes no output slot AND none of its descendants are surfaced or
    reparented. So over root -> b (plan == closed, $where-excluded) -> b1
    (active, would satisfy $where): b is excluded and, because $where is
    hereditary, its descendant b1 is NOT surfaced anywhere — no promotion, no
    reparenting. Root's coverage view therefore has no included children.
    ($where allow-list / $except deny-list, deny overrides; both hereditary.)
    The nested keyed view under $field is rendered as the row array the sibling
    recursive cases use, so an empty level is the empty array.
  '''

  package: {
    $liasse: 1
    $app: "t.rec_where_gap@1.0.0"
    $model: {
      accounts: {
        $key: "id"
        id: "text"
      }
      companies: {
        $key: "id"
        id: "text"
        name: "text"
        plan: "text = 'active'"
        subcompanies: { $like: "^" }
        members: {
          $key: "account"
          account: { $ref: "/accounts" }
          admin: "bool = false"
        }
        $roles: {
          admin: {
            $auth: "token"
            $members: ".members[:m | m.admin].account"
            company: {
              $view: ". { id, name, plan }"
              $recursive: {
                $field: "subcompanies"
                $through: ".subcompanies"
                $bind: "child"
                $where: "child.plan != 'closed'"
              }
            }
          }
        }
      }
      $auth: {
        token: {
          $credential: "text"
          $verify: "$credential"
          $actor: "/accounts[$proof]"
        }
      }
    }
    $data: {
      accounts: { alice: {} }
      companies: {
        root: {
          name: "Root"
          members: { alice: { admin: true } }
          subcompanies: {
            b: {
              name: "Closed Branch"
              plan: "closed"
              subcompanies: {
                // Satisfies $where but sits under a $where-excluded child, so
                // hereditary $where keeps it out of the surfaced tree entirely.
                b1: { name: "Active under closed" }
              }
            }
          }
        }
      }
    }
  }

  steps: [
    { connect: "c1", authenticate: { role: "admin", auth: "token", credential: "alice" } }
    // b is $where-excluded and b1 is under it, so hereditary $where surfaces
    // neither: root's coverage view has an empty included-children level.
    { watch: "admin.company", scope: "root", id: "w1",
      expect_init: { value: {
        id: "root"
        name: "Root"
        plan: "active"
        subcompanies: []
        "...": true
      } } }
  ]
}

{
  format: 1
  name: unresolvable-name-outcome-unspecified
  suite: scenario
  spec: ["#interfaces", "§10.3", "§10.4", "#clients"]
  tags: ["authz", "enumeration"]
  note: '''
    Two related gaps discovered while writing this chapter's corpus.
    (1) Failure classification: §12.1 step 1 resolves "the targeted public
    surface or scoped role surface", and §10.4 makes exposure the only access
    grant, so a request naming a surface that exists nowhere MUST fail — but
    the spec never classifies that failure (authorization-style denial vs. a
    distinct not-found error). The rest of this corpus maps unresolvable and
    ungranted names to `denied` as a documented convention (see NOTES.md);
    this case records that the spec itself does not pin the category.
    (2) Enumeration leak: the spec does not say whether the response for a
    nonexistent surface must be indistinguishable from the response for an
    existing surface the caller is not granted ("admin.control" vs
    "admin.mirage" below). If they are distinguishable, an unauthorized
    caller can enumerate which surfaces a role declares.
  '''

  package: {
    "$liasse": 1
    "$app": "t.enum_probe@1.0.0"
    "$model": {
      "accounts": {
        "$key": "id"
        "id": "text"
        "is_admin": "bool = false"
      }
      "notes": {
        "$key": "id"
        "id": "text"
        "body": "text"
      }
      "$mut": {
        "wipe_notes": "-.notes[:n]"
      }
      "$auth": {
        "token": {
          "$credential": "text"
          "$verify": "$credential"
          "$actor": "/accounts[$proof]"
        }
      }
      "$roles": {
        "member": {
          "$auth": "token"
          "$members": ".accounts"
          "notes": { "$view": ".notes { id, body }" }
        }
        "admin": {
          "$auth": "token"
          "$members": ".accounts[:a | a.is_admin]"
          "control": {
            "$mut": { "wipe": ".wipe_notes" }
          }
        }
      }
    }
    "$data": {
      "accounts": { "alice": {} }
    }
  }

  steps: [
    { connect: "c1", authenticate: { role: "admin", auth: "token", credential: "alice" } }
    // Existing surface, ungranted actor: an authorization denial.
    { call: "admin.control.wipe", args: {}, on: "c1",
      expect: { outcome: denied, violates: ["#interfaces"] } }
    // Nonexistent surface under the same role: the spec pins failure but not
    // its classification, nor whether it must be indistinguishable from the
    // denial above.
    { call: "admin.mirage.wipe", args: {}, on: "c1",
      expect: { outcome: unspecified } }
  ]
}

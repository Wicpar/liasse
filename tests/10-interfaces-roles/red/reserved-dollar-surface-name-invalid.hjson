{
  format: 1
  name: reserved-dollar-surface-name-invalid
  suite: static
  // Aliasing attack on the declaration grammar: put a member named "$view"
  // directly inside $public, trying to make the surface MAP itself parse as
  // one surface declaration. §10.2: "$public maps external surface names to
  // surface declarations" — its members are surface names. §2.5: names
  // beginning with `$` are reserved by Liasse, declaration names MUST begin
  // with an ASCII letter, and unknown members in a declaration object are
  // invalid. The package must be rejected, not reinterpreted.
  spec: ["#conformance", "#interfaces", "§10.2"]
  tags: ["aliasing"]

  package: {
    $liasse: 1
    $app: "t.dollar_name@1.0.0"
    $model: {
      products: {
        $key: "id"
        id: "text"
        name: "text"
      }
      $public: {
        // Invalid: "$view" is not a legal external surface name, and $public
        // does not accept a $view member of its own.
        $view: ".products { id, name }"
      }
    }
  }

  expect: {
    outcome: invalid
    violates: ["#conformance", "#interfaces"]
    detail: "$public members are surface names; reserved $-names are not surface names"
  }
}

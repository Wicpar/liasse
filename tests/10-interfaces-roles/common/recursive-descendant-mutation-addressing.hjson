{
  format: 1
  name: recursive-descendant-mutation-addressing
  suite: scenario
  spec: ["#interfaces", "§10.5", "§10.3"]
  tags: ["recursive"]
  note: '''
    SPEC-ISSUES #11(a), pinned. §10.5 propagates "the same surface projection
    and mutations" to included children, so a covered descendant must be
    mutable through the propagated surface. §10.5 now pins the addressing: an
    external request names a covered descendant receiver by the role handle
    (containing row identity + role name, §10.3) TOGETHER WITH the descendant's
    key path from that row down through $field/$through. Admission re-walks the
    recursive relation along the whole path (strict, $where-included,
    non-$except at every step) and binds the addressed descendant as the
    mutation `.` receiver; the role-holding row is the empty path. Here the
    `descendant` member carries that single-segment key path ("a") under the
    role scope row "root", so renaming the covered subcompany "a" succeeds.
  '''

  package: {
    $liasse: 1
    $app: "t.rec_mut_addr@1.0.0"
    $model: {
      accounts: {
        $key: "id"
        id: "text"
      }
      companies: {
        $key: "id"
        id: "text"
        name: "text"
        plan: "text = 'active'"
        subcompanies: { $like: "^" }
        members: {
          $key: "account"
          account: { $ref: "/accounts" }
          admin: "bool = false"
        }
        $mut: {
          rename: [
            ".name = @name"
            "return . { id, name }"
          ]
        }
        $roles: {
          admin: {
            $auth: "token"
            $members: ".members[:m | m.admin].account"
            company: {
              $view: ". { id, name, plan }"
              $mut: { rename: ".rename" }
              $recursive: {
                $field: "subcompanies"
                $through: ".subcompanies"
                $bind: "child"
              }
            }
          }
        }
      }
      $auth: {
        token: {
          $credential: "text"
          $verify: "$credential"
          $actor: "/accounts[$proof]"
        }
      }
    }
    $data: {
      accounts: { alice: {} }
      companies: {
        root: {
          name: "Root"
          members: { alice: { admin: true } }
          subcompanies: {
            a: { name: "Branch A" }
          }
        }
      }
    }
  }

  steps: [
    { connect: "c1", authenticate: { role: "admin", auth: "token", credential: "alice" } }
    // The role-holding row is the empty descendant path: renaming the root row
    // itself is addressed by the role handle alone.
    { call: "admin.company.rename", scope: "root", args: { name: "Root 2" }, on: "c1",
      expect: { outcome: ok, value: { id: "root", name: "Root 2" } } }
    // The covered descendant "a" is addressed by its key path under the scope
    // row; admission re-walks $through and binds "a" as the mutation receiver.
    { call: "admin.company.rename", scope: "root", descendant: "a",
      args: { name: "Branch A 2" }, on: "c1",
      expect: { outcome: ok, value: { id: "a", name: "Branch A 2" } } }
  ]
}

{
  format: 1
  name: distinct-collapses-duplicates-canonical-order
  suite: scenario
  spec: ["#views", "§7.5", "§5.5", "§B.1"]
  tags: ["identity"]
  note: "§7.5: 'distinct(view.field) -> set<field type>.' §5.5: sets collapse repeated input values to one member and 'have canonical read order from the element type's total order.' §B.1: text order is Unicode scalar order. Inputs { b, a, b, a } distinct to the set { a, b } read in text-ascending order."

  package: {
    $liasse: 1
    $app: "t.viewdistinct@1.0.0"
    $model: {
      items: {
        $key: "id"
        id: "text"
        cat: "text"
      }
      cats: "= distinct(.items.cat)"
      $public: {
        stat: { $view: ". { cats }" }
      }
    }
    $data: {
      items: {
        i1: { cat: "b" }
        i2: { cat: "a" }
        i3: { cat: "b" }
        i4: { cat: "a" }
      }
    }
  }

  steps: [
    { watch: "public.stat", id: "w1",
      expect_init: { value: { cats: [ "a", "b" ] } } }
  ]
}

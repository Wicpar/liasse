{
  format: 1
  name: negative-limit-invalid
  suite: static
  spec: ["#views", "§7.3"]
  tags: ["boundary"]
  note: "Attack: a negative $limit, hoping it means 'unbounded' or 'from the end'. §7.3: '$limit keeps at most the next non-negative number.' A negative bound is not a non-negative number, so the view declaration is statically invalid."

  package: {
    $liasse: 1
    $app: "t.viewneglimit@1.0.0"
    $model: {
      items: {
        $key: "id"
        id: "text"
      }
      $public: {
        page: { $view: ".items { id, $limit: -1 }" }
      }
    }
  }

  expect: {
    outcome: "invalid"
    violates: ["#views"]
    detail: "$limit must be a non-negative number; -1 is invalid"
  }
}

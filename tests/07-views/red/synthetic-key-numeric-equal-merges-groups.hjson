{
  format: 1
  name: synthetic-key-numeric-equal-merges-groups
  suite: scenario
  spec: ["#views", "§7.2", "§B.1", "§B.4"]
  tags: ["identity", "boundary"]
  note: "Attack: two differently-written but numerically-equal decimal grouping keys ('1.0' and '1.00') expecting two separate groups. §7.2: 'Rows sharing the synthetic key form one group.' §B.1: 'numerically equal canonical values compare equal' for decimal. So 1.0 and 1.00 are the SAME group; their debits sum together (1 + 2 = 3), leaving two groups total. The canonical wire form of the merged decimal key is not pinned (Annex A.1 leaves the representative among equal inputs unspecified), so 'bucket' is matched with $any; the merge itself — two groups, first total 3 — is the asserted rule."

  package: {
    $liasse: 1
    $app: "t.viewnumkey@1.0.0"
    $model: {
      lines: {
        $key: "id"
        id: "text"
        bucket: "decimal"
        debit: "int"
      }
      $public: {
        totals: { $view: ".lines { $key: bucket, bucket, total: sum(group.debit) }" }
      }
    }
    $data: {
      lines: {
        l1: { bucket: "1.0", debit: "1" }
        l2: { bucket: "1.00", debit: "2" }
        l3: { bucket: "2", debit: "5" }
      }
    }
  }

  steps: [
    { watch: "public.totals", id: "w1",
      expect_init: { value: [
        { bucket: "$any", total: "3" }
        { bucket: "$any", total: "5" }
      ] } }
  ]
}

{
  format: 1
  name: synthetic-key-new-identity-nonaggregated-unspecified
  suite: static
  spec: ["#views", "§7.2"]
  tags: ["grouping", "identity"]
  note: "Pinned (SPEC-ISSUES #12). §7.2 now states that the 'aggregated or key-derived' constraint applies to every projection declaring a synthetic $key, whether it collapses rows into a group or re-identifies each source row. Validity is a property of the declaration, not the data, so the plain non-key source value 'label' is rejected even though the synthetic key 'id' is unique per row. To carry label it must be wrapped in an aggregate over group (e.g. min(group.label))."

  package: {
    $liasse: 1
    $app: "t.viewnewid@1.0.0"
    $model: {
      rows: {
        $key: "id"
        id: "text"
        label: "text"
      }
      $public: {
        reid: { $view: ".rows { $key: id, id, label }" }
      }
    }
  }

  expect: {
    outcome: invalid
    violates: ["#views", "§7.2"]
    detail: "a synthetic $key projection carrying a plain non-key source value (label) is rejected unconditionally, even when the key is unique per row"
  }
}

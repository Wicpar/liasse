{
  format: 1
  name: difference-removes-right-rows
  suite: scenario
  spec: ["#views", "§7.4"]
  note: "§7.4: 'a - b  difference, left projection and order.' The difference keeps left rows whose identity is not in the right operand. Removing the grp R rows from all tasks leaves a, b in left key order with the left projection { id }."

  package: {
    $liasse: 1
    $app: "t.viewdiff@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "text"
        grp: "text"
      }
      $public: {
        notr: { $view: ".tasks { id } - .tasks[:t | t.grp == \"R\"]" }
      }
    }
    $data: {
      tasks: {
        a: { grp: "L" }
        b: { grp: "L" }
        c: { grp: "R" }
      }
    }
  }

  steps: [
    { watch: "public.notr", id: "w1",
      expect_init: { value: [ { id: "a" }, { id: "b" } ] } }
  ]
}

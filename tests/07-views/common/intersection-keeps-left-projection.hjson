{
  format: 1
  name: intersection-keeps-left-projection
  suite: scenario
  spec: ["#views", "§7.4"]
  note: "§7.4: 'a & b  intersection, left projection and order.' The intersection keeps rows present in both operands and shapes them with the LEFT projection { id, grp } in left key order. Only the grp L rows a, b are in both."

  package: {
    $liasse: 1
    $app: "t.viewint@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "text"
        grp: "text"
      }
      $public: {
        common: { $view: ".tasks { id, grp } & .tasks[:t | t.grp == \"L\"]" }
      }
    }
    $data: {
      tasks: {
        a: { grp: "L" }
        b: { grp: "L" }
        c: { grp: "R" }
      }
    }
  }

  steps: [
    { watch: "public.common", id: "w1",
      expect_init: { value: [ { id: "a", grp: "L" }, { id: "b", grp: "L" } ] } }
  ]
}

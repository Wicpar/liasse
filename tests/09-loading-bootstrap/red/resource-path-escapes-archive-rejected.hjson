{
  format: 1
  name: resource-path-escapes-archive-rejected
  suite: static
  spec: ["#package-structure", "#loading"]
  tags: ["tampering"]
  note: '''
    Classic zip-slip / path-traversal attack carried inside a package
    definition: the resource path climbs out of the archive root, aiming at
    host filesystem content. §4.1: "Paths MUST remain inside the archive root
    and MUST identify one entry." §9.2 step 2 verifies artifact entries during
    complete validation, so the load must fail before activation. The declared
    digest is well-formed (SHA-256 of the empty string); the violation under
    test is the path rule alone.
  '''

  package: {
    $liasse: 1
    $app: "t.ld.escape@1.0.0"
    $resources: {
      evil: {
        $path: "../../outside.txt"
        $media: "text/plain"
        $sha256: "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
      }
    }
    $model: {
      items: {
        $key: "id"
        id: "text"
      }
    }
  }

  expect: {
    outcome: invalid
    violates: ["#package-structure"]
    detail: "resource path '../../outside.txt' escapes the archive root"
  }
}

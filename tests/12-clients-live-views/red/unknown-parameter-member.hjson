{
  format: 1
  name: unknown-parameter-member
  suite: scenario
  spec: ["#clients", "§12.1", "#mutations", "§8.11"]
  tags: ["boundary", "protocol"]
  note: '''
    Attack: attach an undeclared member to the call arguments, either to
    smuggle data past the shape or to probe for structural directives.
    SPEC-ISSUES #6 pins the argument object as a CLOSED shape (§8.11/§12.1):
    §12.1 step 3 parses parameters against the declared shape, and a member the
    shape does not declare — here `extra` — makes the request malformed and is
    rejected before admission, never ignored. This keeps §12.3 deduplication
    well-defined: a request's identity is exactly its decoded set of declared
    arguments, with no ignored-but-present member left to vary silently. The
    same closed shape rejects a reserved $-prefixed member such as { $sort: [...] }
    sent as an argument.
  '''

  package: {
    $liasse: 1
    $app: "t.livetasks@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        title: "text"
      }
      $mut: {
        add: [
          "task = .tasks + { title: @title }"
          "return task { id, title }"
        ]
      }
      index: {
        $view: ".tasks { id, title, $sort: [title] }"
      }
      $public: {
        tasks: {
          $view: ".index"
          $mut: {
            add: ".add"
          }
        }
      }
    }
  }

  steps: [
    { connect: "c1" }
    {
      call: "public.tasks.add"
      args: { title: "a", extra: 1 }
      on: "c1"
      expect: { outcome: rejected, violates: ["#clients", "§12.1"] }
    }
  ]
}

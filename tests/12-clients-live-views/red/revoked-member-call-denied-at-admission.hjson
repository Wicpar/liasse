{
  format: 1
  name: revoked-member-call-denied-at-admission
  suite: scenario
  spec: ["#interfaces", "#clients"]
  tags: ["authz", "escalation"]
  note: '''
    Attack: keep an established, previously authorized connection and continue
    calling after membership is revoked, hoping authorization was cached at
    connect time. §10.5: "Membership, recursive edges, filters, and exceptions
    are re-evaluated at admission. A role change therefore affects subsequent
    requests immediately in serial order." §12.1 step 6 evaluates role
    membership per request. The disable commit is serially before the second
    add, so the second add must be denied.
  '''

  package: {
    $liasse: 1
    $app: "t.roletasks@1.0.0"
    $requires: { authsim: "test.authsim@1" }
    $data: {
      accounts: {
        alice: {}
      }
    }
    $model: {
      accounts: {
        $key: "id"
        id: "text"
        enabled: "bool = true"
      }
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        owner: "text"
        title: "text"
      }
      $auth: {
        token: {
          $credential: "text"
          $verify: "authsim.verify($credential)"
          $actor: "/accounts[$proof.account]"
          $check: "$proof.auth == $auth_name"
        }
      }
      $mut: {
        add_own: [
          "task = .tasks + { owner: $actor.id, title: @title }"
          "return task { id, title }"
        ]
      }
      $roles: {
        member: {
          $auth: "token"
          $members: ".accounts[:a | a.enabled]"
          tasks: {
            $view: ".tasks[:t | t.owner == $actor.id] { id, title, $sort: [title] }"
            $mut: {
              add: ".add_own"
            }
          }
        }
      }
      $public: {
        admin: {
          $mut: {
            disable: ".accounts[@id].enabled = false"
          }
        }
      }
    }
  }

  hosts: {
    namespaces: {
      authsim: {
        contract: "test.authsim@1"
        functions: {
          verify: {
            effect: "verifier"
            signature: "(credential: text) -> { auth: text, account: text }"
            behavior: "Splits the credential at the first ':' into { auth, account }. Any credential containing ':' verifies; others fail verification."
          }
        }
      }
    }
  }

  steps: [
    {
      connect: "c1"
      authenticate: { role: "member", auth: "token", credential: "token:alice" }
    }
    // Sanity: alice is currently a member.
    {
      call: "member.tasks.add"
      args: { title: "before" }
      on: "c1"
      expect: { outcome: ok, value: { id: "$any:uuid", title: "before" } }
    }
    { connect: "c2" }
    {
      call: "public.admin.disable"
      args: { id: "alice" }
      on: "c2"
      expect: { outcome: ok }
    }
    // Same connection, same credential, next request: membership is
    // re-evaluated at admission and must now fail.
    {
      call: "member.tasks.add"
      args: { title: "after" }
      on: "c1"
      expect: {
        outcome: denied
        violates: ["#interfaces", "#clients"]
        detail: "actor no longer occurs in $members at the request's admission position"
      }
    }
  ]
}

{
  format: 1
  name: role-surface-requires-authentication
  suite: scenario
  spec: ["#clients", "#interfaces", "#authentication"]
  tags: ["authz"]
  note: '''
    §10.3 grants role surfaces to authenticated members only; §11.4 "Every
    authenticated request names both the role and one accepted authenticator";
    §12.1 pipeline steps 2 and 6 verify the authenticator and role membership.
    A connection that never authenticated must be denied both the subscription
    and the call on a role surface.
  '''

  package: {
    $liasse: 1
    $app: "t.roletasks@1.0.0"
    $requires: { authsim: "test.authsim@1" }
    $data: {
      accounts: {
        alice: {}
      }
    }
    $model: {
      accounts: {
        $key: "id"
        id: "text"
        enabled: "bool = true"
      }
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        owner: "text"
        title: "text"
      }
      $auth: {
        token: {
          $credential: "text"
          $verify: "authsim.verify($credential)"
          $actor: "/accounts[$proof.account]"
          $check: "$proof.auth == $auth_name"
        }
      }
      $mut: {
        add_own: [
          "task = .tasks + { owner: $actor.id, title: @title }"
          "return task { id, title }"
        ]
      }
      $roles: {
        member: {
          $auth: "token"
          $members: ".accounts[:a | a.enabled]"
          tasks: {
            $view: ".tasks[:t | t.owner == $actor.id] { id, title, $sort: [title] }"
            $mut: {
              add: ".add_own"
            }
          }
        }
      }
    }
  }

  hosts: {
    namespaces: {
      authsim: {
        contract: "test.authsim@1"
        functions: {
          verify: {
            effect: "verifier"
            signature: "(credential: text) -> { auth: text, account: text }"
            behavior: "Splits the credential at the first ':' into { auth, account }. Any credential containing ':' verifies; others fail verification."
          }
        }
      }
    }
  }

  steps: [
    { connect: "c1" }
    {
      watch: "member.tasks"
      on: "c1"
      id: "w1"
      expect: {
        outcome: denied
        violates: ["#interfaces", "#authentication", "#clients"]
      }
    }
    {
      call: "member.tasks.add"
      args: { title: "x" }
      on: "c1"
      expect: {
        outcome: denied
        violates: ["#interfaces", "#authentication", "#clients"]
      }
    }
  ]
}

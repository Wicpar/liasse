{
  format: 1
  name: unaffected-watch-advances-frontier
  suite: scenario
  spec: ["#clients"]
  tags: ["coherence", "frontier"]
  note: '''
    §12.3: "Before returning `committed`, the runtime advances every
    still-authorized active subscription on the same logical client connection
    through the commit. Unaffected views MAY receive only a frontier
    advancement." Two subscriptions live on one connection; a commit affects
    only the first. After the committed response, both live results are
    evaluated at a frontier covering the commit: the affected one contains the
    new row, the unaffected one is still (correctly) empty. Whether the
    unaffected stream carried a frontier-only patch or nothing visible is the
    runtime's choice and is not asserted.
  '''

  package: {
    $liasse: 1
    $app: "t.livetasks@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        title: "text"
        done: "bool = false"
      }
      $mut: {
        add: [
          "task = .tasks + { title: @title }"
          "return task { id, title, done }"
        ]
      }
      open: {
        $view: ".tasks[:t | !t.done] { id, title, $sort: [title] }"
      }
      closed: {
        $view: ".tasks[:t | t.done] { id, title, $sort: [title] }"
      }
      $public: {
        tasks: {
          $view: ".open"
          $mut: {
            add: ".add"
          }
        }
        done: {
          $view: ".closed"
        }
      }
    }
  }

  steps: [
    { connect: "c1" }
    { watch: "public.tasks", on: "c1", id: "w1", expect_init: { value: [] } }
    { watch: "public.done", on: "c1", id: "w2", expect_init: { value: [] } }
    {
      call: "public.tasks.add"
      args: { title: "a" }
      on: "c1"
      expect: { outcome: ok, completion: committed, value: { id: "$bind:t1", title: "a", done: false } }
    }
    { expect_view: { watch: "w1", value: [ { id: "$ref:t1", title: "a" } ] } }
    // w2 has also advanced through the commit; its correct result there is
    // still empty.
    { expect_view: { watch: "w2", value: [] } }
  ]
}

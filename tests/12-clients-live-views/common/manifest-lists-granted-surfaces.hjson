{
  format: 1
  name: manifest-lists-granted-surfaces
  suite: scenario
  spec: ["#clients", "#interfaces", "#authentication"]
  tags: ["manifest", "authz"]
  note: '''
    §12.1: "After authentication, the client receives the surfaces granted by
    the explicitly selected role and actor"; the manifest operation lists
    "available surfaces for a role and authentication context". The package
    declares no public surface, so an unauthenticated context is granted no
    surface, and an authenticated member is granted exactly the role surface.
    Only the surface address set is asserted; §12.1 also promises parameter and
    response shapes, but their encoding is not specified (see NOTES.md).
  '''

  package: {
    $liasse: 1
    $app: "t.roletasks@1.0.0"
    $requires: { authsim: "test.authsim@1" }
    $data: {
      accounts: {
        alice: {}
      }
    }
    $model: {
      accounts: {
        $key: "id"
        id: "text"
        enabled: "bool = true"
      }
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        owner: "text"
        title: "text"
      }
      $auth: {
        token: {
          $credential: "text"
          $verify: "authsim.verify($credential)"
          $actor: "/accounts[$proof.account]"
          $check: "$proof.auth == $auth_name"
        }
      }
      $mut: {
        add_own: [
          "task = .tasks + { owner: $actor.id, title: @title }"
          "return task { id, title }"
        ]
      }
      $roles: {
        member: {
          $auth: "token"
          $members: ".accounts[:a | a.enabled]"
          tasks: {
            $view: ".tasks[:t | t.owner == $actor.id] { id, title, $sort: [title] }"
            $mut: {
              add: ".add_own"
            }
          }
        }
      }
    }
  }

  hosts: {
    namespaces: {
      authsim: {
        contract: "test.authsim@1"
        functions: {
          verify: {
            effect: "verifier"
            signature: "(credential: text) -> { auth: text, account: text }"
            behavior: "Splits the credential at the first ':' into { auth, account }. Any credential containing ':' verifies; others fail verification."
          }
        }
      }
    }
  }

  steps: [
    // Unauthenticated context: no public surfaces exist, no role selected,
    // so nothing is available.
    { connect: "c1" }
    {
      manifest: {}
      on: "c1"
      expect: { outcome: ok, surfaces: [] }
    }
    // Authenticated member context: exactly the role surface is granted.
    {
      connect: "c2"
      authenticate: { role: "member", auth: "token", credential: "token:alice" }
    }
    {
      manifest: {}
      on: "c2"
      expect: { outcome: ok, surfaces: ["member.tasks"] }
    }
  ]
}

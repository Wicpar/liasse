{
  format: 1
  name: authority-loss-emits-close
  suite: scenario
  spec: ["#clients", "#interfaces"]
  tags: ["authz", "close"]
  note: '''
    §12.2: "The runtime re-evaluates authentication, session validity, scoped
    role membership, surface availability, and output projection at every
    outgoing frontier. When the current state removes that subscription's
    authority or surface, the runtime emits `close`; the client releases the
    cached result." Disabling the actor's account removes membership
    (`$members` selects enabled accounts), so the live subscription must be
    closed rather than advanced.
  '''

  package: {
    $liasse: 1
    $app: "t.roletasks@1.0.0"
    $requires: { authsim: "test.authsim@1" }
    $data: {
      accounts: {
        alice: {}
      }
    }
    $model: {
      accounts: {
        $key: "id"
        id: "text"
        enabled: "bool = true"
      }
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        owner: "text"
        title: "text"
      }
      $auth: {
        token: {
          $credential: "text"
          $verify: "authsim.verify($credential)"
          $actor: "/accounts[$proof.account]"
          $check: "$proof.auth == $auth_name"
        }
      }
      $mut: {
        add_own: [
          "task = .tasks + { owner: $actor.id, title: @title }"
          "return task { id, title }"
        ]
      }
      $roles: {
        member: {
          $auth: "token"
          $members: ".accounts[:a | a.enabled]"
          tasks: {
            $view: ".tasks[:t | t.owner == $actor.id] { id, title, $sort: [title] }"
            $mut: {
              add: ".add_own"
            }
          }
        }
      }
      $public: {
        admin: {
          $mut: {
            disable: ".accounts[@id].enabled = false"
          }
        }
      }
    }
  }

  hosts: {
    namespaces: {
      authsim: {
        contract: "test.authsim@1"
        functions: {
          verify: {
            effect: "verifier"
            signature: "(credential: text) -> { auth: text, account: text }"
            behavior: "Splits the credential at the first ':' into { auth, account }. Any credential containing ':' verifies; others fail verification."
          }
        }
      }
    }
  }

  steps: [
    {
      connect: "c1"
      authenticate: { role: "member", auth: "token", credential: "token:alice" }
    }
    {
      call: "member.tasks.add"
      args: { title: "mine" }
      on: "c1"
      expect: { outcome: ok, value: { id: "$bind:t1", title: "mine" } }
    }
    {
      watch: "member.tasks"
      on: "c1"
      id: "w1"
      expect_init: { value: [ { id: "$ref:t1", title: "mine" } ] }
    }
    // Disable alice through the deliberately unauthenticated admin surface.
    // The commit removes alice's role membership at its frontier.
    {
      connect: "c2"
    }
    {
      call: "public.admin.disable"
      args: { id: "alice" }
      on: "c2"
      expect: { outcome: ok }
    }
    {
      expect_close: { watch: "w1", reason: "$any" }
    }
  ]
}

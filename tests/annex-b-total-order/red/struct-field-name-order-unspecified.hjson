{
  format: 1
  name: struct-field-name-order-unspecified
  suite: scenario
  spec: ["#annex-b", "§B.4", "§D.2"]
  tags: ["ordering", "unspecified"]
  note: '''
    §B.4 struct: "lexicographic fields in canonical field-name order". §D.2
    likewise says a struct key uses "its components in canonical field-name
    order". Neither passage defines what "canonical field-name order" IS when
    it differs from declaration order. Two defensible readings exist, and this
    case is constructed so they disagree:

      (a) declaration order  -> compare field `b` first, then `a`
      (b) Unicode text order of the field names (the canonicalization used for
          object keys in A.7 / D.4) -> compare field `a` first, then `b`

    The struct `pt` is declared with fields in the order (b, a) — the reverse
    of their text order. Two rows:
      p1: { b: 1, a: 2 }
      p2: { b: 2, a: 1 }
    Under reading (a): compare b -> 1 < 2, so p1 < p2.
    Under reading (b): compare a -> 2 > 1, so p2 < p1.
    The result order is therefore not deducible from SPEC.md; recorded as
    `outcome: unspecified`. If Annex B is later amended to define "canonical
    field-name order" (most plausibly as text order, matching A.7/D.4), this
    case becomes a fixed-order assertion.
  '''

  package: {
    $liasse: 1
    $app: "t.annexb.struct@1.0.0"
    $model: {
      rows: {
        $key: "id"
        id: "text"
        pt: {
          b: "int"
          a: "int"
        }
      }
      $public: {
        by_pt: { $view: ".rows { id, $sort: [pt] }" }
      }
    }
    $data: {
      rows: {
        p1: { pt: { b: 1, a: 2 } }
        p2: { pt: { b: 2, a: 1 } }
      }
    }
  }

  steps: [
    { watch: "public.by_pt", id: "w1",
      // Order of p1 vs p2 depends on the undefined "canonical field-name
      // order"; the harness records the observed order without judging.
      expect_init: { outcome: "unspecified" } }
  ]
}

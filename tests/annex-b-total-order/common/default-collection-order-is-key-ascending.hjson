{
  format: 1
  name: default-collection-order-is-key-ascending
  suite: scenario
  spec: ["#annex-b", "§B.5", "§B.1"]
  tags: ["ordering"]
  note: '''
    §B.5: "A collection defaults to key ascending." A view that declares no
    $sort presents rows in ascending key order. With a text key, that is
    scalar-value order (§B.1 text). Seeded in scrambled order to prove output
    order is by key, not by insertion.
  '''

  package: {
    $liasse: 1
    $app: "t.annexb.defaultkey@1.0.0"
    $model: {
      cities: {
        $key: "name"
        name: "text"
      }
      $public: {
        all: { $view: ".cities { name }" }
      }
    }
    $data: {
      cities: {
        "Zurich": {}
        "Amsterdam": {}
        "Madrid": {}
        "Berlin": {}
      }
    }
  }

  steps: [
    { watch: "public.all", id: "w1",
      expect_init: { value: [
        { name: "Amsterdam" }
        { name: "Berlin" }
        { name: "Madrid" }
        { name: "Zurich" }
      ] } }
  ]
}

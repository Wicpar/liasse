{
  format: 1
  name: reversible-transform-roundtrip-commits
  suite: scenario
  spec: ["#evolution", "§20.2", "#loading", "§9.4"]
  note: '''
    §20.2: a transform MAY declare an exact inverse `$back`, and for every
    migrated value x the engine verifies `$back($as(x)) == x`. For the seeded
    name "hi": $as = base64.encode(string.bytes("hi")) = "aGk=" (bytes
    0x68 0x69), and $back(string.from_bytes(base64.decode("aGk="))) == "hi".
    The round trip holds, so the migration commits and `encoded` == "aGk=".
  '''

  package: {
    $liasse: 1
    $app: "t.mig.rev@1.0.0"
    $model: {
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      $public: {
        accounts: { $view: ".accounts { id, name }" }
      }
    }
    $data: {
      accounts: { a1: { name: "hi" } }
    }
  }

  steps: [
    { host_load: {
        package: {
          $liasse: 1
          $app: "t.mig.rev@2.0.0"
          $model: {
            accounts: {
              $key: "id"
              id: "text"
              encoded: {
                $type: "text"
                $from: "name"
                $as: "base64.encode(string.bytes(.))"
                $back: "string.from_bytes(base64.decode(.))"
              }
            }
            $public: {
              accounts: { $view: ".accounts { id, encoded }" }
            }
          }
        }
      }
      expect: { outcome: ok, result: committed } }
    { watch: "public.accounts", id: "w1",
      expect_init: { value: [ { id: "a1", encoded: "aGk=" } ] } }
  ]
}

{
  format: 1
  name: nondeterministic-migration-transform-invalid
  suite: scenario
  spec: ["#evolution", "§20.1", "#loading", "§9.4"]
  note: '''
    §20.1: the migration program array "MUST use deterministic pure functions."
    An attacker tries to stamp fresh identity during migration by writing the
    target `token` from `uuid()`, which ignores the bound old value and produces
    a different result on every run — not a deterministic pure function. The
    program is statically ill-formed on its own terms, so the update is
    `invalid` (definition-only defect; see NOTES.md) and 1.0.0 stays active.

    uuid() sits inside the `$migrations` array so the MUST that forbids it
    applies to the literal text of the clause, not merely by analogy to a local
    `$as` transform.
  '''

  package: {
    $liasse: 1
    $app: "t.mig.nondet@1.0.0"
    $model: {
      rows: {
        $key: "id"
        id: "text"
        name: "text"
      }
      $public: {
        rows: { $view: ".rows { id, name }" }
      }
    }
    $data: {
      rows: { r1: { name: "keep" } }
    }
  }

  steps: [
    { host_load: {
        package: {
          $liasse: 1
          $app: "t.mig.nondet@2.0.0"
          $model: {
            rows: {
              $key: "id"
              id: "text"
              token: "text"
            }
            $migrations: {
              "1.0.0": [
                ".rows = $old.rows { id, token: uuid() }"
              ]
            }
            $public: {
              rows: { $view: ".rows { id, token }" }
            }
          }
        }
      }
      expect: {
        outcome: invalid
        violates: ["§20.1"]
        detail: "migration program writes token from uuid(); §20.1 requires deterministic pure functions"
      } }
    { watch: "public.rows", id: "w1",
      expect_init: { value: [ { id: "r1", name: "keep" } ] } }
  ]
}

{
  format: 1
  name: enum-narrowing-migration-out-of-domain-value-rejected
  suite: scenario
  // §20.1: "The complete prospective target is checked under ordinary keys, refs,
  // uniqueness, checks, buckets, meters, modules, and interfaces before the package
  // update commits." §22.1 lists "field and shape types" among the state
  // constraints that hold in EVERY committed state, and §5.9 makes a `$enum` a
  // CLOSED label set — an insert/assign of an undeclared label is rejected.
  //
  // A major release narrows `status` from {draft, active, archived} to
  // {draft, active}. The live row t1 holds `archived`, which the migration copies
  // by compatible same-identity copy (§20.1). In the prospective TARGET state that
  // copied value is no longer a declared label of the target enum, so the target
  // state violates the §5.9 field type. Exactly as a migrated value that fails a
  // target `$check` is rejected (see migrated-value-fails-target-check-rejected)
  // and a migrated dangling ref is rejected (migrated-state-dangling-ref-rejected),
  // this migration MUST be rejected and 1.0.0 stays active.
  //
  // ATTACK (red): a migration copies an already-parsed enum value verbatim, hoping
  // the closed-set re-validation only runs on a wire-supplied label and is skipped
  // for a value that already carries an enum representation — which would strand an
  // out-of-domain label in committed target state.
  spec: ["#evolution", "§20.1", "#state-model", "§5.9", "#runtime", "§22.1"]

  package: {
    $liasse: 1
    $app: "t.mig.enum@1.0.0"
    $model: {
      things: {
        $key: "id"
        id: "text"
        status: { $enum: ["draft", "active", "archived"] }
      }
      $public: {
        things: { $view: ".things { id, status }" }
      }
    }
    $data: {
      things: { t1: { status: "archived" } }
    }
  }

  steps: [
    { host_load: {
        package: {
          $liasse: 1
          $app: "t.mig.enum@2.0.0"
          $model: {
            things: {
              $key: "id"
              id: "text"
              // narrowed: `archived` is dropped from the closed label set
              status: { $enum: ["draft", "active"] }
            }
            $public: {
              things: { $view: ".things { id, status }" }
            }
          }
        }
      }
      expect: {
        outcome: rejected
        violates: ["§20.1", "§5.9"]
        detail: "the live status 'archived' is no longer a declared label of the target $enum, so the prospective target state violates the enum field type"
      } }
    // the rejected migration left 1.0.0 active, so t1 still reads under the v1 shape
    { watch: "public.things", id: "w1",
      expect_init: { value: [ { id: "t1", status: "archived" } ] } }
  ]
}

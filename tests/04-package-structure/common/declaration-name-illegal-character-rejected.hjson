{
  format: 1
  name: declaration-name-illegal-character-rejected
  suite: static
  spec: ["#conformance", "§2.5"]
  note: "§2.5: 'Application declaration names MUST begin with an ASCII letter and contain only ASCII letters, digits, and _.' A hyphen is outside the permitted character set."

  package: {
    $liasse: 1
    $app: "t.names@1.0.0"
    $model: {
      "task-list": "text"
    }
  }

  expect: {
    outcome: invalid
    violates: ["#conformance", "§2.5"]
    detail: "declaration name 'task-list' contains '-', which is outside ASCII letters, digits, and _"
  }
}

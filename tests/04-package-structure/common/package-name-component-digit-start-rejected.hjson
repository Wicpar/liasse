{
  format: 1
  name: package-name-component-digit-start-rejected
  suite: static
  spec: ["#conformance", "§2.5"]
  note: "§2.5: package-name components must each begin with a letter. '2go' begins with a digit."

  package: {
    $liasse: 1
    $app: "t.2go@1.0.0"
    $model: {
      note: "text"
    }
  }

  expect: {
    outcome: invalid
    violates: ["#conformance", "§2.5"]
    detail: "package-name component '2go' begins with a digit, not a letter"
  }
}

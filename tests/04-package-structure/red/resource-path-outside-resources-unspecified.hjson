{
  format: 1
  name: resource-path-outside-resources-unspecified
  suite: static
  spec: ["#package-structure", "§4.1", "#annex-c", "§C.1"]
  tags: ["aliasing"]
  note: "Aliasing probe: a resource descriptor whose $path targets a structural archive entry (liasse.json) rather than a packaged resource, giving expressions/namespaces a handle on the raw definition. The normative MUSTs on $path in §4.1 are only 'remain inside the archive root' and 'identify one entry' — liasse.json satisfies both. §4.1 also says '$resources maps logical resource names to entries below resources/', which reads either as a hard structural constraint (reject: not below resources/) or as descriptive framing of the common case (accept: MUSTs are met). Annex C.1 types $path as a 'relative-archive-path' without restricting it to resources/. The spec does not pin whether a $path outside resources/ is valid; a runtime needs this decided because it is a definition-read escalation vector."

  package: {
    $liasse: 1
    $app: "t.alias@1.0.0"
    $resources: {
      self: {
        $path: "liasse.json"
        $media: "application/json"
        $sha256: "2163bddf11b2e116332448d10374d504f9508c148b72e5c9d970b88665330490"
      }
    }
    $model: {
      note: "text"
    }
  }

  expect: {
    outcome: unspecified
  }
}

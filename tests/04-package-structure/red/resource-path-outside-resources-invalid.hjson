{
  format: 1
  name: resource-path-outside-resources-invalid
  suite: static
  spec: ["#package-structure", "§4.1"]
  tags: ["aliasing"]
  note: "Aliasing probe: a resource descriptor whose $path targets a structural archive entry (liasse.json) rather than a packaged resource, which would give expressions/namespaces a handle on the raw definition and fold a $sha256 over non-resource bytes into the definition identity (§D.4). Resolution (SPEC-ISSUES #26): §4.1's 'below resources/' clause is a hard structural constraint — a resource $path MUST resolve to an entry below resources/, and a $path naming any other archive entry (liasse.json, or a state/, history/, blobs/ entry) is rejected. So $path: 'liasse.json' is invalid."

  package: {
    $liasse: 1
    $app: "t.alias@1.0.0"
    $resources: {
      self: {
        $path: "liasse.json"
        $media: "application/json"
        $sha256: "2163bddf11b2e116332448d10374d504f9508c148b72e5c9d970b88665330490"
      }
    }
    $model: {
      note: "text"
    }
  }

  expect: {
    outcome: invalid
    violates: ["#package-structure", "§4.1"]
    detail: "resource $path 'liasse.json' does not name an entry below resources/"
  }
}

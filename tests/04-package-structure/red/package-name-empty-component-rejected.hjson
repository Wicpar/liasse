{
  format: 1
  name: package-name-empty-component-rejected
  suite: static
  spec: ["#conformance", "§2.5"]
  tags: ["boundary", "identity"]
  note: "Boundary abuse of the dot-separated grammar: 't..app' contains an empty component. §2.5 requires each component to begin with a letter, which an empty component cannot. Implementations that split-and-join naively would collapse 't..app' and 't.app' into colliding registry/storage keys."

  package: {
    $liasse: 1
    $app: "t..app@1.0.0"
    $model: {
      note: "text"
    }
  }

  expect: {
    outcome: invalid
    violates: ["#conformance", "§2.5"]
    detail: "empty package-name component between consecutive dots"
  }
}

{
  format: 1
  name: app-version-prerelease-unspecified
  suite: static
  spec: ["#annex-e", "§E.1", "#package-structure", "§4.3"]
  tags: ["boundary", "identity"]
  note: "Annex E.1 says package identifiers 'use semantic versions'. SemVer 2.0.0 admits pre-release identifiers ('1.0.0-rc.1') and build metadata, but the spec's compatibility algorithm defines roles only for major/minor/patch and never mentions pre-release ordering, identity, or registry treatment. Whether '@1.0.0-rc.1' is a valid package version is therefore unspecified: readings range from 'full SemVer grammar, accepted' to 'only the major.minor.patch triple the compatibility rules cover'. Registries and update paths need this pinned — a pre-release that aliases its release version is an update-confusion vector."

  package: {
    $liasse: 1
    $app: "t.app@1.0.0-rc.1"
    $model: {
      note: "text"
    }
  }

  expect: {
    outcome: unspecified
  }
}

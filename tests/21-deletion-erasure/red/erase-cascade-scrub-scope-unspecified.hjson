{
  format: 1
  name: erase-cascade-scrub-scope-unspecified
  suite: scenario
  tags: [erasure, cascade, privacy]
  note: '''Privacy scope gap. §21.2 step 1 says erase "plans the same live
removal and $on_delete effects as ordinary deletion", and step 3 "replaces each
scrubbed occurrence with a digest stub." When erasing a user cascades to a
`profiles` row (which itself holds sensitive bytes), the chapter never says
whether the cascaded profile counts as a "scrubbed occurrence" (its retained
history payload is scrubbed too) or is merely deleted like ordinary deletion (its
prior bytes REMAIN in retained history per §21.1). The extract's coverage —
§21.2 step 2 "every payload required for possible reinsertion" — is likewise not
pinned to the cascade closure. Both live rows leave live state (deducible and
asserted); whether the cascaded profile's historical payload is scrubbed is
unspecified. This is a real erase-for-privacy hole worth surfacing before
implementation freezes a behavior.'''
  spec: ["§21.2", "§21.1"]

  package: {
    $liasse: 1
    $app: "t.del@1.0.0"
    $model: {
      users: {
        $key: "id"
        id: "text"
      }
      profiles: {
        $key: "id"
        id: "text"
        bio: "text"
        user: {
          $ref: "/users"
          $on_delete: "cascade"
        }
      }
      $mut: {
        erase_user: "return erase(.users[@id])"
      }
      users_view: { $view: ".users { id }" }
      profiles_view: { $view: ".profiles { id, bio, user }" }
      $public: {
        users: { $view: ".users_view", $mut: { erase: ".erase_user" } }
        profiles: { $view: ".profiles_view" }
      }
    }
    $data: {
      users: { u1: {} }
      profiles: { pr1: { bio: "sensitive", user: "u1" } }
    }
  }

  steps: [
    { watch: "public.users", id: "wu", expect_init: { value: [ { id: "u1" } ] } }
    { watch: "public.profiles", id: "wp", expect_init: { value: [ { id: "pr1", bio: "sensitive", user: "u1" } ] } }
    // deducible: both leave live state (erase target + cascade)
    { call: "public.users.erase", args: { id: "u1" }, expect: { outcome: ok, value: "$bind:extract" } }
    { expect_view: { watch: "wu", value: [] } }
    { expect_view: { watch: "wp", value: [] } }
    // NOT deducible: is the cascaded profile's historical payload scrubbed (like
    // the erase target) or retained (like ordinary deletion)? §21.2 does not say.
    { scrub_scope_of_cascaded_row: { collection: "profiles", key: "pr1" },
      expect: { outcome: unspecified } }
  ]
}

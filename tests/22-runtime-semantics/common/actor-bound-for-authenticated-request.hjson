{
  // §22.8: "Only authenticated external interface requests bind `$actor`." An
  // authenticated call resolves one application row as `$actor` (§2.4, §3.1);
  // writing `$actor` into state must record that resolved account. This is the
  // provenance happy path for §22.8.
  format: 1
  name: actor-bound-for-authenticated-request
  suite: scenario
  spec: ["§22.8", "#runtime", "#authentication"]
  tags: ["authz", "provenance"]

  package: {
    $liasse: 1
    $app: "t.actor@1.0.0"
    $requires: { token: "test.token@1" }
    $model: {
      accounts: {
        $key: "id"
        id: "uuid = uuid()"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        revoked: "bool = false"
      }
      notes: {
        $key: "id"
        id: "uuid = uuid()"
        author: { $ref: "/accounts" }
        body: "text"
      }
      $mut: {
        add_note: [
          "n = .notes + { author: $actor, body: @body }"
          "return n { id, author, body }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: [
            "$proof.auth == $auth_name"
            "!$session.revoked"
          ]
        }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          notes: {
            $mut: { add: ".add_note" }
          }
        }
      }
    }
    $data: {
      accounts: {
        "aaaaaaaa-0000-4000-8000-000000000001": { name: "alice" }
      }
      sessions: {
        "5e551000-0000-4000-8000-000000000001": {
          account: "aaaaaaaa-0000-4000-8000-000000000001"
        }
      }
    }
  }

  hosts: {
    token: {
      $namespace: "test.token@1"
      tokens: {
        "tok-alice": { auth: "session", session: "5e551000-0000-4000-8000-000000000001" }
      }
    }
  }

  steps: [
    { connect: "c1", authenticate: { auth: "session", credential: "tok-alice" } }
    {
      call: "member.notes.add"
      args: { body: "hi" }
      on: "c1"
      // $actor resolved to alice's account row key.
      expect: { outcome: ok, value: {
        id: "$any:uuid"
        author: "aaaaaaaa-0000-4000-8000-000000000001"
        body: "hi"
      } }
    }
  ]
}

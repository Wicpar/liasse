{
  format: 1
  name: manifest-included-range-statement-unspecified
  suite: scenario
  // Spec-gap documentation case.
  note: '''§19.7 requires: "The artifact manifest states the included range
and whether every represented point is fully restorable." But the required
manifest.json structure in §19.5 defines no member carrying an included-range
or restorability statement, and closes the format: "Additional members are
invalid for format version 1." The two rules cannot both be satisfied by a
format-1 manifest, so where and how an export states its included range and
restorability is unspecified. history/index.json (§19.6) records segment and
archive coverage but has no restorability statement either.'''
  spec: ["§19.7", "§19.5", "§19.6"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    // Where does this artifact state its included range and restorability?
    { inspect_artifact: { artifact: "a1", expect: {
        outcome: unspecified
        
    } } }
  ]
}

{
  format: 1
  name: import-rollback-restores-earlier-point
  suite: scenario
  // §19.8: "incoming point precedes local -> rollback available" and
  // "Rollback restores the selected earlier point". Importing an artifact of
  // an earlier own point with rollback policy restores that state.
  spec: ["§19.8", "§19.3"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { call: "public.notes.put", args: { id: "n2", body: "two" },
      expect: { outcome: ok, value: { id: "n2", body: "two" } } }
    { import: { from: "a1", policy: ["rollback"] },
      expect: { outcome: ok, value: { relation: "rollback", applied: true, "...": true } } }
    // State is back at the exported boundary: n2 is gone from live state.
    { watch: "public.notes", id: "w1", expect_init: { value: [
      { id: "n1", body: "one" }
    ] } }
  ]
}

{
  format: 1
  name: import-same-point-already-synchronized
  suite: scenario
  // §19.8 classification table: "same point -> already synchronized".
  // Importing an artifact whose selected point equals the local point
  // applies no movement and changes no state.
  spec: ["§19.8"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { watch: "public.notes", id: "w1", expect_init: { value: [
      { id: "n1", body: "one" }
    ] } }
    { import: { from: "a1", policy: ["fast_forward", "rollback", "merge"] },
      expect: { outcome: ok, value: { relation: "same_point", applied: false, "...": true } } }
    { expect_view: { watch: "w1", value: [
      { id: "n1", body: "one" }
    ] } }
  ]
}

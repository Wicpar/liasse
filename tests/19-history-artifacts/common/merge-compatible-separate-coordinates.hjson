{
  format: 1
  name: merge-compatible-separate-coordinates
  suite: scenario
  // §19.9: automatic merge "accepts an unambiguous combined result,
  // including ... compatible changes to separate logical coordinates."
  // §19.8: "shared point followed by divergence -> three-way merge".
  spec: ["§19.9", "§19.8"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
        set_body: [
          ".notes[@id].body = @body"
          "return .notes[@id] { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put", set_body: ".set_body" }
        }
      }
    }
  }

  steps: [
    // Shared base: two rows.
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { call: "public.notes.put", args: { id: "n2", body: "two" },
      expect: { outcome: ok, value: { id: "n2", body: "two" } } }
    { export: { as: "a0" }, expect: { outcome: ok } }
    // Incoming side edits n2 only.
    { in_sandbox: "s1", steps: [
      { restore: { from: "a0" }, expect: { outcome: ok } }
      { call: "public.notes.set_body", args: { id: "n2", body: "incoming-edit" },
        expect: { outcome: ok, value: { id: "n2", body: "incoming-edit" } } }
      { export: { as: "a2" }, expect: { outcome: ok } }
    ] }
    // Local side edits n1 only: separate logical coordinates.
    { call: "public.notes.set_body", args: { id: "n1", body: "local-edit" },
      expect: { outcome: ok, value: { id: "n1", body: "local-edit" } } }
    { reconcile: { from: "a2", policy: ["merge"] },
      expect: { outcome: ok, value: { relation: "merge", applied: true, "...": true } } }
    { watch: "public.notes", id: "w1", expect_init: { value: [
      { id: "n1", body: "local-edit" }
      { id: "n2", body: "incoming-edit" }
    ] } }
  ]
}

{
  format: 1
  name: import-policy-gates-activation
  suite: scenario
  // §19.8: "An import policy selects which automatic movements may
  // activate ... Valid imported alternatives MAY remain available without
  // becoming active." A fast-forward whose movement is excluded from the
  // policy must not activate; local state stays at the local head.
  spec: ["§19.8"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1" }, expect: { outcome: ok } }
      { call: "public.notes.put", args: { id: "n2", body: "two" },
        expect: { outcome: ok, value: { id: "n2", body: "two" } } }
      { export: { as: "a2" }, expect: { outcome: ok } }
    ] }
    // Fast-forward is available but the policy only allows merge: the
    // classification is reported, the movement does not activate.
    { import: { from: "a2", policy: ["merge"] },
      expect: { outcome: ok, value: { relation: "fast_forward", applied: false, "...": true } } }
    { watch: "public.notes", id: "w1", expect_init: { value: [
      { id: "n1", body: "one" }
    ] } }
  ]
}

{
  format: 1
  name: merge-equal-inserts-collapse-to-one-incarnation
  suite: scenario
  tags: [identity]
  // Both sides insert a row with the same key AND identical field values.
  note: '''§19.9 (SPEC-ISSUES item 21 pinned): "equal results reached on both
sides" compares LOGICAL state — application address and typed field values
(§D.3) — and the opaque row incarnation (§D.1) does not participate. The two
sides independently insert `k` with equal field values, so the merge accepts
cleanly as one row, the merged lineage retains the local incarnation for
that address, and the equal-insert merge collapses to one incarnation.
"Competing identities" is reserved for competing rekeys onto one application
key, never two fresh inserts of equal logical value.'''
  spec: ["#history", "§19.9", "Annex D.1"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "base", body: "anchor" },
      expect: { outcome: ok, value: { id: "base", body: "anchor" } } }
    { export: { as: "a0" }, expect: { outcome: ok } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a0" }, expect: { outcome: ok } }
      { call: "public.notes.put", args: { id: "k", body: "same" },
        expect: { outcome: ok, value: { id: "k", body: "same" } } }
      { export: { as: "a2" }, expect: { outcome: ok } }
    ] }
    { call: "public.notes.put", args: { id: "k", body: "same" },
      expect: { outcome: ok, value: { id: "k", body: "same" } } }
    { reconcile: { from: "a2", policy: ["merge"] },
      expect: { outcome: ok, value: { relation: "merge", applied: true, "...": true } } }
    { watch: "public.notes", id: "w1",
      expect_init: { value: [
        { id: "base", body: "anchor" }
        { id: "k", body: "same" }
      ] } }
  ]
}

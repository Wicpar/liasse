{
  format: 1
  name: unknown-extra-entry-tolerated
  suite: scenario
  tags: [tampering]
  // A benign-looking extra archive entry that is NOT referenced by the
  // manifest at all.
  note: '''§19.5/Annex D.5 (SPEC-ISSUES item 21 pinned): the closed member set
applies to the manifest, not the archive — an archive entry no manifest
member references is TOLERATED for forward compatibility. It fails nothing,
carries no verified status, and is ignored by every §19 semantic, so the
restore succeeds. The trust consequence is deliberate and pinned in §19.11:
verification establishes integrity only, an unreferenced entry is outside
the verified content, and guarding provenance is the host application's
trust decision (a signature, when present, covers the whole byte stream
including such entries, Annex D.9).'''
  spec: ["#history", "§19.5", "§19.11", "Annex D.5"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { add_entry: { path: "extra/readme.txt", text: "not referenced anywhere" } }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: ok } }
    ] }
  ]
}

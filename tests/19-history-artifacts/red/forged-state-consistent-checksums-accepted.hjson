{
  format: 1
  name: forged-state-consistent-checksums-accepted
  suite: scenario
  tags: [tampering, integrity]
  // Attack: edit one field value INSIDE the canonical state CBOR (leaving
  // the embedded selection untouched) and recompute every manifest
  // checksum. The artifact is now fully self-consistent: structure valid,
  // every checksum matches, selection coherent.
  note: '''§19.11/Annex D.5 (SPEC-ISSUES item 21 pinned): verification
establishes byte integrity and internal self-consistency ONLY, never
cross-host authenticity. This artifact is internally self-consistent —
every checksum matches the re-checksummed forged bytes and the claimed
identities agree with the archive's own bytes — so verification passes and
the restore succeeds, restoring the forged value under a genuine point id.
That is the pinned trust model: forged-but-self-consistent content is not
detectable from the bytes alone and is not the verification layer's
concern; deciding whether to trust an artifact of uncertain provenance is
the host application's responsibility, informed by the Annex D.9 detached
signatures when present (whole-byte-stream signing means this re-checksummed
artifact would carry no valid signature).'''
  spec: ["#history", "§19.11", "Annex D.5", "§19.8"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "true-value" },
      expect: { outcome: ok, value: { id: "n1", body: "true-value" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { edit_cbor: { path: "state/current.cbor.zst",
                     pointer: "/state/notes/n1/body", value: "forged-value" } }
      { fix_checksums: true }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: ok } }
    ] }
  ]
}

{
  format: 1
  name: manifest-index-selection-mismatch-invalid
  suite: scenario
  tags: [tampering, aliasing]
  // Attack: retarget manifest.json's selected point to a fabricated point
  // id while history/index.json (and the state entry) still name the
  // genuine one, then repair checksums. §19.5: history/index.json
  // "identifies the selected lineage and point"; §19.7: everything in one
  // artifact MUST describe the same committed boundary. Two entries naming
  // different selections cannot describe one boundary.
  spec: ["§19.5", "§19.6", "§19.7"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { edit_json: { path: "manifest.json", pointer: "/selected/point",
                     value: "point-that-does-not-exist" } }
      { fix_checksums: true }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: invalid, violates: ["§19.5", "§19.7"],
                  detail: "manifest selected point differs from history index selection" } }
    ] }
  ]
}

{
  format: 1
  name: duplicate-archive-entry-invalid
  suite: scenario
  tags: [tampering, aliasing]
  // Attack: ZIP permits two entries with the same name; extractors disagree
  // on which one wins, a classic parser-differential vector. The duplicate
  // here has IDENTICAL bytes, so every checksum matches — the only violated
  // rule is uniqueness. Annex D.5: "Verification succeeds only when every
  // referenced entry exists exactly once."
  spec: ["Annex D.5", "§19.5"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { duplicate_entry: { path: "state/current.cbor.zst" } }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: invalid, violates: ["Annex D.5"],
                  detail: "referenced entry exists more than once" } }
    ] }
  ]
}

{
  format: 1
  name: tampered-state-checksum-mismatch-invalid
  suite: scenario
  tags: [tampering]
  // Attack: flip a byte in state/current.cbor.zst after export, leaving the
  // manifest checksum stale. §19.8: "Import verifies the complete recursive
  // artifact." Annex D.5: "Verification succeeds only when every referenced
  // entry exists exactly once and every checksum matches."
  spec: ["§19.8", "Annex D.5", "§19.5"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { corrupt_entry: { path: "state/current.cbor.zst" } }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: invalid, violates: ["§19.8", "Annex D.5"],
                  detail: "state entry bytes do not match manifest sha256" } }
    ] }
  ]
}

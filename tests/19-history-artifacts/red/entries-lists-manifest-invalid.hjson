{
  format: 1
  name: entries-lists-manifest-invalid
  suite: scenario
  tags: [tampering]
  // Attack: list `manifest.json` inside the manifest's own `entries` map.
  // §19.5 (SPEC-ISSUES #33) pins `entries` membership exhaustively: it covers
  // every required direct archive leaf OTHER THAN `manifest.json`, which cannot
  // checksum itself. A manifest whose `entries` names `manifest.json` is not the
  // single canonical form and is rejected at admission — an under-verified or
  // divergent artifact must not open.
  spec: ["§19.5"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    // Add an `entries` row for `manifest.json` itself (checksum of its own bytes).
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { add_manifest_entry: { path: "manifest.json" } }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: invalid, violates: ["§19.5"],
                  detail: "manifest `entries` must not list manifest.json" } }
    ] }
  ]
}

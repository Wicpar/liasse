{
  format: 1
  name: missing-required-entry-invalid
  suite: scenario
  tags: [tampering]
  // Attack: strip the state entry while keeping its manifest record.
  // Annex D.5: "Verification succeeds only when every referenced entry
  // exists exactly once and every checksum matches."
  spec: ["Annex D.5", "§19.5", "§19.8"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { remove_entry: { path: "state/current.cbor.zst" } }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: invalid, violates: ["Annex D.5", "§19.5"],
                  detail: "referenced entry state/current.cbor.zst does not exist" } }
    ] }
  ]
}

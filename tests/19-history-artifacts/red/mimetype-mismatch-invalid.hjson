{
  format: 1
  name: mimetype-mismatch-invalid
  suite: scenario
  tags: [tampering]
  // Attack: rewrite the mimetype entry and fix every checksum so the ONLY
  // violated rule is the mimetype content itself. §19.5: mimetype contains
  // "application/vnd.liasse+zip"; an artifact carrying a different content
  // does not use the required structure.
  spec: ["§19.5"]

  package: {
    $liasse: 1
    $app: "t.hist@1.0.0"
    $model: {
      notes: {
        $key: "id"
        id: "text"
        body: "text"
      }
      $mut: {
        put: [
          "n = .notes + { id: @id, body: @body }"
          "return n { id, body }"
        ]
      }
      all: { $view: ".notes { id, body, $sort: [id] }" }
      $public: {
        notes: {
          $view: ".all"
          $mut: { put: ".put" }
        }
      }
    }
  }

  steps: [
    { call: "public.notes.put", args: { id: "n1", body: "one" },
      expect: { outcome: ok, value: { id: "n1", body: "one" } } }
    { export: { as: "a1" }, expect: { outcome: ok } }
    { tamper_artifact: { from: "a1", as: "a1x", ops: [
      { set_entry: { path: "mimetype", text: "application/zip" } }
      { fix_checksums: true }
    ] } }
    { in_sandbox: "s1", steps: [
      { restore: { from: "a1x" },
        expect: { outcome: invalid, violates: ["§19.5"],
                  detail: "mimetype entry does not contain application/vnd.liasse+zip" } }
    ] }
  ]
}

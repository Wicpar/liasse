{
  // §23.5: host access retains "provider contracts, serial admission, and
  // atomicity"; §17.9: "A provider failure before admission rejects the affected
  // operation and commits no application effect ... an unavailable signing
  // operation rejects the requesting mutation." §23.3: an implementation "MUST
  // preserve declared ... values, ... atomicity." A misbehaving (erroring)
  // registered key provider must reject the in-flight mutation cleanly AND must
  // not corrupt already-committed state. `issue` writes a `tokens` row then signs
  // through the keyring; when the provider's sign fails, the whole `issue` is
  // rejected and the previously committed token survives.
  format: 1
  name: provider-error-rejects-preserving-committed-state
  suite: scenario
  spec: ["#rust-host", "§23.5", "§23.3", "#keyrings", "§17.9"]
  tags: ["provider", "atomicity"]

  package: {
    $liasse: 1
    $app: "t.providererr@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      tokens: {
        $key: "id"
        id: "uuid = uuid()"
        note: "text"
      }
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      $mut: {
        issue: [
          "t = .tokens + { note: @note }"
          "sig = cose.sign(/session_keys, { id: t.id })"
          "return t { id, note }"
        ]
      }
      $public: {
        tokens: { $view: ".tokens { id, note, $sort: [note] }" }
      }
    }
  }

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  steps: [
    { connect: "c1" }
    // Healthy provider: first issue commits.
    { operator: { call: "issue", args: { note: "first" } },
      expect: { outcome: ok, value: { id: "$bind:first", note: "first" } } }
    // Provider sign now fails.
    { provider_set: { provider: "test-kp", fail: ["sign"] } }
    // The signing mutation is rejected before admission; no token row is created.
    { operator: { call: "issue", args: { note: "second" } },
      expect: { outcome: rejected, violates: ["§17.9", "§23.5"] } }
    // Committed state is preserved: only the first token exists.
    { watch: "public.tokens", on: "c1", id: "w1",
      expect_init: { value: [ { id: "$ref:first", note: "first" } ] } }
  ]
}

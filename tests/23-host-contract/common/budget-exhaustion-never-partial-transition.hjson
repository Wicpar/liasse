{
  // §23.6: "Budget exhaustion produces operational backpressure or a rejected
  // request according to the declared API contract. It never permits a partial
  // state transition." §23.6 lists "query and mutation time" as a budget. A
  // provider operation that hangs (never returns) exceeds any finite
  // mutation-time budget; the enclosing mutation is resolved by budget
  // exhaustion. This case pins BOTH the MUST invariant — NO partial state
  // transition — and, per §23.6 (SPEC-ISSUES #16), the outcome CLASS: an
  // in-flight mutation-time budget exhausted mid-transition surfaces as a
  // terminal `rejected` request, never backpressure, and a silent API contract
  // defaults to reject. `issue` writes a `tokens` row then signs; with the signer
  // hung under a finite mutation-time budget, the atomic transition rejects and
  // no `tokens` row is left behind. (budget_set / provider_set hang: see NOTES.md.)
  format: 1
  name: budget-exhaustion-never-partial-transition
  suite: scenario
  spec: ["#rust-host", "§23.6", "#keyrings", "§17.9", "#runtime", "§22.2"]
  tags: ["budget", "atomicity", "provider"]
  note: "§23.6 (SPEC-ISSUES #16) pins in-flight budget exhaustion (here a finite mutation-time budget the hung signer exceeds) to a terminal `rejected` request, never backpressure, when the API contract is silent. This case asserts both that rejection and the absolute MUST — exhaustion 'never permits a partial state transition' — via the trailing watch showing the `tokens` collection empty: the atomic `issue` (write-then-sign, §22.2) left no partial row."

  package: {
    $liasse: 1
    $app: "t.budgetnopartial@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      tokens: {
        $key: "id"
        id: "uuid = uuid()"
        note: "text"
      }
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      $mut: {
        issue: [
          "t = .tokens + { note: @note }"
          "sig = cose.sign(/session_keys, { id: t.id })"
          "return t { id, note }"
        ]
      }
      $public: {
        tokens: { $view: ".tokens { id, note, $sort: [note] }" }
      }
    }
  }

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  steps: [
    { connect: "c1" }
    { budget_set: { mutation_time: "PT1S" } }
    // Signer hangs; the mutation-time budget is exhausted.
    { provider_set: { provider: "test-kp", hang: ["sign"] } }
    // In-flight budget exhaustion resolves the request as a terminal rejection
    // (§23.6, SPEC-ISSUES #16 — silent contract defaults to reject), never a
    // partial transition.
    { operator: { call: "issue", args: { note: "never" } },
      expect: { outcome: rejected, violates: ["#rust-host", "§23.6"] } }
    // The MUST: no partial `tokens` row exists.
    { watch: "public.tokens", on: "c1", id: "w1", expect_init: { value: [] } }
  ]
}

{
  // §16.3: a `pure` function is one where "same logical inputs produce the same
  // output," and "Pure functions MAY run during views, checks, and replay."
  // §23.3 requires an implementation to "materialize or compute views" while
  // preserving declared values across strategies, and §22.1 says "Replay uses
  // those recorded values." A pure function's result is therefore NOT required
  // to be recorded — the runtime may recompute it, including on replay. The
  // attack: a component declares effect `pure` but in fact returns a different
  // value on each evaluation for identical inputs (op `drifting`, §23 NOTES).
  // A view over it is computed once live and again after a restart-driven
  // recompute; the two MAY diverge. §16.3 (SPEC-ISSUES #15) pins this asymmetry:
  // "a `pure` function that returns divergent values for equal arguments is a
  // §2.1 nonconformance; a DETECTED divergence is a host failure and commits no
  // effect. Because the runtime MAY recompute rather than record a pure result,
  // it carries no obligation to reproduce a pre-replay value it was permitted not
  // to record — a lying-pure function has no post-replay value guarantee." So the
  // post-restart recomputed value is whatever the recompute yields: still
  // UNSPECIFIED, because the runtime recomputes across an independent
  // watch/restart and does not observe the two results together, so no divergence
  // is detected to reject.
  format: 1
  name: impure-pure-function-replay-divergence-unspecified
  suite: scenario
  spec: ["#host-namespaces", "§16.3", "#rust-host", "§23.3", "#runtime", "§22.1"]
  tags: ["namespace", "effect-class", "replay", "nonconforming-host"]
  note: "The component declares effect `pure` (§16.3) but returns a different value on each evaluation for the same input. §16.3 (SPEC-ISSUES #15) now pins that a DETECTED pure-divergence is a host failure that rejects, but also that the runtime carries no obligation to reproduce a pre-replay value it was permitted not to record — a lying-pure function has no post-replay value guarantee. Here the pre- and post-restart views are computed by independent recomputations the runtime never compares, so no divergence is detected and the post-restart value stays unspecified (it may or may not equal the pre-restart value)."

  package: {
    $liasse: 1
    $app: "t.driftpure@1.0.0"
    $requires: { u: "test.util@1" }
    $model: {
      seed: { $key: "id", id: "text", n: "int" }
      // Declared pure -> the runtime MAY recompute this view at any time.
      drifted: { $view: "= u.g(/seed['only'].n)" }
      $public: {
        out: { $view: ".drifted" }
      }
    }
    $data: { seed: { only: { n: 7 } } }
  }

  hosts: {
    namespaces: [
      {
        id: "test.util"
        version: "1.0.0"
        interface_hash: "ih-util-drift"
        functions: {
          // Declared pure, but op `drifting` returns a different value each call.
          g: { signature: "(int) -> int", effect: "pure", op: "drifting" }
        }
      }
    ]
  }

  steps: [
    { connect: "c1" }
    // First evaluation binds whatever the (falsely-pure) component returned.
    { watch: "public.out", on: "c1", id: "w1",
      expect_init: { value: "$bind:live" } }
    { restart: {} }
    // After replay the runtime MAY recompute; whether it equals $live is not
    // pinned, because §16.3 purity was violated by the component.
    { watch: "public.out", on: "c1", id: "w2",
      expect_init: { outcome: unspecified } }
  ]
}

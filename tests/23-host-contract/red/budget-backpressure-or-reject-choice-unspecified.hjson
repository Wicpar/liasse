{
  // §23.6: "Budget exhaustion produces operational backpressure OR a rejected
  // request according to the declared API contract. It never permits a partial
  // state transition." The invariant (no partial transition) is pinned and is
  // asserted by the common case budget-exhaustion-never-partial-transition. This
  // case isolates the OTHER half of the same sentence: which of the two visible
  // outcomes occurs — operational backpressure (the request is throttled/queued)
  // or an outright rejection — is chosen "according to the declared API
  // contract." When the package's surface contract does not itself pin that
  // choice (nothing in this minimal package declares a backpressure-vs-reject
  // policy), the spec leaves the observed outcome class unspecified. A pedantic
  // reader cannot deduce `rejected` versus a backpressure signal from SPEC.md.
  format: 1
  name: budget-backpressure-or-reject-choice-unspecified
  suite: scenario
  spec: ["#rust-host", "§23.6"]
  tags: ["budget", "backpressure"]
  note: "§23.6 admits either operational backpressure or a rejected request on budget exhaustion, chosen by the declared API contract. This minimal package declares no such policy, so which of the two outcome classes a client observes is unspecified. The separate no-partial-transition invariant is covered by common/budget-exhaustion-never-partial-transition."

  package: {
    $liasse: 1
    $app: "t.budgetchoice@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      tokens: { $key: "id", id: "uuid = uuid()", note: "text" }
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      $mut: {
        issue: [
          "t = .tokens + { note: @note }"
          "sig = cose.sign(/session_keys, { id: t.id })"
          "return t { id, note }"
        ]
      }
    }
  }

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  steps: [
    { connect: "c1" }
    { budget_set: { mutation_time: "PT1S" } }
    { provider_set: { provider: "test-kp", hang: ["sign"] } }
    // Exhaustion is guaranteed; the CLASS of the surfaced outcome is not.
    { operator: { call: "issue", args: { note: "throttle-or-reject" } },
      expect: { outcome: unspecified } }
  ]
}

{
  // §23.6 makes resource budgets a host option ("The host MAY allocate budgets")
  // and only fixes behavior on "Budget exhaustion." §17.9 pins provider FAILURE
  // ("A provider failure before admission rejects the affected operation"), but a
  // provider that HANGS neither succeeds nor fails: it never reaches admission and
  // never rejects. The attack is a registered key provider whose `sign` never
  // returns, with NO mutation-time budget in force. SPEC.md mandates no timeout of
  // its own — a runtime MAY run without budgets (§23.6) — so nothing in the spec
  // forces the enclosing mutation to resolve. Whether it hangs, is eventually
  // killed, or is rejected is unspecified. Contrast the common case
  // budget-exhaustion-never-partial-transition, where a finite mutation-time
  // budget IS installed and §23.6 exhaustion applies.
  format: 1
  name: no-time-budget-hanging-provider-unspecified
  suite: scenario
  spec: ["#rust-host", "§23.6", "#keyrings", "§17.9"]
  tags: ["provider", "hang", "budget"]
  note: "A registered key provider's sign operation hangs and no mutation-time budget is installed. §17.9 pins provider failure but a hang is neither success nor failure, and §23.6 makes budgets optional and mandates no default timeout. With no budget in force the spec does not require the enclosing mutation to resolve, so its outcome is unspecified."

  package: {
    $liasse: 1
    $app: "t.nobudgethang@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      tokens: { $key: "id", id: "uuid = uuid()", note: "text" }
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      $mut: {
        issue: [
          "t = .tokens + { note: @note }"
          "sig = cose.sign(/session_keys, { id: t.id })"
          "return t { id, note }"
        ]
      }
    }
  }

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  steps: [
    { connect: "c1" }
    // No budget_set here: nothing bounds the hang.
    { provider_set: { provider: "test-kp", hang: ["sign"] } }
    { operator: { call: "issue", args: { note: "hang" } },
      expect: { outcome: unspecified } }
  ]
}

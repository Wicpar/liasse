{
  format: 1
  name: retain-omitted-accepts-until-revoked
  suite: scenario
  tags: ["rotation"]
  spec: ["#keyrings", "§17.1", "§17.3"]
  note: "§17.1: when $retain is omitted, retired public versions remain accepted until explicit revocation or destruction. A v1 token still authenticates ~181 virtual days and several rotations later; explicit revocation then rejects it immediately (§17.3). The count of intervening versions is deliberately not asserted — how many overdue rotations a runtime performs at once is not the rule under test."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    "$liasse": 1
    "$app": "t.keyrings@1.0.0"
    "$requires": { "cose": "liasse.cose@1" }
    "$model": {
      "session_keys": {
        "$keyring": {
          "$provider": "test-kp"
          "$algorithm": "Ed25519"
          "$rotate": "P30D"
        }
      }
      "accounts": {
        "$key": "id"
        "id": "text"
        "name": "text"
        "enabled": "bool = true"
      }
      "sessions": {
        "$key": "id"
        "id": "uuid = uuid()"
        "account": { "$ref": "/accounts" }
        "revoked": "bool = false"
      }
      "$mut": {
        "login": [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      "$auth": {
        "session": {
          "$credential": "bytes"
          "$verify": "cose.verify(/session_keys, $credential)"
          "$session": "/sessions[$proof.session]"
          "$actor": "/accounts[$session.account]"
          "$check": ["$proof.auth == $auth_name", "!$session.revoked"]
        }
      }
      "$public": {
        "login": { "$mut": { "login": ".login" } }
        "ring_current": { "$view": "/session_keys.$current" }
      }
      "$roles": {
        "member": {
          "$auth": "session"
          "$members": ".accounts[:a | a.enabled]"
          "mysessions": { "$view": "/sessions[:s | s.account == $actor] { revoked }" }
        }
      }
    }
    "$data": { "accounts": { "alice": { "name": "Alice" } } }
  }

  steps: [
    { watch: "public.ring_current", id: "w1",
      expect_init: { value: { id: "$bind:v1", "...": true } } }
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$bind:tok1" } } }
    { advance_time: "P31D" }
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$any" } } }
    // Day ~181: many rotations later, no $retain — v1 must still verify.
    { advance_time: "P150D" }
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$any" } } }
    { connect: "c2",
      authenticate: { role: "member", auth: "session", credential: "$ref:tok1" },
      expect: { outcome: ok } }
    // Explicit revocation ends acceptance immediately (§17.3).
    { keyring_admin: { ring: "/session_keys", op: "revoke", version: "$ref:v1" },
      expect: { outcome: ok } }
    { connect: "c3",
      authenticate: { role: "member", auth: "session", credential: "$ref:tok1" },
      expect: { outcome: denied, violates: ["§17.1", "§17.3"] } }
  ]
}

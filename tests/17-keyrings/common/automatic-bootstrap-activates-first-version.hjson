{
  format: 1
  name: automatic-bootstrap-activates-first-version
  suite: scenario
  spec: ["#keyrings", "§17.3", "§17.2"]
  note: "§17.3: during initial create, automatic mode generates and activates the first version as part of bootstrap, and at most one signing version is active. Right after load the ring has one activated version, the accepted set contains exactly that version, and the dependent login surface is available."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
        ring_current: { $view: "/session_keys.$current" }
        ring_accepted: { $view: "/session_keys.$accepted" }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    // Version metadata per §17.2: id, algorithm, created_at, activated_at;
    // "...": true because the spec does not pin the remaining member names.
    { watch: "public.ring_current", id: "w1",
      expect_init: { value: {
        id: "$bind:v1"
        algorithm: "Ed25519"
        created_at: "$any:timestamp"
        activated_at: "$any:timestamp"
        retired_at: "$absent"
        revoked_at: "$absent"
        "...": true
      } } }
    { watch: "public.ring_accepted", id: "w2",
      expect_init: { value: { $unordered: [
        { id: "$ref:v1", "...": true }
      ] } } }
    // The surface requiring the active keyring is available immediately (§17.3).
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$any" } } }
  ]
}

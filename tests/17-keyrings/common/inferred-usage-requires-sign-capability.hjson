{
  format: 1
  name: inferred-usage-requires-sign-capability
  suite: static
  spec: ["#keyrings", "§17.1", "§17.5", "§17.6", "#host-namespaces"]
  note: "$usage is omitted, so §17.1 makes the checker infer the minimal operation set required by every call site using the keyring. The login mutation calls cose.sign(/session_keys, ...), whose namespace descriptor requires the provider 'sign' capability (§17.5). §17.6 validates the provider's operation set at load; this provider advertises no operations."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: []
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  expect: {
    outcome: invalid
    violates: ["§17.6", "§17.1"]
    detail: "inferred keyring usage requires the 'sign' operation; provider 'test-kp' does not advertise it"
  }
}

{
  format: 1
  name: surface-unavailable-before-manual-activation
  suite: scenario
  spec: ["#keyrings", "§17.1", "§17.3"]
  note: "§17.3 mandates that a package surface requiring an active keyring becomes available only after the keyring has one active version, and manual mode (no $rotate, §17.1) starts with none — so this call MUST NOT succeed. The spec does not pin which failure category an unavailable dependent surface produces (denied vs rejected vs error), hence outcome: unspecified."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: false
        bind: true
        protection: "software"
        external_keys: {
          ext1: { algorithm: "Ed25519" }
        }
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    // The keyring has no active version yet; login signs with it, so the
    // surface must be unavailable. Only the failure category is unpinned.
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: unspecified } }
  ]
}

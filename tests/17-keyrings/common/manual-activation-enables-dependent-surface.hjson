{
  format: 1
  name: manual-activation-enables-dependent-surface
  suite: scenario
  spec: ["#keyrings", "§17.1", "§17.3", "§17.4"]
  note: "Omitting $rotate disables scheduled rotation and leaves activation manual (§17.1). §17.3: manual mode requires the host to bind and activate one version before the dependent surface is enabled. §17.4: the manual operator action binds an externally created provider handle, validates its public metadata, and activates it through the rotation transition."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: false
        bind: true
        protection: "software"
        external_keys: {
          "ext1": { algorithm: "Ed25519" }
        }
      }
    }
  }

  package: {
    "$liasse": 1
    "$app": "t.keyrings@1.0.0"
    "$requires": { "cose": "liasse.cose@1" }
    "$model": {
      "session_keys": {
        "$keyring": {
          "$provider": "test-kp"
          "$algorithm": "Ed25519"
        }
      }
      "accounts": {
        "$key": "id"
        "id": "text"
        "name": "text"
        "enabled": "bool = true"
      }
      "sessions": {
        "$key": "id"
        "id": "uuid = uuid()"
        "account": { "$ref": "/accounts" }
        "revoked": "bool = false"
      }
      "$mut": {
        "login": [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      "$auth": {
        "session": {
          "$credential": "bytes"
          "$verify": "cose.verify(/session_keys, $credential)"
          "$session": "/sessions[$proof.session]"
          "$actor": "/accounts[$session.account]"
          "$check": ["$proof.auth == $auth_name", "!$session.revoked"]
        }
      }
      "$public": {
        "login": { "$mut": { "login": ".login" } }
        "ring_current": { "$view": "/session_keys.$current" }
      }
      "$roles": {
        "member": {
          "$auth": "session"
          "$members": ".accounts[:a | a.enabled]"
          "mysessions": { "$view": "/sessions[:s | s.account == $actor] { revoked }" }
        }
      }
    }
    "$data": { "accounts": { "alice": { "name": "Alice" } } }
  }

  steps: [
    { keyring_admin: { ring: "/session_keys", op: "bind_activate", external: "ext1" },
      expect: { outcome: ok } }
    { watch: "public.ring_current", id: "w1",
      expect_init: { value: {
        id: "$bind:v1"
        algorithm: "Ed25519"
        activated_at: "$any:timestamp"
        retired_at: "$absent"
        "...": true
      } } }
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$bind:tok1" } } }
    { connect: "c2",
      authenticate: { role: "member", auth: "session", credential: "$ref:tok1" },
      expect: { outcome: ok } }
  ]
}

{
  format: 1
  name: verification-survives-provider-outage
  suite: scenario
  tags: ["availability"]
  spec: ["#keyrings", "§17.2", "§17.7", "§17.9"]
  // Availability attack surface: the HSM goes completely dark. §17.2 makes
  // accepted public keys application values and §17.7 says verification uses
  // the accepted public versions — no provider operation is involved — so
  // existing tokens MUST keep authenticating. §17.9: the unavailable signing
  // operation rejects new logins. An implementation that round-trips
  // verification through the provider fails the first assertion; one that
  // silently queues or fakes signatures fails the second.
  note: "Keyring metadata also stays readable during the outage: it is committed application state, not a live provider call."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    "$liasse": 1
    "$app": "t.keyrings@1.0.0"
    "$requires": { "cose": "liasse.cose@1" }
    "$model": {
      "session_keys": {
        "$keyring": {
          "$provider": "test-kp"
          "$algorithm": "Ed25519"
          "$rotate": "P30D"
          "$retain": "P45D"
        }
      }
      "accounts": {
        "$key": "id"
        "id": "text"
        "name": "text"
        "enabled": "bool = true"
      }
      "sessions": {
        "$key": "id"
        "id": "uuid = uuid()"
        "account": { "$ref": "/accounts" }
        "revoked": "bool = false"
      }
      "$mut": {
        "login": [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      "$auth": {
        "session": {
          "$credential": "bytes"
          "$verify": "cose.verify(/session_keys, $credential)"
          "$session": "/sessions[$proof.session]"
          "$actor": "/accounts[$session.account]"
          "$check": ["$proof.auth == $auth_name", "!$session.revoked"]
        }
      }
      "$public": {
        "login": { "$mut": { "login": ".login" } }
        "ring_current": { "$view": "/session_keys.$current" }
      }
      "$roles": {
        "member": {
          "$auth": "session"
          "$members": ".accounts[:a | a.enabled]"
          "mysessions": { "$view": "/sessions[:s | s.account == $actor] { revoked }" }
        }
      }
    }
    "$data": { "accounts": { "alice": { "name": "Alice" } } }
  }

  steps: [
    { watch: "public.ring_current", id: "w1",
      expect_init: { value: { id: "$bind:v1", "...": true } } }
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$bind:tok1" } } }
    // Total provider outage.
    { provider_set: { provider: "test-kp", available: false } }
    // Verification needs only the accepted public versions — still ok.
    { connect: "c2",
      authenticate: { role: "member", auth: "session", credential: "$ref:tok1" },
      expect: { outcome: ok } }
    // Signing needs the provider — rejected, no partial effect.
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: rejected, violates: ["§17.9"] } }
    // Public metadata remains committed application state.
    { watch: "public.ring_current", on: "c1", id: "w2",
      expect_init: { value: { id: "$ref:v1", retired_at: "$absent", "...": true } } }
  ]
}

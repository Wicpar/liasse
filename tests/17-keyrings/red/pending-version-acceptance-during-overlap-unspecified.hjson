{
  format: 1
  name: pending-version-acceptance-during-overlap-unspecified
  suite: scenario
  tags: ["rotation", "boundary"]
  spec: ["#keyrings", "§17.2", "§17.3", "§17.4"]
  // Pedantic corner with a security edge: during the $overlap window a pending
  // version is "recorded and exposed" (§17.4 step 3). §17.2 defines
  // ring.$accepted as "versions accepted for verification" and ring.$public as
  // "public key values for accepted versions", while §17.3 only says retired
  // versions remain accepted and active is selected for new operations. The
  // spec never states whether a PENDING version is already accepted for
  // verification before activation. If it is, a signature made with the
  // pending key's private counterpart (e.g. an externally bound key an
  // attacker touched pre-activation) verifies a full $overlap early.
  note: "Genuine gap: §17.4 step 3 exposes pending public metadata, but neither §17.2 nor §17.3 pins pending membership in $accepted/$public before activation. The first watch asserts only the pinned part (a pending version exists at day 29 with v1 still active); the second records the unpinned acceptance question."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: { $every: "P30D", $overlap: "P2D" }
          $retain: "P45D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
        ring_versions: { $view: "/session_keys.$versions" }
        ring_accepted: { $view: "/session_keys.$accepted" }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    // Day 29: inside the overlap window (lead time starts at day 28).
    { advance_time: "P29D" }
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$any" } } }
    // Pinned: the pending version is recorded and exposed, v1 still active.
    { watch: "public.ring_versions", id: "w1",
      expect_init: { value: { $unordered: [
        { id: "$any", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
        { id: "$any", activated_at: "$absent", retired_at: "$absent", "...": true }
      ] } } }
    // Unpinned: does $accepted contain 1 entry (active only) or 2 (plus pending)?
    { watch: "public.ring_accepted", id: "w2",
      expect_init: { outcome: unspecified } }
  ]
}

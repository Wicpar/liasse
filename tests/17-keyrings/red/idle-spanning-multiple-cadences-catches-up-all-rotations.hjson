{
  format: 1
  name: idle-spanning-multiple-cadences-catches-up-all-rotations
  suite: scenario
  tags: ["rotation", "ordering"]
  spec: ["#keyrings", "§17.1", "§17.3", "§17.4"]
  note: '''
    §17.1: a duration `$rotate` is shorthand for automatic rotation at that
    cadence. §17.4: automatic rotation activates a replacement and retires the
    prior active version; "A runtime MAY schedule them or perform a due rotation
    before the next operation. THE RESULTING LOGICAL ORDER AND KEY SELECTION ARE
    IDENTICAL." A scheduled runtime with a P30D cadence fires a rotation at day
    30, day 60, and day 90, so after the clock crosses three whole cadence
    periods it has performed THREE rotations: the ring holds four versions
    (v1..v3 retired, v4 active). §17.4's identical-result guarantee therefore
    fixes the lazy "perform a due rotation before the next operation" strategy to
    the SAME four-version outcome — a runtime that performs a single rotation to
    catch up an idle gap of three cadences is a divergence, not a permitted
    scheduling choice.

    This is the multi-cadence generalisation of `scheduled-rotation-retires-\
    prior-active` (one cadence, exactly two versions). The long `$retain`
    (P365D) keeps every retired version well inside its acceptance window, so
    version *count* is governed purely by how many rotations occurred, isolating
    the catch-up rule from `$retain`/destruction. §17.3: at most one signing
    version is active — asserted by the single `retired_at: $absent` entry.
  '''

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P365D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
        ring_versions: { $view: "/session_keys.$versions" }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    { watch: "public.ring_versions", id: "w1",
      expect_init: { value: { $unordered: [
        { activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
      ] } } }
    // Idle across three whole P30D cadence periods (day 91 > 30, 60, 90).
    { advance_time: "P91D" }
    // Admission-creating operation: any due rotation is performed no later than
    // this (§17.4). A scheduled runtime would have rotated three times by now.
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$any" } } }
    // §17.4 identical-key-selection: exactly four versions — three retired, one
    // active. A single catch-up rotation (two versions) violates the guarantee.
    { expect_view: { watch: "w1", value: { $unordered: [
      { retired_at: "$any:timestamp", "...": true }
      { retired_at: "$any:timestamp", "...": true }
      { retired_at: "$any:timestamp", "...": true }
      { activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
    ] } } }
  ]
}

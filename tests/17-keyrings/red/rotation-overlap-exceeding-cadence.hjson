{
  format: 1
  name: rotation-overlap-exceeding-cadence
  suite: static
  tags: ["boundary"]
  spec: ["#keyrings", "§17.1", "§17.4", "§C.16"]
  // Boundary abuse: $overlap (pending lead time) longer than $every (cadence).
  // Taken literally, the pending version for rotation N+1 would have to be
  // exposed BEFORE rotation N activates, so several pending versions per ring
  // would coexist. §17.3's lifecycle admits at most one pending version, so
  // §17.1 (and §C.16) now pin `$overlap` strictly less than `$every`: a
  // declaration with `$overlap >= $every` is rejected at load (§9.2 step 5)
  // with a keyring diagnostic.
  note: "SPEC-ISSUES #18: $overlap P40D at/beyond $every P30D would require a successor pending version before its predecessor activates. §17.1/§C.16 pin `$overlap` strictly less than `$every`; this declaration is statically rejected."

  hosts: {
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: { $every: "P30D", $overlap: "P40D" }
          $retain: "P45D"
        }
      }
    }
  }

  expect: {
    outcome: invalid
    violates: ["§17.1", "§C.16"]
    detail: "$overlap P40D is not strictly less than $every P30D; the declaration is rejected at load (§17.1)"
  }
}

{
  format: 1
  name: usage-excluding-callsite-operation
  suite: static
  tags: ["boundary"]
  spec: ["#keyrings", "§17.1", "§17.6", "§9.2"]
  // Pedantic corner: $usage is declared as the empty set — "the set of
  // permitted protected key operations" (§17.1) permits nothing — while a
  // package call site (cose.sign) performs the protected sign operation.
  // §17.1 now pins that a declared $usage MUST include every protected
  // operation a call site performs; a call site requiring an operation outside
  // the declared $usage is rejected at load (§9.2 step 5). $usage: [] is legal
  // only when no call site signs, so this declaration is statically rejected.
  note: "SPEC-ISSUES #18: declared $usage [] excludes the protected `sign` operation the login mutation's cose.sign(/session_keys, ...) call site performs. §17.1 pins a declared $usage as a superset of the inferred set, rejected at load (§9.2 step 5)."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $usage: []
          $rotate: "P30D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  expect: {
    outcome: invalid
    violates: ["§17.1", "§9.2"]
    detail: "the login call site performs cose.sign(/session_keys, ...) but declared $usage [] permits no protected operation; rejected at load (§17.1, §9.2 step 5)"
  }
}

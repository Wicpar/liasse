{
  format: 1
  name: retain-boundary-instant
  suite: scenario
  tags: ["boundary", "rotation"]
  spec: ["#keyrings", "§17.1", "§17.3", "§17.4", "§22.5"]
  // Exact-boundary probe: v1 is signed at day 0, rotation is due at exactly
  // day 30, and $retain is P45D — the authentication attempt lands at exactly
  // day 75 = retirement + $retain. SPEC-ISSUES #18 pins both readings:
  //   (a) §17.4 pins the acceptance window half-open `[retired_at,
  //       retired_at + $retain)`, so the instant retired_at + $retain is
  //       already NOT accepted (exclusive boundary);
  //   (b) §17.4 pins the RECORDED retired_at at the scheduled cadence boundary
  //       (activated_at + $every = day 30), independent of when the lazy
  //       rotation fires, so retired_at + $retain is exactly day 75.
  // Day 75 is therefore the first instant v1 is no longer accepted: denied.
  note: "SPEC-ISSUES #18: half-open acceptance window `[retired_at, retired_at + $retain)`; retired_at is the scheduled boundary (day 30). Day 75 = day 30 + P45D is the exclusive end, so verification is denied. One second earlier is accepted (retain-window-bounds-retired-acceptance)."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
        enabled: "bool = true"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        revoked: "bool = false"
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $auth: {
        session: {
          $credential: "bytes"
          $verify: "cose.verify(/session_keys, $credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: ["$proof.auth == $auth_name", "!$session.revoked"]
        }
      }
      $public: {
        login: { $mut: { login: ".login" } }
      }
      $roles: {
        member: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          mysessions: { $view: "/sessions[:s | s.account == $actor] { revoked }" }
        }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$bind:tok1" } } }
    // Exactly the due instant: the triggering login and the scheduled instant
    // coincide at day 30 on the virtual clock.
    { advance_time: "P30D" }
    { call: "public.login.login", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$any" } } }
    // Exactly retirement + $retain = day 75, the exclusive end of the half-open
    // acceptance window: v1 is no longer accepted, so verification is denied.
    { advance_time: "P45D" }
    { connect: "c2",
      authenticate: { role: "member", auth: "session", credential: "$ref:tok1" },
      expect: { outcome: denied, violates: ["§17.4", "§17.3"] } }
  ]
}

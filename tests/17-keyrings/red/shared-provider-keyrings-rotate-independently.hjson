{
  format: 1
  name: shared-provider-keyrings-rotate-independently
  suite: scenario
  tags: ["keys", "rotation", "aliasing"]
  spec: ["#keyrings", "§17.1", "§17.4"]
  // Aliasing probe: two keyrings share one provider. §17.1 makes lifecycle
  // policy a property of each keyring declaration ("the declaration defines
  // observable policy"), so ring_a rotating at its P30D cadence must not
  // touch ring_b (P90D cadence, same provider). A runtime that keys rotation
  // state off the provider instead of the keyring would rotate both.
  note: "ring_b's version set must be exactly its bootstrap version after ring_a rotates."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    "$liasse": 1
    "$app": "t.keyrings@1.0.0"
    "$requires": { "cose": "liasse.cose@1" }
    "$model": {
      "ring_a": {
        "$keyring": { "$provider": "test-kp", "$algorithm": "Ed25519", "$rotate": "P30D", "$retain": "P45D" }
      }
      "ring_b": {
        "$keyring": { "$provider": "test-kp", "$algorithm": "Ed25519", "$rotate": "P90D", "$retain": "P45D" }
      }
      "accounts": {
        "$key": "id"
        "id": "text"
        "name": "text"
      }
      "sessions": {
        "$key": "id"
        "id": "uuid = uuid()"
        "account": { "$ref": "/accounts" }
      }
      "$mut": {
        "login": [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/ring_a, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      "$public": {
        "login": { "$mut": { "login": ".login" } }
        "a_versions": { "$view": "/ring_a.$versions" }
        "b_versions": { "$view": "/ring_b.$versions" }
      }
    }
    "$data": { "accounts": { "alice": { "name": "Alice" } } }
  }

  steps: [
    { watch: "public.a_versions", id: "w1",
      expect_init: { value: { $unordered: [
        { id: "$bind:va1", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
      ] } } }
    { watch: "public.b_versions", id: "w2",
      expect_init: { value: { $unordered: [
        { id: "$bind:vb1", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
      ] } } }
    { advance_time: "P31D" }
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$any" } } }
    // ring_a rotated: two versions.
    { expect_view: { watch: "w1", value: { $unordered: [
      { id: "$ref:va1", retired_at: "$any:timestamp", "...": true }
      { id: "$any", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
    ] } } }
    // ring_b untouched: exactly its bootstrap version, still active.
    { expect_view: { watch: "w2", value: { $unordered: [
      { id: "$ref:vb1", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
    ] } } }
  ]
}

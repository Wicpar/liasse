{
  format: 1
  name: due-rotation-commits-once-under-concurrency
  suite: scenario
  tags: ["ordering", "rotation"]
  spec: ["#keyrings", "§17.3", "§17.4", "#runtime"]
  // Ordering race: one rotation is due (day 31, cadence P30D) and two clients
  // race to trigger it lazily. §17.4: whether the runtime schedules the
  // rotation or performs the due rotation before the next operation, "the
  // resulting logical order and key selection are identical" — so exactly ONE
  // rotation transition may exist, not one per racing trigger. §17.3: at most
  // one signing version is active at one admitted state position. A runtime
  // that runs the due-rotation check per request without serializing it would
  // mint two replacement versions.
  note: "Asserting the exact two-element version set pins single execution of the due rotation; the per-branch call outcomes are unconditional because both serializations sign successfully."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: "P30D"
          $retain: "P45D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
        ring_versions: { $view: "/session_keys.$versions" }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    { watch: "public.ring_versions", id: "w1",
      expect_init: { value: { $unordered: [
        { id: "$bind:v1", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
      ] } } }
    { connect: "c2" }
    { advance_time: "P31D" }
    { concurrently: [
      [
        { call: "public.login.login", args: { account: "alice" }, on: "c1",
          expect: { outcome: ok, value: { token: "$any" } } }
      ]
      [
        { call: "public.login.login", args: { account: "alice" }, on: "c2",
          expect: { outcome: ok, value: { token: "$any" } } }
      ]
    ] }
    // Exactly one rotation: v1 retired plus a single new active version.
    { watch: "public.ring_versions", id: "w2",
      expect_init: { value: { $unordered: [
        { id: "$ref:v1", retired_at: "$any:timestamp", "...": true }
        { id: "$any", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
      ] } } }
  ]
}

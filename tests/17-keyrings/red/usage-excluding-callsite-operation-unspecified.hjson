{
  format: 1
  name: usage-excluding-callsite-operation-unspecified
  suite: static
  tags: ["boundary"]
  spec: ["#keyrings", "§17.1", "§17.6", "§9.2"]
  // Pedantic corner: $usage is declared as the empty set — "the set of
  // permitted key operations" (§17.1) permits nothing — while a package call
  // site (cose.sign) requires the sign operation. The spec states usage
  // inference when $usage is omitted, and §17.6 checks the PROVIDER's
  // operation set, but it never states the consequence of a declared $usage
  // that excludes an operation a call site requires, nor whether an empty
  // $usage is itself valid.
  note: "Genuine gap: §17.1 defines $usage as the permitted operation set but the spec never pins where a call site requiring an operation outside $usage is rejected (static validation per §9.2 step 5, keyring activation, or per-request admission), nor whether $usage: [] is legal at all. A conforming reading arguably cannot let cose.sign succeed at runtime, but the outcome class and phase are unpinned."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $usage: []
          $rotate: "P30D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  expect: {
    outcome: unspecified
    
    detail: "call site requires 'sign' but declared $usage permits no operations; enforcement point and outcome are not pinned by the spec"
  }
}

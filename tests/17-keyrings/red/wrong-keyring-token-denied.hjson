{
  format: 1
  name: wrong-keyring-token-denied
  suite: scenario
  tags: ["authz", "keys"]
  spec: ["#keyrings", "§17.7", "#authentication"]
  // Attack: two keyrings share one provider and one algorithm. The attacker
  // mints a perfectly valid token signed under ring_a (with real claims and a
  // real session row) and presents it to the authenticator that verifies
  // against ring_b. §17.7: verification uses the *named* keyring's accepted
  // public versions, so a signature from another ring's key must not verify —
  // even though provider, algorithm, and claims all match.
  note: "The control step proves the token itself is well-formed: the same credential authenticates against the ring that signed it."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    "$liasse": 1
    "$app": "t.keyrings@1.0.0"
    "$requires": { "cose": "liasse.cose@1" }
    "$model": {
      "ring_a": {
        "$keyring": { "$provider": "test-kp", "$algorithm": "Ed25519", "$rotate": "P30D", "$retain": "P45D" }
      }
      "ring_b": {
        "$keyring": { "$provider": "test-kp", "$algorithm": "Ed25519", "$rotate": "P30D", "$retain": "P45D" }
      }
      "accounts": {
        "$key": "id"
        "id": "text"
        "name": "text"
        "enabled": "bool = true"
      }
      "sessions": {
        "$key": "id"
        "id": "uuid = uuid()"
        "account": { "$ref": "/accounts" }
        "revoked": "bool = false"
      }
      "$mut": {
        "login_a": [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/ring_a, { auth: 'session_a', session: session.$key })"
          "return { token }"
        ]
      }
      "$auth": {
        "session_a": {
          "$credential": "bytes"
          "$verify": "cose.verify(/ring_a, $credential)"
          "$session": "/sessions[$proof.session]"
          "$actor": "/accounts[$session.account]"
          "$check": ["$proof.auth == $auth_name", "!$session.revoked"]
        }
        "session_b": {
          "$credential": "bytes"
          "$verify": "cose.verify(/ring_b, $credential)"
          "$session": "/sessions[$proof.session]"
          "$actor": "/accounts[$session.account]"
          "$check": ["!$session.revoked"]
        }
      }
      "$public": {
        "login": { "$mut": { "login_a": ".login_a" } }
      }
      "$roles": {
        "member_a": {
          "$auth": "session_a"
          "$members": ".accounts[:a | a.enabled]"
          "mysessions": { "$view": "/sessions[:s | s.account == $actor] { revoked }" }
        }
        "member_b": {
          "$auth": "session_b"
          "$members": ".accounts[:a | a.enabled]"
          "mysessions": { "$view": "/sessions[:s | s.account == $actor] { revoked }" }
        }
      }
    }
    "$data": { "accounts": { "alice": { "name": "Alice" } } }
  }

  steps: [
    { call: "public.login.login_a", args: { account: "alice" }, on: "c1",
      expect: { outcome: ok, value: { token: "$bind:tok1" } } }
    // Signature is by ring_a's key; ring_b's accepted versions cannot verify it.
    { connect: "c2",
      authenticate: { role: "member_b", auth: "session_b", credential: "$ref:tok1" },
      expect: { outcome: denied, violates: ["§17.7"] } }
    // Control: the same token is valid where it was signed.
    { connect: "c3",
      authenticate: { role: "member_a", auth: "session_a", credential: "$ref:tok1" },
      expect: { outcome: ok } }
  ]
}

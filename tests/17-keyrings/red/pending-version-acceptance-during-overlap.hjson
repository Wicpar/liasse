{
  format: 1
  name: pending-version-acceptance-during-overlap
  suite: scenario
  tags: ["rotation", "boundary"]
  spec: ["#keyrings", "§17.2", "§17.3", "§17.4"]
  // Pedantic corner with a security edge: during the $overlap window a pending
  // version is "recorded and exposed" (§17.4 step 3). SPEC-ISSUES #18 pins the
  // security-correct reading: a pending version appears in $versions but is
  // NOT a member of $accepted/$public until it is activated (§17.3). Only the
  // active version and in-$retain-window retired versions are accepted, so at
  // day 29 — pending v2 exposed, v1 still active — $accepted holds exactly the
  // one active version, never the pending key an attacker could touch early.
  note: "SPEC-ISSUES #18: a pending version is exposed in $versions (first watch) but excluded from $accepted/$public until activation (§17.3). At day 29 $accepted holds exactly the single active v1; the pending v2 is not accepted for verification."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    $liasse: 1
    $app: "t.keyrings@1.0.0"
    $requires: { cose: "liasse.cose@1" }
    $model: {
      session_keys: {
        $keyring: {
          $provider: "test-kp"
          $algorithm: "Ed25519"
          $rotate: { $every: "P30D", $overlap: "P2D" }
          $retain: "P45D"
        }
      }
      accounts: {
        $key: "id"
        id: "text"
        name: "text"
      }
      sessions: {
        $key: "id"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
      }
      $mut: {
        login: [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      $public: {
        login: { $mut: { login: ".login" } }
        ring_versions: { $view: "/session_keys.$versions" }
        ring_accepted: { $view: "/session_keys.$accepted" }
      }
    }
    $data: { accounts: { alice: { name: "Alice" } } }
  }

  steps: [
    // Day 29: inside the overlap window (lead time starts at day 28).
    { advance_time: "P29D" }
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$any" } } }
    // Pinned: the pending version is recorded and exposed, v1 still active.
    { watch: "public.ring_versions", id: "w1",
      expect_init: { value: { $unordered: [
        { id: "$any", activated_at: "$any:timestamp", retired_at: "$absent", "...": true }
        { id: "$any", activated_at: "$absent", retired_at: "$absent", "...": true }
      ] } } }
    // Pinned (§17.3): $accepted holds exactly the one active version (v1); the
    // pending v2 is exposed in $versions but is NOT accepted for verification.
    { watch: "public.ring_accepted", id: "w2",
      expect_init: { value: { $unordered: [
        { id: "$any", activated_at: "$any:timestamp", retired_at: "$absent", revoked_at: "$absent", "...": true }
      ] } } }
  ]
}

{
  format: 1
  name: revocation-overrides-retain-window
  suite: scenario
  tags: ["keys", "rotation"]
  spec: ["#keyrings", "§17.3", "§17.1"]
  // Attack surface: an operator learns v1 leaked and revokes it. The retired
  // version is still deep inside its $retain acceptance window, but §17.3 says
  // "revoked is rejected immediately" — revocation must beat retention.
  note: "v1 retires around day 30-31 with $retain P45D, so without the revocation the day-31 token check would succeed (as retain-window-bounds-retired-acceptance shows). The denial here is attributable only to revocation."

  hosts: {
    namespaces: { cose: "liasse.cose@1" }
    key_providers: {
      "test-kp": {
        algorithms: ["Ed25519"]
        operations: ["sign"]
        generate: true
        bind: false
        protection: "software"
      }
    }
  }

  package: {
    "$liasse": 1
    "$app": "t.keyrings@1.0.0"
    "$requires": { "cose": "liasse.cose@1" }
    "$model": {
      "session_keys": {
        "$keyring": {
          "$provider": "test-kp"
          "$algorithm": "Ed25519"
          "$rotate": "P30D"
          "$retain": "P45D"
        }
      }
      "accounts": {
        "$key": "id"
        "id": "text"
        "name": "text"
        "enabled": "bool = true"
      }
      "sessions": {
        "$key": "id"
        "id": "uuid = uuid()"
        "account": { "$ref": "/accounts" }
        "revoked": "bool = false"
      }
      "$mut": {
        "login": [
          "session = /sessions + { account: @account }"
          "token = cose.sign(/session_keys, { auth: 'session', session: session.$key })"
          "return { token }"
        ]
      }
      "$auth": {
        "session": {
          "$credential": "bytes"
          "$verify": "cose.verify(/session_keys, $credential)"
          "$session": "/sessions[$proof.session]"
          "$actor": "/accounts[$session.account]"
          "$check": ["$proof.auth == $auth_name", "!$session.revoked"]
        }
      }
      "$public": {
        "login": { "$mut": { "login": ".login" } }
        "ring_current": { "$view": "/session_keys.$current" }
        "ring_versions": { "$view": "/session_keys.$versions" }
      }
      "$roles": {
        "member": {
          "$auth": "session"
          "$members": ".accounts[:a | a.enabled]"
          "mysessions": { "$view": "/sessions[:s | s.account == $actor] { revoked }" }
        }
      }
    }
    "$data": { "accounts": { "alice": { "name": "Alice" } } }
  }

  steps: [
    { watch: "public.ring_current", id: "w1",
      expect_init: { value: { id: "$bind:v1", "...": true } } }
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$bind:tok1" } } }
    { advance_time: "P31D" }
    { call: "public.login.login", args: { account: "alice" },
      expect: { outcome: ok, value: { token: "$any" } } }
    { keyring_admin: { ring: "/session_keys", op: "revoke", version: "$ref:v1" },
      expect: { outcome: ok } }
    // Deep inside the retain window, but revoked is rejected immediately.
    { connect: "c2",
      authenticate: { role: "member", auth: "session", credential: "$ref:tok1" },
      expect: { outcome: denied, violates: ["§17.3"] } }
    { watch: "public.ring_versions", id: "w2",
      expect_init: { value: { $unordered: [
        { id: "$ref:v1", revoked_at: "$any:timestamp", "...": true }
        { id: "$any", retired_at: "$absent", revoked_at: "$absent", "...": true }
      ] } } }
  ]
}

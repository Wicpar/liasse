{
  format: 1
  name: media-compared-case-insensitively
  suite: scenario
  spec: ["#blobs", "§18.2"]
  tags: ["blob", "canonicalization"]
  note: '''
    §18.2: "Media type and subtype are compared case-insensitively after
    canonical lowercasing." The field accepts application/pdf; an upload
    declaring the ASCII-case variant "APPLICATION/PDF" must be accepted.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.mediacase@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["application/pdf"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "%PDF-1.7 payload"
        media: "APPLICATION/PDF"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
  ]
}
</content>

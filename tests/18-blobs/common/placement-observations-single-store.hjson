{
  format: 1
  name: placement-observations-single-store
  suite: scenario
  spec: ["#blobs", "§18.5"]
  tags: ["blob", "placement"]
  note: '''
    §18.5: "$stored contains verified stores. $satisfied evaluates the
    placement policy over them. $surplus contains verified copies outside the
    currently required policy." With a single-store $in policy and one verified
    copy, $stored is {primary}, $satisfied is true, and $surplus is empty.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.placement1@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      placement: {
        $view: ".docs[@id] { id, stored: .file.$stored { id }, satisfied: .file.$satisfied, surplus: .file.$surplus { id } }"
      }
      $public: {
        docs: {
          $view: ".placement"
          $mut: { add: ".add" }
        }
      }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "body"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    { watch: "public.docs", args: { id: "d1" }, on: "c1", id: "w1",
      expect_init: { value: {
        id: "d1"
        stored: { $unordered: [ { id: "primary" } ] }
        satisfied: true
        surplus: { $unordered: [] }
      } } }
  ]
}
</content>

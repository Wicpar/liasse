{
  format: 1
  name: live-descriptor-pins-content-across-restart
  suite: scenario
  spec: ["#blobs", "§18.10", "§18.8"]
  tags: ["blob", "retention", "lifecycle"]
  note: '''
    §18.10: "Live descriptors and retained history pin content according to
    storage policy. Vacuum MAY remove bytes only when every applicable live,
    history, placement, and grace requirement permits it." A committed row still
    holds the blob descriptor, so its content stays pinned and MUST NOT be
    vacuumed; the bytes remain fetchable. Committed state survives a runtime
    replay (durability), and the external store retains its object across that
    replay, so a fetch after restart still returns exactly the bytes identified
    by $sha512 (§18.8). No delete/vacuum-permitting condition occurs, so the
    only conformant outcome is a successful, hash-clean fetch of the original
    bytes.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.pin@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      one: { $view: ".docs[@id] { id, file }" }
      $public: {
        docs: {
          $view: ".one"
          $mut: { add: ".add" }
        }
      }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "stream_download", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "pinned by a live descriptor"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    // The row remains live across a replay; the descriptor still pins the bytes.
    { restart: {} }
    { connect: "c1" }
    { blob_get: {
        surface: "public.docs"
        args: { id: "d1" }
        at: ".file"
        on: "c1"
      }
      expect: { outcome: ok, holders: ["primary"], bytes: "pinned by a live descriptor" } }
  ]
}

{
  format: 1
  name: media-declaration-without-params-accepts-any-params
  suite: scenario
  spec: ["#blobs", "§18.2"]
  tags: ["blob", "canonicalization"]
  note: '''
    §18.2: "A declaration without parameters accepts the same type/subtype with
    any parameters." The field accepts text/plain (no parameters); an upload
    declaring text/plain with a charset parameter must be accepted.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.mediaparams@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "plain body"
        media: "text/plain; charset=utf-8"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
  ]
}

{
  format: 1
  name: unaccepted-media-rejected
  suite: scenario
  spec: ["#blobs", "§18.2"]
  tags: ["blob"]
  note: '''
    §18.2: "The $media array is the set of accepted media types." A descriptor
    whose $media is not in that set fails the accepted-media verification and
    the call is rejected before admission. The field accepts only
    application/pdf; the upload declares text/plain.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.media@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["application/pdf"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "not a pdf"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: rejected, violates: ["#blobs"],
                detail: "media type not in the accepted $media set" } }
  ]
}
</content>

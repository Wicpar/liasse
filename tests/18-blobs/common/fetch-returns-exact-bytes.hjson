{
  format: 1
  name: fetch-returns-exact-bytes
  suite: scenario
  spec: ["#blobs", "§18.8", "§18.9"]
  tags: ["blob", "fetch"]
  note: '''
    §18.8: "Visibility of a blob value through a currently authorized surface
    grants fetching the exact bytes identified by that descriptor" and "A
    successful fetch returns exactly the bytes identified by $sha512." §18.9:
    verification occurs at fetch before delivering a successful result. The
    surface exposes the whole blob value, so the fetched bytes equal the
    uploaded content.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.fetch@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      one: { $view: ".docs[@id] { id, file }" }
      $public: {
        docs: {
          $view: ".one"
          $mut: { add: ".add" }
        }
      }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "stream_download", "range_reads", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "the exact bytes"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    { blob_get: {
        surface: "public.docs"
        args: { id: "d1" }
        at: ".file"
        on: "c1"
      }
      expect: { outcome: ok, holders: ["primary"], bytes: "the exact bytes" } }
  ]
}

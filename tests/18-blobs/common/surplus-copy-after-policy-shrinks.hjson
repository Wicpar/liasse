{
  format: 1
  name: surplus-copy-after-policy-shrinks
  suite: scenario
  spec: ["#blobs", "§18.4", "§18.5"]
  tags: ["blob", "placement", "surplus", "lifecycle"]
  note: '''
    §18.5: "$stored contains verified stores. $satisfied evaluates the placement
    policy over them. $surplus contains verified copies outside the currently
    required policy." §18.4: an `$in: <view>` policy is "verified in every store
    yielded by the view." The policy view `/stores[:s | s.enabled]` yields both
    stores at upload, so a verified copy lands in each ($stored = {a, b},
    $satisfied = true, $surplus = {}). Disabling store `b` shrinks the required
    policy to {a} without moving any bytes: `b` still physically holds a verified
    copy, so $stored stays {a, b}, $satisfied stays true (a is still required and
    present), and the now-unrequired copy in `b` appears in $surplus. This is the
    orphaned/surplus observation §18.5 defines; whether a reconciler later drains
    it is grace-gated (§18.6 step 5) and not asserted here.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.surplus@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores[:s | s.enabled]" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
        set_enabled: [
          "s = .stores[@id] { enabled = @enabled }"
          "return s { id, enabled }"
        ]
      }
      placement: {
        $view: ".docs[@id] { id, stored: .file.$stored { id }, satisfied: .file.$satisfied, surplus: .file.$surplus { id } }"
      }
      $public: {
        docs: {
          $view: ".placement"
          $mut: { add: ".add" }
        }
        stores: { $mut: { set_enabled: ".set_enabled" } }
      }
    }
    $data: {
      stores: {
        a: { connector: "fs-a", enabled: true }
        b: { connector: "fs-b", enabled: true }
      }
    }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "checksum"] }
      "fs-b": { capabilities: ["stream_upload", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "replicated then orphaned"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    // Both enabled stores required and verified: nothing surplus yet.
    { watch: "public.docs", args: { id: "d1" }, on: "c1", id: "w1",
      expect_init: { value: {
        id: "d1"
        stored: { $unordered: [ { id: "a" }, { id: "b" } ] }
        satisfied: true
        surplus: { $unordered: [] }
      } } }
    // Shrink the policy: disable b. No bytes move; b's verified copy is now
    // outside the required policy, hence surplus. a alone still satisfies.
    { call: "public.stores.set_enabled", args: { id: "b", enabled: false }, on: "c1",
      expect: { outcome: ok, value: { id: "b", enabled: false } } }
    { expect_view: { watch: "w1", value: {
        id: "d1"
        stored: { $unordered: [ { id: "a" }, { id: "b" } ] }
        satisfied: true
        surplus: { $unordered: [ { id: "b" } ] }
    } } }
  ]
}

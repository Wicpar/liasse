{
  format: 1
  name: claimed-byte-count-mismatch-rejected
  suite: scenario
  spec: ["#blobs", "§18.2", "§18.7"]
  tags: ["blob", "integrity", "tampering"]
  note: '''
    Attack: declare a small $bytes to slip under a $max_bytes limit or a billing
    threshold, then stream more bytes. §18.2 requires acceptance to confirm the
    "exact byte count"; the streamed length must equal the declared $bytes.
    The stream carries 22 bytes while the descriptor claims 4, so verification
    fails and the call is rejected before admission.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.bytemismatch@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "actual malicious bytes"
        media: "text/plain"
        claim: { $bytes: 4 }
        on: "c1"
      }
      expect: { outcome: rejected, violates: ["#blobs"],
                detail: "streamed byte count does not equal the declared $bytes" } }
  ]
}
</content>

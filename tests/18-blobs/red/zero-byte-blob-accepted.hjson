{
  format: 1
  name: zero-byte-blob-accepted
  suite: scenario
  spec: ["#blobs", "§18.1", "§18.2"]
  tags: ["blob", "boundary", "empty"]
  note: '''
    Empty-value boundary. §18.1: "$bytes is a non-negative integer byte count",
    which admits zero. §18.2: "$max_bytes is an inclusive content-size limit",
    and 0 <= any limit. An empty content stream with $bytes = 0 and the SHA-512
    of the empty byte sequence is a well-formed descriptor of accepted media,
    so the upload commits. Verifies the lower boundary is a valid blob, not an
    error.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.zerobyte@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id, bytes: .file.$bytes }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: ""
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1", bytes: 0 } } }
  ]
}
</content>

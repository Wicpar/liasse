{
  format: 1
  name: descriptor-bytes-encoding-unspecified
  suite: scenario
  spec: ["#blobs", "§18.1"]
  tags: ["blob", "identity", "unspecified"]
  note: '''
    Internal contradiction in §18.1. The worked descriptor encodes the byte
    count as a JSON *string*: "$bytes": "184320". The following prose states
    "$bytes is a non-negative integer byte count." The two disagree on the
    descriptor's on-the-wire value type, which matters for descriptor equality
    and canonical ordering (Annex B.4 includes the complete descriptor). A
    client declaring $bytes as the JSON string "5" for 5 bytes of content is
    valid under the example but ill-typed under the prose; §18.1 does not
    resolve which. Recorded as an ambiguity rather than guessed either way.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.bytesenc@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "hello"
        media: "text/plain"
        // JSON string encoding of the byte count, as in the §18.1 example.
        claim: { $bytes: "5" }
        on: "c1"
      }
      expect: { outcome: unspecified,
                detail: "§18.1 example (string) contradicts §18.1 prose (integer) for $bytes" } }
  ]
}

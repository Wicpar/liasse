{
  format: 1
  name: repeated-store-identity-deduplicated
  suite: scenario
  spec: ["#blobs", "§18.4"]
  tags: ["blob", "placement", "aliasing"]
  note: '''
    Aliasing probe. §18.4: "Placement order is flattened depth-first and
    left-to-right ... Repeated store identities are removed by first
    occurrence." The $all lists store `a` twice around `b`; the flattened,
    deduplicated requirement is exactly {a, b}, not three copies. A correct
    runtime lands verified copies in a and b only (no spurious extra copy),
    and the default $serve fetch order is [a, b] (the repeated a collapsed).
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.dedup@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: { $all: ["/stores['a']", "/stores['b']", "/stores['a']"] } }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id, satisfied: .file.$satisfied, stored: .file.$stored { id }, surplus: .file.$surplus { id } }"
        ]
      }
      one: { $view: ".docs[@id] { id, file }" }
      $public: {
        docs: {
          $view: ".one"
          $mut: { add: ".add" }
        }
      }
    }
    $data: {
      stores: {
        a: { connector: "fs-a" }
        b: { connector: "fs-b" }
      }
    }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "stream_download", "checksum"] }
      "fs-b": { capabilities: ["stream_upload", "stream_download", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "deduped"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: {
        id: "d1"
        satisfied: true
        stored: { $unordered: [ { id: "a" }, { id: "b" } ] }
        surplus: { $unordered: [] }
      } } }
    { blob_get: {
        surface: "public.docs"
        args: { id: "d1" }
        at: ".file"
        on: "c1"
      }
      // Default $serve order is the deduplicated flattened order [a, b].
      expect: { outcome: ok, holders: ["a", "b"], bytes: "deduped" } }
  ]
}

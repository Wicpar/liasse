{
  format: 1
  name: all-holders-corrupt-fetch-outcome-unspecified
  suite: scenario
  spec: ["#blobs", "§18.8", "§18.9"]
  tags: ["blob", "fetch", "integrity", "unspecified"]
  note: '''
    Pinned (SPEC-ISSUES #19). §18.8 now states that a runtime-driven fetch
    attempts each accessible verified holder in $serve order and succeeds iff at
    least one delivers hash-clean content; when none does the fetch fails with an
    `unavailable` outcome, distinct from `denied`, without blocking on
    reconciliation. Here the sole copy is corrupt, so no holder can deliver a
    hash-clean result and the fetch is a no-clean-holder failure (mapped to the
    corpus `error` outcome, §18.9).
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.allcorrupt@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      one: { $view: ".docs[@id] { id, file }" }
      $public: {
        docs: {
          $view: ".one"
          $mut: { add: ".add" }
        }
      }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "stream_download", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "sole copy"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    // Corrupt the only copy; no other verified holder exists to repair from.
    { connector_set: { connector: "fs-a", corrupt: "/stores['primary']" } }
    { blob_get: {
        surface: "public.docs"
        args: { id: "d1" }
        at: ".file"
        on: "c1"
      }
      expect: { outcome: error, violates: ["#blobs", "§18.8", "§18.9"],
                detail: "no accessible verified holder can deliver a hash-clean result; the runtime-driven fetch fails (no-clean-holder)" } }
  ]
}

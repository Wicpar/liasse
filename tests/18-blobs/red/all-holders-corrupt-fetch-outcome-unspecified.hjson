{
  format: 1
  name: all-holders-corrupt-fetch-outcome-unspecified
  suite: scenario
  spec: ["#blobs", "§18.8", "§18.9"]
  tags: ["blob", "fetch", "integrity", "unspecified"]
  note: '''
    §18.9: at fetch, hash verification occurs "before delivering a successful
    result", and §18.8: "A successful fetch returns exactly the bytes
    identified by $sha512." When the only holder's object is corrupt there is
    no verified holder to serve (the §18.8 plan "contains accessible verified
    holders", here none), so the runtime MUST NOT deliver wrong bytes. What it
    returns instead is not pinned: §18 names no error/denied/unavailable
    outcome for a fetch with zero deliverable verified holders, nor whether the
    fetch blocks pending repair. Recorded as an ambiguity: only the negative
    guarantee (no successful delivery of non-matching bytes) is normative.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.allcorrupt@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      one: { $view: ".docs[@id] { id, file }" }
      $public: {
        docs: {
          $view: ".one"
          $mut: { add: ".add" }
        }
      }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "stream_download", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "sole copy"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    // Corrupt the only copy; no other verified holder exists to repair from.
    { connector_set: { connector: "fs-a", corrupt: "/stores['primary']" } }
    { blob_get: {
        surface: "public.docs"
        args: { id: "d1" }
        at: ".file"
        on: "c1"
      }
      expect: { outcome: unspecified, violates: ["#blobs"],
                detail: "no verified holder can deliver a hash-clean result; §18 pins no failure outcome" } }
  ]
}
</content>

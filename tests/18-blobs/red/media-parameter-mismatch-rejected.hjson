{
  format: 1
  name: media-parameter-mismatch-rejected
  suite: scenario
  spec: ["#blobs", "§18.2"]
  tags: ["blob", "canonicalization"]
  note: '''
    §18.2: "parameters ... compared exactly when the declaration includes
    them." When the declaration carries a parameter, an upload whose same
    type/subtype has a *different* parameter value is not accepted. The field
    accepts text/plain; charset=utf-8; the upload declares
    text/plain; charset=us-ascii, which differs in the parameter value.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.parammismatch@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain; charset=utf-8"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "ascii body"
        media: "text/plain; charset=us-ascii"
        on: "c1"
      }
      expect: { outcome: rejected, violates: ["#blobs"],
                detail: "declared media parameter differs from the required parameter" } }
  ]
}
</content>

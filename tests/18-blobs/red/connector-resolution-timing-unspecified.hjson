{
  format: 1
  name: connector-resolution-timing-unspecified
  suite: scenario
  spec: ["#blobs", "§18.3", "§18.12", "§2.1"]
  tags: ["blob", "loading", "unspecified"]
  note: '''
    Genuine ambiguity in WHEN a connector named by *runtime* store data is
    validated. §18.3: a store row carries the connector as an ordinary `text`
    field and store rows "MAY be scoped to companies, users, or modules like
    ordinary data" — which reads as: inserting a store row is a plain data
    write, so a row naming an unregistered connector "ghost" is accepted
    (`ok`). §18.12/§2.1, by contrast, tie connector validation to load
    ("Loading validates connector capabilities required by declared placement";
    "a package requiring an unavailable ... component fails validation before
    activation"), and this store row IS routed to by a declared placement
    (`$in: /stores['dynamic']`); a runtime MAY therefore extend that check to
    the store-row write and reject the insert eagerly. §18 pins neither: it
    names load-time validation but never says a store-row write that feeds a
    declared placement must, or must not, revalidate its connector. So the
    observable outcome of the INSERT is unspecified. (The downstream safety
    floor — that no blob can land in a store whose connector is unregistered —
    is covered deterministically by red/no-writable-store-rejects-upload; the
    seeded/genesis form is covered by common/unregistered-connector-fails-load.
    Only the runtime-write timing is open here.)
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.dyncon@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['dynamic']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add_store: [
          "s = .stores + { id: @id, connector: @connector }"
          "return s { id }"
        ]
      }
      $public: {
        stores: { $mut: { add: ".add_store" } }
      }
    }
    // No stores seeded; at load the placement view `/stores['dynamic']` yields
    // nothing, so load-time connector validation (§18.12) has nothing to bind.
    $data: {}
  }

  hosts: {
    // Only fs-a exists; the store row inserted below names "ghost".
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    // Insert a store row whose connector "ghost" is unregistered and to which a
    // declared placement routes. Ordinary-data reading -> ok; eager
    // connector-validation reading -> rejected. §18 pins neither.
    { call: "public.stores.add", args: { id: "dynamic", connector: "ghost" }, on: "c1",
      expect: { outcome: unspecified,
                detail: "§18 pins load-time connector validation but not whether a runtime store-row write feeding a declared placement revalidates its connector" } }
  ]
}

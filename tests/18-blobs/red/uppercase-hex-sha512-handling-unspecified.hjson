{
  format: 1
  name: uppercase-hex-sha512-handling-unspecified
  suite: scenario
  spec: ["#blobs", "§18.1"]
  tags: ["blob", "canonicalization", "identity", "unspecified"]
  note: '''
    §18.1 fixes the canonical descriptor encoding: "$sha512 is 64 SHA-512 bytes
    encoded as lowercase hexadecimal." A client here declares the CORRECT digest
    of the streamed bytes but spells it in UPPER-CASE hex, so there is no content
    mismatch — the claimed hex decodes to exactly the streamed content's digest;
    only its case is non-canonical. §18.1 states the canonical form but pins no
    handling for non-canonical client input: a runtime MAY reject it as a
    malformed descriptor value (strict reading of "lowercase"), or MAY case-fold
    the hex to canonical form and accept, since uppercase hex is a lossless
    re-encoding of the same 64 bytes and §18 grants no descriptor normalization
    step that would force one choice. (Contrast negative $bytes, which is not a
    byte count under any reading; there uppercase hex still denotes a valid
    digest.) Recorded as an ambiguity rather than asserting an unmandated
    rejection.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.hexcase@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "hello"
        media: "text/plain"
        // Correct SHA-512 of "hello", but spelled in uppercase hexadecimal.
        claim: { $sha512: "9B71D224BD62F3785D96D46AD3EA3D73319BFBC2890CAADAE2DFF72519673CA72323C3D99BA5C11D7C7ACC6E14B8C5DA0C4663475C2E5C3ADEF46F73BCDEC043" }
        on: "c1"
      }
      expect: { outcome: unspecified,
                detail: "§18.1 pins the lowercase-hex canonical form but not whether non-canonical (uppercase) client $sha512 is rejected or normalized" } }
  ]
}

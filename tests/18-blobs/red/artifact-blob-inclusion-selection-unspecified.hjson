{
  format: 1
  name: artifact-blob-inclusion-selection-unspecified
  suite: scenario
  spec: ["#blobs", "§18.10", "#history", "§19.7"]
  tags: ["blob", "artifact", "unspecified"]
  note: '''
    Boundary ambiguity between §18 and §19. §2.4 says a .liasse artifact
    contains "blobs selected for inclusion"; §19.7 lists "selected owned blob
    contents"; §19.5 places owned blob bytes under blobs/. But no normative rule
    defines the SELECTION criterion — which owned blobs' bytes are included
    versus referenced by descriptor only. §18.10 compounds this: "History MAY
    retain a descriptor after physical bytes are released", so an artifact MAY
    legitimately carry a descriptor with no bytes. Whether the blobs/ entry for
    a live, committed blob is present in a default export is therefore not
    pinned. This case exports an application holding one committed blob and
    records that the presence of its bytes under blobs/ is unspecified.
    (Reuses §19 export/inspect_artifact steps; see NOTES.md.)
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.artifactincl@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "stream_download", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "owned blob bytes"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    { export: { as: "a1" } }
    // Whether the blob's bytes appear under blobs/ is not pinned by §18/§19.
    { inspect_artifact: { artifact: "a1", expect: {
        outcome: unspecified
        violates: ["#blobs", "#history"]
        detail: "no normative rule defines which owned blob bytes a default export includes under blobs/"
    } } }
  ]
}
</content>

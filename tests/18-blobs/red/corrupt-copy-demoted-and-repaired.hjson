{
  format: 1
  name: corrupt-copy-demoted-and-repaired
  suite: scenario
  spec: ["#blobs", "§18.6", "§18.9", "§18.5"]
  tags: ["blob", "integrity", "reconciliation"]
  note: '''
    §18.6: "A corrupt observation demotes that copy and triggers repair from
    another verified holder. The descriptor continues to identify the intended
    content." §18.9 verifies copies before a destination becomes verified. Two
    verified copies exist (a, b); the object in `a` is tampered and observed
    corrupt; the reconciler demotes `a`, repairs it from the verified holder
    `b`, and `a` returns to verified. The descriptor is unchanged and a fetch
    still returns the exact original bytes.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.repair@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: { $all: ["/stores['a']", "/stores['b']"] } }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["text/plain"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      placement: {
        $view: ".docs[@id] { id, stored: .file.$stored { id }, satisfied: .file.$satisfied }"
      }
      one: { $view: ".docs[@id] { id, file }" }
      $public: {
        state: { $view: ".placement" }
        docs: {
          $view: ".one"
          $mut: { add: ".add" }
        }
      }
    }
    $data: {
      stores: {
        a: { connector: "fs-a" }
        b: { connector: "fs-b" }
      }
    }
  }

  hosts: {
    connectors: {
      "fs-a": { capabilities: ["stream_upload", "stream_download", "server_side_copy", "checksum"] }
      "fs-b": { capabilities: ["stream_upload", "stream_download", "server_side_copy", "checksum"] }
    }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "durable original"
        media: "text/plain"
        on: "c1"
      }
      expect: { outcome: ok, value: { id: "d1" } } }
    // Tamper with the physical object in store `a`.
    { connector_set: { connector: "fs-a", corrupt: "/stores['a']" } }
    { run_reconciler: {}, expect: { outcome: ok } }
    // `a` was demoted then repaired from `b`; both verified again.
    { watch: "public.state", args: { id: "d1" }, on: "c1", id: "w1",
      expect_init: { value: {
        id: "d1"
        stored: { $unordered: [ { id: "a" }, { id: "b" } ] }
        satisfied: true
      } } }
    // Descriptor unchanged; bytes still exact.
    { blob_get: {
        surface: "public.docs"
        args: { id: "d1" }
        at: ".file"
        on: "c1"
      }
      expect: { outcome: ok, bytes: "durable original" } }
  ]
}
</content>

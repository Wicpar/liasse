{
  format: 1
  name: confusable-media-type-not-accepted
  suite: scenario
  spec: ["#blobs", "§18.2"]
  tags: ["blob", "unicode", "identity"]
  note: '''
    Attack: bypass the accepted-media set with a homoglyph. The declared media
    "application/pdf" uses a Cyrillic small letter a (U+0430) in place of the
    ASCII a in "application". §18.2 compares type/subtype "case-insensitively
    after canonical lowercasing"; canonical lowercasing is an ASCII case fold
    over media-type tokens and does not fold a non-ASCII homoglyph onto ASCII
    "a". The confusable string is therefore a different, unaccepted media type
    and the upload is rejected.
  '''

  package: {
    $liasse: 1
    $app: "t.blobs.confusablemedia@1.0.0"
    $model: {
      stores: {
        $key: "id"
        id: "text"
        connector: "text"
        enabled: "bool = true"
      }
      docs: {
        $key: "id"
        $blob_storage: { $in: "/stores['primary']" }
        id: "text"
        file: {
          $type: "blob"
          $max_bytes: "10485760"
          $media: ["application/pdf"]
        }
      }
      $mut: {
        add: [
          "doc = .docs + { id: @id, file: @file }"
          "return doc { id }"
        ]
      }
      $public: { docs: { $mut: { add: ".add" } } }
    }
    $data: { stores: { primary: { connector: "fs-a" } } }
  }

  hosts: {
    connectors: { "fs-a": { capabilities: ["stream_upload", "checksum"] } }
  }

  steps: [
    { connect: "c1" }
    { blob_put: {
        call: "public.docs.add"
        param: "file"
        args: { id: "d1" }
        content: "%PDF payload"
        // "applicаtion/pdf": Cyrillic a (U+0430), not ASCII a.
        media: "applicаtion/pdf"
        on: "c1"
      }
      expect: { outcome: rejected, violates: ["#blobs"],
                detail: "homoglyph media type is not the accepted application/pdf" } }
  ]
}
</content>

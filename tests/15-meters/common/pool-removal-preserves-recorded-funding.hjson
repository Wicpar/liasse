{
  format: 1
  name: pool-removal-preserves-recorded-funding
  suite: scenario
  spec: ["#meters", "§15.2", "§15.3", "§15.6"]
  note: '''Changing or removing a pool never rewrites an earlier funding allocation, and
earlier funding remains attached to its spend even when the source row later disappears
(SPEC §15.2/§15.3). The recorded funding value is bound at admission and compared
byte-for-byte after the pool row is deleted; removal reduces future availability to
zero but cannot revoke the admitted spend.'''

  package: {
    $liasse: 1
    $app: "t.meters.poolremove@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      users: {
        $key: "id"
        id: "text"
        topups: {
          $key: "id"
          id: "text"
          amount: "decimal"
        }
        spends: {
          $key: "id"
          $consumes: "credits"
          id: "uuid = uuid()"
          amount: "decimal"
          occurred_at: "timestamp = now()"
        }
        $limits: {
          credits: {
            $sources: { topup: ".topups { $quantity: .amount }" }
          }
        }
        $mut: {
          consume: [
            "spend = .spends + { amount: @amount }"
            "return spend { id, funding }"
          ]
          remove_topup: ".topups - @topup"
        }
      }
      $public: {
        wallet: {
          $mut: {
            consume: ".users[@user].consume"
            remove_topup: ".users[@user].remove_topup"
          }
        }
        audit: {
          $view: ".users { id, spends: .spends { id, funding } }"
        }
      }
    }
    $data: { users: { u1: { topups: { t1: { amount: "100" } } } } }
  }

  steps: [
    { call: "public.wallet.consume", args: { user: "u1", amount: "60" },
      expect: { outcome: ok, value: { id: "$bind:s1", funding: "$bind:f1" } } }
    // removing the pool is admitted; it cannot revoke the earlier spend
    { call: "public.wallet.remove_topup", args: { user: "u1", topup: "t1" },
      expect: { outcome: ok } }
    // the recorded allocation is unchanged after the source row disappeared
    { watch: "public.audit", id: "w1",
      expect_init: { value: [ { id: "u1", spends: [ { id: "$ref:s1", funding: "$ref:f1" } ] } ] } }
    // future availability is zero
    { call: "public.wallet.consume", args: { user: "u1", amount: "1" },
      expect: { outcome: rejected, violates: ["#meters", "§15.2"] } }
  ]
}

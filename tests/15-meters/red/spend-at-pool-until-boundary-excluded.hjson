{
  format: 1
  name: spend-at-pool-until-boundary-excluded
  suite: scenario
  spec: ["#meters", "§15.1", "§15.2", "#buckets", "§14.1"]
  tags: [temporal, boundary]
  note: '''Half-open interval pedantry: bucket intervals are [$from, $until) and at the
upper bound the row is no longer active (§14.1). A spend timed exactly at $until must
find the pool inactive; one second earlier it must be funded. Timestamps at seconds
precision: $until = 2026-01-08T00:00:00Z = 1767830400.'''

  package: {
    $liasse: 1
    $app: "t.meters.halfopen@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      users: {
        $key: "id"
        id: "text"
        topups: {
          $key: "id"
          $bucket: { $until: ".expires_at" }
          id: "text"
          amount: "decimal"
          expires_at: "timestamp? = none"
        }
        spends: {
          $key: "id"
          $consumes: "credits"
          id: "uuid = uuid()"
          amount: "decimal"
          occurred_at: "timestamp = now()"
        }
        $limits: {
          credits: {
            $sources: { topup: ".topups { $quantity: .amount }" }
            $order: ["$until"]
          }
        }
        $mut: {
          consume_at: [
            "spend = .spends + { amount: @amount, occurred_at: @at }"
            "return spend { id }"
          ]
        }
      }
      $public: {
        wallet: {
          $mut: { consume_at: ".users[@user].consume_at" }
        }
      }
    }
    $data: {
      users: {
        u1: { topups: { t1: { amount: "100", expires_at: "1767830400" } } }
      }
    }
  }

  steps: [
    // exactly at $until: the pool is no longer active at that instant
    { call: "public.wallet.consume_at", args: { user: "u1", amount: "10", at: "1767830400" },
      expect: { outcome: rejected, violates: ["#buckets", "§14.1", "#meters", "§15.1", "§15.2"],
                detail: "the interval is half-open; the pool is inactive at $until, so eligible capacity is zero" } }
    // one second before $until: funded
    { call: "public.wallet.consume_at", args: { user: "u1", amount: "10", at: "1767830399" },
      expect: { outcome: ok, value: { id: "$any:uuid" } } }
  ]
}

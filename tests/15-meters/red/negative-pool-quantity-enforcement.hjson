{
  format: 1
  name: negative-pool-quantity-enforcement
  suite: scenario
  spec: ["#meters", "§15.1"]
  note: '''SPEC §15.1 pins pool $quantity MUST be non-negative and (as of the eager-
enforcement decision) enforces it at the transition that would establish the offending
value, never lazily at a later meter read. A topup whose projected pool $quantity
(`.topups { $quantity: .amount }`) is negative is therefore rejected at admission of the
insert — committed state never contains a negative projected pool. The control positive
topup is an ordinary insert; the -100 topup is rejected at the insert, not admitted to
poison later allocation arithmetic.'''

  package: {
    $liasse: 1
    $app: "t.meters.negpool@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      users: {
        $key: "id"
        id: "text"
        topups: {
          $key: "id"
          id: "text"
          amount: "decimal"
        }
        spends: {
          $key: "id"
          $consumes: "credits"
          id: "uuid = uuid()"
          amount: "decimal"
          occurred_at: "timestamp = now()"
        }
        $limits: {
          credits: {
            $sources: { topup: ".topups { $quantity: .amount }" }
          }
        }
        $mut: {
          consume: [
            "spend = .spends + { amount: @amount }"
            "return spend { id }"
          ]
          add_topup: ".topups + { id: @topup, amount: @amount }"
        }
      }
      $public: {
        wallet: {
          $mut: {
            consume: ".users[@user].consume"
            add_topup: ".users[@user].add_topup"
          }
        }
      }
    }
    $data: { users: { u1: {} } }
  }

  steps: [
    // control: a positive topup is an ordinary insert
    { call: "public.wallet.add_topup", args: { user: "u1", topup: "t1", amount: "50" },
      expect: { outcome: ok } }
    // the pool quantity projected from this row would be negative: rejected eagerly
    // at admission of the insert (§15.1), never admitted to surface later at a read
    { call: "public.wallet.add_topup", args: { user: "u1", topup: "t2", amount: "-100" },
      expect: { outcome: rejected, violates: ["#meters", "§15.1"] } }
  ]
}

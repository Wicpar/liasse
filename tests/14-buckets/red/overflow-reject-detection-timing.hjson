{
  format: 1
  name: overflow-reject-detection-timing
  suite: scenario
  spec: ["#buckets", "§14.5", "§14.7", "§A.4"]
  tags: ["calendar", "recurrence", "boundary"]
  note: "A.4 defines overflow: reject — when a generated boundary lands on a calendar date missing from the destination month, that policy rejects rather than clamps. Here a monthly series anchored on Jan 31 with a finite series bound (Mar 31) must produce b1 = Feb 31, which does not exist. Per the eager-enforcement decision (§14.5, §14.7), an overflow: reject boundary within an enumerable series is validated eagerly at the source transition: the subscription insert that establishes the series is rejected at admission, never deferred to a later temporal read. Committed state therefore never holds a finite source-backed series that would, on enumeration, hit an overflow: reject boundary."

  package: {
    $liasse: 1
    $app: "t.b14.overflowreject@1.0.0"
    $model: {
      plans: {
        $key: "id"
        id: "text"
        credits: "decimal"
        period: "period?"
      }
      subscriptions: {
        $key: "id"
        id: "text"
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp?"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
      }
      $public: {
        subs: {
          $mut: {
            add: [
              "s = .subscriptions + { id: @id, plan: @plan, starts_at: @starts_at, ends_at: @ends_at }"
              "return s { id }"
            ]
          }
        }
      }
    }
    $data: {
      plans: {
        // months:1, reject when the destination day is missing
        strict_monthly: { credits: "100", period: { months: 1, zone: "UTC", overflow: "reject" } }
      }
    }
  }

  steps: [
    // finite series [Jan 31, Mar 31); computing it requires b1 = Feb 31 (missing).
    // The overflow: reject boundary within this enumerable series is validated
    // eagerly at the source transition, so the insert is rejected at admission
    // (§14.5, §14.7) rather than admitted to fault only at a later temporal read.
    { call: "public.subs.add"
      args: { id: "s1", plan: "strict_monthly", starts_at: "1769817600000000", ends_at: "1774915200000000" }
      expect: { outcome: rejected, violates: ["#buckets", "§14.7"] } }
  ]
}

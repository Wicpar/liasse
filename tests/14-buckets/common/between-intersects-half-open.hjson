{
  format: 1
  name: between-intersects-half-open
  suite: scenario
  spec: ["#buckets", "§14.1"]
  tags: ["boundary", "temporal"]
  note: ".$between(a, b) selects rows whose half-open intervals intersect the half-open range [a, b). A range starting exactly at a row's $until, or ending exactly at its $from, does not intersect it."

  package: {
    $liasse: 1
    $app: "t.b14.intersect@1.0.0"
    $model: {
      reservations: {
        $key: "id"
        $bucket: { $from: ".starts_at", $until: ".ends_at" }
        id: "text"
        starts_at: "timestamp"
        ends_at: "timestamp"
      }
      $data: {
        reservations: {
          // interval [2026-01-01T01:00Z, 2026-01-01T02:00Z)
          r1: { starts_at: "1767229200000000", ends_at: "1767232800000000" }
        }
      }
      $public: {
        q: {
          $mut: {
            between: "return .reservations.$between(@a, @b) { id }"
          }
        }
      }
    }
  }

  steps: [
    // query [02:00, 03:00) starts exactly at the row's $until: no intersection
    { call: "public.q.between"
      args: { a: "1767232800000000", b: "1767236400000000" }
      expect: { outcome: ok, value: [] } }

    // query [00:00, 01:00) ends exactly at the row's $from: no intersection
    { call: "public.q.between"
      args: { a: "1767225600000000", b: "1767229200000000" }
      expect: { outcome: ok, value: [] } }

    // query [00:00, 01:00:00.000001) includes the row's first active instant
    { call: "public.q.between"
      args: { a: "1767225600000000", b: "1767229200000001" }
      expect: { outcome: ok, value: [ { id: "r1" } ] } }

    // query [01:30, 05:00) overlaps the interval interior
    { call: "public.q.between"
      args: { a: "1767231000000000", b: "1767243600000000" }
      expect: { outcome: ok, value: [ { id: "r1" } ] } }
  ]
}

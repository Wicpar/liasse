{
  format: 1
  name: recurring-consecutive-periods
  suite: scenario
  spec: ["#buckets", "§14.5"]
  tags: ["temporal", "recurrence"]
  note: "With $repeat, boundary bi comes from adding the period to the prior boundary; row i has $index=i, $from=bi, $until=min(bi+1, series-until). A series bound landing exactly on a boundary produces no zero-width trailing interval (a clipped interval is included only when its start is below its end)."

  package: {
    $liasse: 1
    $app: "t.b14.recurring@1.0.0"
    $model: {
      plans: {
        $key: "id"
        id: "text"
        credits: "decimal"
        period: "period?"
      }
      subscriptions: {
        $key: "id"
        id: "text"
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp?"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
      }
      $public: {
        periods: {
          $params: { a: "timestamp", b: "timestamp" }
          $view: '.credit_periods.$between(@a, @b) { index: $index, from: $from, until: $until, $sort: ["from"] }'
        }
      }
    }
    $data: {
      plans: {
        weekly: { credits: "30", period: "P7D" }
      }
      subscriptions: {
        // series [2026-01-01T00:00Z, 2026-01-22T00:00Z): exactly three weeks
        s1: { plan: "weekly", starts_at: "1767225600000000", ends_at: "1769040000000000" }
      }
    }
  }

  steps: [
    // window [2026-01-01, 2026-02-01): all generated periods
    { watch: "public.periods"
      args: { a: "1767225600000000", b: "1769904000000000" }
      id: "w1"
      expect_init: {
        value: [
          { index: "0", from: "1767225600000000", until: "1767830400000000" }  // Jan 1  - Jan 8
          { index: "1", from: "1767830400000000", until: "1768435200000000" }  // Jan 8  - Jan 15
          { index: "2", from: "1768435200000000", until: "1769040000000000" }  // Jan 15 - Jan 22
          // no fourth row: [Jan 22, Jan 22) would be zero-width
        ]
      } }
  ]
}

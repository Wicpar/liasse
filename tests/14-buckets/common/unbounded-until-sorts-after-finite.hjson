{
  format: 1
  name: unbounded-until-sorts-after-finite
  suite: scenario
  spec: ["#buckets", "§14.3", "#views", "§7.3", "#annex-b"]
  tags: ["ordering"]
  note: "The ordinary total order of optional values places none after present values ascending and before them descending: sorting bucket rows by $until puts the earliest finite end first and the unbounded row last (ascending), and the unbounded row first (descending)."

  package: {
    $liasse: 1
    $app: "t.b14.nonesort@1.0.0"
    $model: {
      subscriptions: {
        $key: "id"
        id: "text"
        starts_at: "timestamp"
        ends_at: "timestamp?"
      }
      access_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
        }
        id: "= $source.id"
      }
      $public: {
        asc: { $view: '.access_periods.$all { id, until: $until, $sort: ["until"] }' }
        desc: { $view: '.access_periods.$all { id, until: $until, $sort: ["-until"] }' }
      }
    }
    $data: {
      subscriptions: {
        a: { starts_at: "1767225600000000", ends_at: "1767232800000000" }  // ends +2h
        b: { starts_at: "1767225600000000", ends_at: "1767229200000000" }  // ends +1h
        c: { starts_at: "1767225600000000" }                               // unbounded
      }
    }
  }

  steps: [
    // ascending: earliest finite end ... latest finite end, unbounded
    { watch: "public.asc", id: "w1"
      expect_init: {
        value: [
          { id: "b", until: "1767229200000000" }
          { id: "a", until: "1767232800000000" }
          { id: "c" }                             // until omitted: none sorts last
        ]
      } }

    // descending: unbounded, latest finite end ... earliest finite end
    { watch: "public.desc", id: "w2"
      expect_init: {
        value: [
          { id: "c" }
          { id: "a", until: "1767232800000000" }
          { id: "b", until: "1767229200000000" }
        ]
      } }
  ]
}

{
  format: 1
  name: ref-wire-value-is-current-typed-key
  suite: scenario
  spec: ["§D.1", "§5.4", "§6.4"]
  tags: ["identity"]
  note: '''§D.1: "A ref's visible wire value is the target's current typed key. Its
durable relationship binds the declared target relation and target incarnation."
So a projected ref shows whatever key the target currently has: at first the
original key, and after an atomic rekey of the target (§5.4 preserves the target
incarnation) the SAME ref shows the new key without the relationship breaking.
The wire value tracks the current key; the underlying binding tracks the
incarnation.'''

  package: {
    $liasse: 1
    $app: "t.refwire@1.0.0"
    $model: {
      users: {
        $key: "id"
        id: "text"
        name: "text"
      }
      posts: {
        $key: "id"
        id: "text"
        author: { $ref: "/users" }
      }
      $public: {
        posts: {
          $view: ".posts[:p] { id: p.id, author: p.author, author_name: p.author.name, $sort: [id] }"
          $mut: {
            add_user: ".users + { id: @id, name: @name }"
            add_post: ".posts + { id: @id, author: .users[@author] }"
            rekey_user: ".users[@old].id = @new"
          }
        }
      }
    }
  }

  steps: [
    { call: "public.posts.add_user", args: { id: "alice", name: "Alice" },
      expect: { outcome: ok } }
    { call: "public.posts.add_post", args: { id: "p1", author: "alice" },
      expect: { outcome: ok } }
    // wire value is the target's current typed key
    { watch: "public.posts", id: "w1", expect_init: { value: [
      { id: "p1", author: "alice", author_name: "Alice" }
    ] } }
    // atomic rekey: the relationship (incarnation) is preserved, the visible
    // wire value now shows the new key
    { call: "public.posts.rekey_user", args: { old: "alice", new: "alice2" },
      expect: { outcome: ok } }
    { expect_view: { watch: "w1", value: [
      { id: "p1", author: "alice2", author_name: "Alice" }
    ] } }
  ]
}

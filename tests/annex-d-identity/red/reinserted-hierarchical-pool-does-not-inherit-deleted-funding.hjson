{
  format: 1
  name: reinserted-hierarchical-pool-does-not-inherit-deleted-funding
  suite: scenario
  spec: ["#identity", "§D.1", "#meters", "§15.4", "§15.2", "§15.3"]
  note: '''Annex D.1: meter-pool coordinates "include incarnation identity wherever key reuse
could otherwise conflate occurrences." The W9-2 fix bound that incarnation for TOP-LEVEL
meter pools, but a §15.4 HIERARCHICAL meter enforces over a NESTED ancestor row and its
nested pool rows were still matched key-only, so the same delete/reinsert conflation
persisted one level down. Here `credits` is declared at BOTH the company row and the nested
account row. Spend 40 at account a1: account pool at1(100) funds 40 → account balance 60;
company pool ct(1000) funds 40 → company balance 960. Delete at1 (account funding stays
frozen against incarnation A, §15.2 → account balance 0). Reinsert at1=100 as a fresh
incarnation B (§5.6/§21.3, Annex D.1): the deleted A's 40 must NOT bind to B, so account
balance is the full 100 (not 60), and a fresh 100-spend admits — drawing another 100 off
the company (960 → 860). Company-level funding is unaffected (ct untouched) throughout.'''

  package: {
    $liasse: 1
    $app: "t.identity.hierpoolreinsert@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      companies: {
        $key: "id"
        id: "text"
        topups: { $key: "id", id: "text", amount: "decimal" }
        $limits: { credits: { $sources: { topup: ".topups { $quantity: .amount }" } } }
        accounts: {
          $key: "id"
          id: "text"
          topups: { $key: "id", id: "text", amount: "decimal" }
          $limits: { credits: { $sources: { topup: ".topups { $quantity: .amount }" } } }
          spends: {
            $key: "id"
            $consumes: "credits"
            id: "uuid = uuid()"
            amount: "decimal"
            occurred_at: "timestamp = now()"
          }
          $mut: {
            consume: [
              "spend = .spends + { amount: @amount }"
              "return spend { id }"
            ]
            add_topup: ".topups + { id: @id, amount: @amount }"
            remove_topup: ".topups - @topup"
          }
        }
      }
      $public: {
        wallet: {
          $view: '''.companies {
            id,
            balance: .credits.balance,
            accounts: .accounts { id, balance: .credits.balance }
          }'''
          $mut: {
            consume: ".companies[@company].accounts[@account].consume"
            add_topup: ".companies[@company].accounts[@account].add_topup"
            remove_topup: ".companies[@company].accounts[@account].remove_topup"
          }
        }
      }
    }
    $data: {
      companies: {
        co: {
          topups: { ct: { amount: "1000" } }
          accounts: { a1: { topups: { at1: { amount: "100" } } } }
        }
      }
    }
  }

  steps: [
    // spend 40 at account a1 (incarnation A): account 60, company 960
    { call: "public.wallet.consume", args: { company: "co", account: "a1", amount: "40" },
      expect: { outcome: ok, value: { id: "$bind:s1" } } }
    { watch: "public.wallet", id: "w1", expect_init: { value: [
      { id: "co", balance: "960", accounts: [ { id: "a1", balance: "60" } ] } ] } }
    // delete at1: the account spend's 40 stays frozen against incarnation A; account 0
    { call: "public.wallet.remove_topup", args: { company: "co", account: "a1", topup: "at1" },
      expect: { outcome: ok } }
    { expect_view: { watch: "w1", value: [
      { id: "co", balance: "960", accounts: [ { id: "a1", balance: "0" } ] } ] } }
    // reinsert at1=100: a NEW incarnation B (§5.6/§21.3, Annex D.1)
    { call: "public.wallet.add_topup", args: { company: "co", account: "a1", id: "at1", amount: "100" },
      expect: { outcome: ok } }
    // the deleted incarnation A's 40 does NOT bind to incarnation B — full 100
    { expect_view: { watch: "w1", value: [
      { id: "co", balance: "960", accounts: [ { id: "a1", balance: "100" } ] } ] } }
    // a fresh 100-spend admits against incarnation B's full account capacity; the
    // company draws another 100 (960 → 860)
    { call: "public.wallet.consume", args: { company: "co", account: "a1", amount: "100" },
      expect: { outcome: ok, value: { id: "$any:uuid" } } }
    { expect_view: { watch: "w1", value: [
      { id: "co", balance: "860", accounts: [ { id: "a1", balance: "0" } ] } ] } }
  ]
}

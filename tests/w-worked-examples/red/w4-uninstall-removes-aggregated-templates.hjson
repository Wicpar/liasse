{
  format: 1
  name: w4-uninstall-removes-aggregated-templates
  suite: scenario
  spec: ["W4", "#modules", "§13.3", "§13.12"]
  tags: [modules]
  note: '''
    Lifecycle: an exposed template must disappear from the parent aggregation
    when its instance is removed. §13.3: uninstall "removes the instance through
    the ordinary cross-module deletion plan"; §13.12: uninstall "deletes the
    instance incarnation and owned subtree ... admitted atomically after the full
    deletion ripple." After install the parent's available_templates shows the
    template; after uninstall the .modules::templates aggregation has no
    contributing instance and is empty.
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.company.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          plan: "text"
          modules: {
            $modules: {
              $expose: { company: { $view: ". { id, name, plan }" } }
              $interfaces: {
                templates: { $view: { $key: "id", id: "text", label: "text", journal: "text", lines: "json" } }
              }
            }
          }
          available_templates: {
            $view: ".modules::templates { module: modules.$key, template: templates.$key, id, label, $sort: [module, template] }"
          }
        }
        $public: {
          companies: { $params: { company: "text" }, $view: "/companies[@company].available_templates" }
        }
      }
      $data: { companies: { acme: { name: "Acme", plan: "fr-pcg" } } }
    }

    frsales: {
      $liasse: 1
      $module: "acme.fr_sales_templates@1.0.0"
      $use: { company: "$parent" }
      $model: {
        templates: { $key: "id", id: "text", label: "text", journal: "text", enabled: "bool = true", lines: "json" }
      }
      $data: {
        templates: {
          sale_invoice: {
            label: "Facture de vente", journal: "VE"
            enabled: "= #company.plan == 'fr-pcg'"
            lines: [ { account: "411", side: "debit", amount: "'= total_ttc" } ]
          }
        }
      }
      $expose: { templates: { $view: ".templates[:t | t.enabled] { id, label, journal, lines }" } }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules"
        request: { $name: "fr_sales", $module: "acme.fr_sales_templates@1.0.0" } }
      expect: { outcome: ok } }
    { watch: "public.companies", args: { company: "acme" }, id: "w1"
      expect_init: { value: [ { module: "fr_sales", template: "sale_invoice", id: "sale_invoice", label: "Facture de vente" } ] } }
    { module_uninstall: { instance: "/companies/acme/modules/fr_sales" }, expect: { outcome: ok } }
    { expect_view: { watch: "w1", value: [] } }
  ]
}

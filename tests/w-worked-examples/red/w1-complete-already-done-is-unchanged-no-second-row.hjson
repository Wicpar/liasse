{
  format: 1
  name: w1-complete-already-done-is-unchanged-no-second-row
  suite: scenario
  spec: ["#mutations", "W1", "§8.9"]
  tags: [idempotency, replay]
  note: '''
    Pedantic double-submit. A client (or a retrying network layer) fires
    public.tasks.complete twice for the same task. The second run of
    ".done = true; return ..." changes no state (done is already true). §8.9:
    "When the complete program produces no state change, the call returns
    unchanged and creates no commit ... that response is still evaluated against
    the unchanged state." So the second call must NOT reject and must NOT create
    a new commit/row: it succeeds, re-returning done=true. Asserted as outcome ok
    per this chapter's convention (unchanged is a success status, §12.3); the
    load-bearing claim is that the repeat neither errors nor duplicates state —
    the tasks collection still holds exactly one row.
  '''

  package: {
    $liasse: 1
    $app: "example.tasks@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        title: {
          $type: "text"
          $normalize: "string.trim(.)"
          $check: ["size(.) > 0", "A title is required"]
        }
        done: "bool = false"
        created_at: "timestamp = now()"
        $mut: {
          complete: [
            ".done = true"
            "return . { id, title, done, created_at }"
          ]
        }
      }
      $mut: {
        add_task: [
          "task = .tasks + { title: @title }"
          "return task { id, title, done, created_at }"
        ]
      }
      all_tasks: {
        $view: ".tasks { id, done, $sort: [created_at] }"
      }
      open_tasks: {
        $view: ".tasks[:task | !task.done] { id, title, created_at, $sort: [-created_at] }"
      }
      $public: {
        tasks: {
          $view: ".open_tasks"
          $mut: {
            add: ".add_task"
            complete: ".tasks[@id].complete()"
          }
        }
        audit: { $view: ".all_tasks" }
      }
    }
  }

  steps: [
    { call: "public.tasks.add", args: { title: "once" }, expect: { outcome: ok, value: { id: "$bind:t", "...": true } } }
    { call: "public.tasks.complete", args: { id: "$ref:t" }, expect: { outcome: ok, value: { done: true, "...": true } } }
    // repeat: no state change -> must not reject, must not duplicate
    { call: "public.tasks.complete", args: { id: "$ref:t" }, expect: { outcome: ok, value: { id: "$ref:t", done: true, "...": true } } }
    { watch: "public.audit", id: "w1", expect_init: { value: [ { id: "$ref:t", done: true } ] } }
  ]
}

{
  format: 1
  name: w4-confusable-instance-names-both-install-distinct
  suite: scenario
  spec: ["W4", "#modules", "§13.3", "§13.9"]
  tags: [modules, unicode, identity]
  note: '''
    Identity-aliasing probe on instance names. §13.3: an instance name "is unique
    within its module space, and forms the local component of instance identity."
    Two names that look alike but differ by code point — ASCII "sales" (U+0073
    LATIN s) and "ѕales" (leading U+0455 CYRILLIC ѕ) — are distinct text, so both
    installs succeed and produce two independent instances (no confusable
    folding). The parent aggregation therefore shows two rows whose inherited
    identity (§13.9: module instance identity + row identity) differs only by the
    module-instance key. An implementation that folded confusables would reject
    the second install as a duplicate; the spec keys identity on exact text.
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.company.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          plan: "text"
          modules: {
            $modules: {
              $expose: { company: { $view: ". { id, name, plan }" } }
              $interfaces: {
                templates: { $view: { $key: "id", id: "text", label: "text", journal: "text", lines: "json" } }
              }
            }
          }
          available_templates: {
            $view: ".modules::templates { module: modules.$key, template: templates.$key, id, $sort: [module, template] }"
          }
        }
        $public: {
          companies: { $params: { company: "text" }, $view: "/companies[@company].available_templates" }
        }
      }
      $data: { companies: { acme: { name: "Acme", plan: "fr-pcg" } } }
    }

    frsales: {
      $liasse: 1
      $module: "acme.fr_sales_templates@1.0.0"
      $use: { company: "$parent" }
      $model: {
        templates: { $key: "id", id: "text", label: "text", journal: "text", enabled: "bool = true", lines: "json" }
      }
      $data: {
        templates: {
          sale_invoice: {
            label: "Facture de vente", journal: "VE"
            enabled: "= #company.plan == 'fr-pcg'"
            lines: [ { account: "411", side: "debit", amount: "'= total_ttc" } ]
          }
        }
      }
      $expose: { templates: { $view: ".templates[:t | t.enabled] { id, label, journal, lines }" } }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules"
        request: { $name: "sales", $module: "acme.fr_sales_templates@1.0.0" } }
      expect: { outcome: ok } }
    // leading char is U+0455 CYRILLIC SMALL LETTER DZE, not ASCII 's' -> distinct instance name
    { module_install: { space: "/companies/acme/modules"
        request: { $name: "ѕales", $module: "acme.fr_sales_templates@1.0.0" } }
      expect: { outcome: ok } }
    { watch: "public.companies", args: { company: "acme" }, id: "w1"
      expect_init: { value: { $unordered: [
        { module: "sales",  template: "sale_invoice", id: "sale_invoice" }
        { module: "ѕales", template: "sale_invoice", id: "sale_invoice" }
      ] } } }
  ]
}

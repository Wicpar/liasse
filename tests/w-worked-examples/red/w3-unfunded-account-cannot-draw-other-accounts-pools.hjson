{
  format: 1
  name: w3-unfunded-account-cannot-draw-other-accounts-pools
  suite: scenario
  spec: ["#meters", "W3", "§15.2", "§15.1"]
  tags: [meters, escalation, isolation]
  note: '''
    Cross-account credit-theft probe on W3's account-scoped meter source. The
    limit source is "/credit_periods[:p | p.$source.account == .] { $quantity:
    .credits, price }": each account's `credits` meter only reaches the credit
    periods whose subscription belongs to that same account row. a1 holds a
    weekly subscription (30 credits); a2 holds none. §15.1: "A meter begins with
    zero capacity"; a2's source selects zero pools, so a2's balance is 0. When a2
    spends 1, §15.2 step 6 "rejects the complete transition when eligible
    capacity is insufficient" — a2 cannot fund the spend from a1's pool. The
    rejection leaves a1's pool untouched (balance still 30), so the isolation is
    observable and not merely a balance coincidence.
  '''

  package: {
    $liasse: 1
    $app: "example.credits@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      plans: { $key: "id", id: "text", credits: "decimal", period: "period?", price: "decimal" }
      subscriptions: {
        $key: "id", id: "text"
        account: { $ref: "/accounts" }
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp? = none"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
        price: "= /plans[$source.plan].price"
      }
      accounts: {
        $key: "id", id: "text"
        $limits: {
          credits: {
            $sources: { subscription: "/credit_periods[:p | p.$source.account == .] { $quantity: .credits, price }" }
            $order: ["$until", "price"]
          }
        }
        spends: {
          $key: "id", $consumes: "credits"
          id: "uuid = uuid()", amount: "decimal", occurred_at: "timestamp = now()"
        }
        $mut: { consume: [ "spend = .spends + { amount: @amount }", "return spend { id, amount }" ] }
      }
      $public: {
        wallet: {
          $view: ".accounts { id, balance: .credits.balance }"
          $mut: { consume: ".accounts[@account].consume" }
        }
      }
    }
    $data: {
      plans: { weekly: { credits: "30", price: "9" } }
      accounts: { a1: {}, a2: {} }
      // only a1 is funded; a2 has no subscription and therefore no pools
      subscriptions: { sw: { account: "a1", plan: "weekly", starts_at: "1767225600" } }
    }
  }

  steps: [
    { watch: "public.wallet", id: "w1", expect_init: { value: { $unordered: [
      { id: "a1", balance: "30" }
      { id: "a2", balance: "0" }
    ] } } }
    // a2 has zero eligible capacity: it cannot reach a1's account-scoped pool
    { call: "public.wallet.consume", args: { account: "a2", amount: "1" }
      expect: { outcome: rejected, violates: ["§15.2"], detail: "a2 has no eligible pool; 1 exceeds its capacity 0" } }
    // a1's pool is untouched by a2's failed spend
    { expect_view: { watch: "w1", value: { $unordered: [
      { id: "a1", balance: "30" }
      { id: "a2", balance: "0" }
    ] } } }
  ]
}

{
  format: 1
  name: w1-title-unicode-whitespace-trim-unspecified
  suite: scenario
  spec: ["W1", "#mutations", "§8.8", "#expressions", "§6"]
  tags: [unicode, ambiguity]
  note: '''
    W1 normalizes the title with string.trim(.). A title consisting solely of a
    non-breaking space (U+00A0) probes whether string.trim strips non-ASCII
    Unicode whitespace. If it does, the title normalizes to "" and the size>0
    check rejects the add (outcome rejected). If string.trim only strips ASCII
    whitespace, the title survives as U+00A0 (size 1) and the add succeeds
    (outcome ok). SPEC.md — §6 expressions and Annex A — does not define which
    whitespace class string.trim removes, so the outcome is not externally
    deducible. Captured as an ambiguity rather than guessing implementation
    behavior. The title argument below is the JSON escape " " so the exact
    code point is unambiguous in the case file.
  '''

  package: {
    $liasse: 1
    $app: "example.tasks@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        title: {
          $type: "text"
          $normalize: "string.trim(.)"
          $check: ["size(.) > 0", "A title is required"]
        }
        done: "bool = false"
        created_at: "timestamp = now()"
      }
      $mut: {
        add_task: [
          "task = .tasks + { title: @title }"
          "return task { id, title }"
        ]
      }
      $public: {
        tasks: {
          $view: ".tasks { id, title }"
          $mut: { add: ".add_task" }
        }
      }
    }
  }

  steps: [
    // title is exactly one U+00A0 NO-BREAK SPACE
    { call: "public.tasks.add", args: { title: " " }
      expect: { outcome: unspecified }
      note: "rejected if string.trim strips U+00A0 (then size 0), ok if it does not" }
  ]
}

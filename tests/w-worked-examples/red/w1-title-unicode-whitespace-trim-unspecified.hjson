{
  format: 1
  name: w1-title-unicode-whitespace-trim-unspecified
  suite: scenario
  spec: ["W1", "#mutations", "§8.8", "#expressions", "§6"]
  tags: [unicode, ambiguity]
  note: '''
    Pinned (SPEC-ISSUES #5). W1 normalizes the title with string.trim(.). §6.5
    now states that string.trim removes leading and trailing Unicode scalar
    values carrying the Unicode White_Space property (the scalars Rust's
    str::trim removes). A title consisting solely of a non-breaking space
    (U+00A0) therefore normalizes to "", and because $normalize runs before
    $check (§8.8) the size(.) > 0 check rejects the add (outcome rejected).
    The title argument below is the JSON escape " " so the exact
    code point is unambiguous in the case file.
  '''

  package: {
    $liasse: 1
    $app: "example.tasks@1.0.0"
    $model: {
      tasks: {
        $key: "id"
        id: "uuid = uuid()"
        title: {
          $type: "text"
          $normalize: "string.trim(.)"
          $check: ["size(.) > 0", "A title is required"]
        }
        done: "bool = false"
        created_at: "timestamp = now()"
      }
      $mut: {
        add_task: [
          "task = .tasks + { title: @title }"
          "return task { id, title }"
        ]
      }
      $public: {
        tasks: {
          $view: ".tasks { id, title }"
          $mut: { add: ".add_task" }
        }
      }
    }
  }

  steps: [
    // title is exactly one U+00A0 NO-BREAK SPACE
    { call: "public.tasks.add", args: { title: " " }
      expect: { outcome: rejected, violates: ["#expressions", "§6.5", "#mutations", "§8.8"] }
      note: "string.trim strips U+00A0 so the title normalizes to empty and the size(.) > 0 check rejects the add" }
  ]
}

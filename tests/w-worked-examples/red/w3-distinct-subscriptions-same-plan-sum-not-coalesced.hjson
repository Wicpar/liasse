{
  format: 1
  name: w3-distinct-subscriptions-same-plan-sum-not-coalesced
  suite: scenario
  spec: ["W3", "#meters", "§15.2", "#buckets", "§14.6"]
  tags: [meters, identity]
  note: '''
    Pedantic pool-identity probe. §15.2: "A source view that repeats the same
    full pool identity contributes one pool, never multiplied capacity." Two
    DISTINCT subscriptions of the same plan are two distinct source rows, hence
    two distinct credit_periods pool identities (§14.6: one interval per source →
    source-row identity), so their capacities SUM rather than coalesce. Both
    weekly subscriptions grant 30, giving 60 total. A spend of 45 — impossible
    from a single 30-credit pool — therefore succeeds, and the balance falls to
    15. An implementation that wrongly deduplicated same-plan pools would reject
    the 45 spend.
  '''

  package: {
    $liasse: 1
    $app: "example.credits@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      plans: { $key: "id", id: "text", credits: "decimal", period: "period?", price: "decimal" }
      subscriptions: {
        $key: "id", id: "text"
        account: { $ref: "/accounts" }
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp? = none"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
        price: "= /plans[$source.plan].price"
      }
      accounts: {
        $key: "id", id: "text"
        $limits: {
          credits: {
            $sources: { subscription: "/credit_periods[:p | p.$source.account == .] { $quantity: .credits, price }" }
            $order: ["$until", "price"]
          }
        }
        spends: {
          $key: "id", $consumes: "credits"
          id: "uuid = uuid()", amount: "decimal", occurred_at: "timestamp = now()"
        }
        $mut: { consume: [ "spend = .spends + { amount: @amount }", "return spend { id, amount }" ] }
      }
      $public: {
        wallet: {
          $view: ".accounts { id, balance: .credits.balance }"
          $mut: { consume: ".accounts[@account].consume" }
        }
      }
    }
    $data: {
      plans: { weekly: { credits: "30", price: "9" } }
      accounts: { a1: {} }
      subscriptions: {
        // two distinct subscriptions, same plan -> two distinct pools
        sw1: { account: "a1", plan: "weekly", starts_at: "1767225600" }
        sw2: { account: "a1", plan: "weekly", starts_at: "1767225600" }
      }
    }
  }

  steps: [
    { watch: "public.wallet", id: "w1", expect_init: { value: [ { id: "a1", balance: "60" } ] } }
    { call: "public.wallet.consume", args: { account: "a1", amount: "45" }
      expect: { outcome: ok, value: { id: "$any:uuid", amount: "45" } } }
    { expect_view: { watch: "w1", value: [ { id: "a1", balance: "15" } ] } }
  ]
}

{
  format: 1
  name: w3-funding-projected-metadata-shape-unspecified
  suite: scenario
  spec: ["#meters", "W3", "§15.3"]
  tags: [meters, ambiguity]
  note: '''
    Pinned (SPEC-ISSUES #14). §15.6 now fixes the observable spend.funding view
    to exactly { source (text), pool (opaque identity), amount (decimal) },
    independent of the meter's source projection. W3's source projects a `price`
    member for $order only; price is retained in the frozen admission fact but is
    NOT a member of the returned funding view. So the weekly funding row for a
    spend of 10 is { source: "subscription", pool: <opaque>, amount: "10" } with
    no `price` member.
  '''

  package: {
    $liasse: 1
    $app: "example.credits@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      plans: { $key: "id", id: "text", credits: "decimal", period: "period?", price: "decimal" }
      subscriptions: {
        $key: "id", id: "text"
        account: { $ref: "/accounts" }
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp? = none"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
        price: "= /plans[$source.plan].price"
      }
      accounts: {
        $key: "id", id: "text"
        $limits: {
          credits: {
            $sources: { subscription: "/credit_periods[:p | p.$source.account == .] { $quantity: .credits, price }" }
            $order: ["$until", "price"]
          }
        }
        spends: {
          $key: "id", $consumes: "credits"
          id: "uuid = uuid()", amount: "decimal", occurred_at: "timestamp = now()"
        }
        $mut: { consume: [ "spend = .spends + { amount: @amount }", "return spend { id, amount, funding }" ] }
      }
      $public: {
        wallet: { $mut: { consume: ".accounts[@account].consume" } }
      }
    }
    $data: {
      plans: { weekly: { credits: "30", price: "9" } }
      accounts: { a1: {} }
      subscriptions: { sw: { account: "a1", plan: "weekly", starts_at: "1767225600" } }
    }
  }

  steps: [
    { call: "public.wallet.consume", args: { account: "a1", amount: "10" }
      expect: { outcome: ok, value: { id: "$any:uuid", amount: "10", funding: [ { source: "subscription", pool: "$any", amount: "10" } ] } }
      note: "the funding row carries exactly source/pool/amount; the source-projected price is not a member of the funding view (§15.6)" }
  ]
}

{
  format: 1
  name: w2-expired-session-token-replay-denied
  suite: scenario
  spec: ["W2", "#authentication", "§11.7", "#buckets", "§14.1"]
  tags: [authz, session, replay, temporal]
  note: '''
    Stolen-token replay after expiry. The session is opened with
    expires_at = now() + P30D, and the sessions collection is bucketed on
    ".expires_at". The authenticator selects the session with the ordinary
    selector "/sessions[$proof.session]", which returns only rows active at the
    evaluation time (§14.1). A token captured while valid is replayed after the
    virtual clock advances past expiry: the session is no longer active, so
    $session resolves zero rows and authentication is denied (§11.7 expiry). The
    row still exists in .$all, but the active-only selector will not resolve it.
  '''

  package: {
    $liasse: 1
    $app: "example.accounts@1.0.0"
    $requires: { webauthn: "test.webauthn@1", token: "test.token@1" }
    $model: {
      accounts: { $key: "id", id: "uuid = uuid()", name: "text", enabled: "bool = true" }
      logins: { $key: ["kind", "issuer", "subject"], kind: "text", issuer: "text", subject: "text" }
      account_logins: { $key: ["account", "login"], account: { $ref: "/accounts" }, login: { $ref: "/logins" } }
      sessions: {
        $key: "id"
        $bucket: ".expires_at"
        id: "uuid = uuid()"
        account: { $ref: "/accounts" }
        login: { $ref: "/logins" }
        device: "text?"
        expires_at: "timestamp"
        revoked: "bool = false"
        $mut: { revoke: [".revoked = true", "return . { id, revoked }"] }
      }
      $mut: {
        bootstrap: [
          "acct = /accounts + { name: @name }"
          "lg = /logins + { kind: 'passkey', issuer: @rp, subject: @credential }"
          "/account_logins + { account: acct.$key, login: lg.$key }"
          "return { account: acct.$key }"
        ]
        passkey_login: [
          "identity = webauthn.verify(@response)"
          "login = /logins[{ kind: 'passkey', issuer: identity.rp, subject: identity.credential }]"
          "mapping = /account_logins[{ account: @account, login: login.$key }]"
          '''session = /sessions + {
            account: mapping.account,
            login: mapping.login,
            device: @device,
            expires_at: now() + time.duration('P30D')
          }'''
          "token = token.sign({ auth: 'session', session: session.$key })"
          "return { auth: 'session', token, expires_at: session.$until }"
        ]
      }
      $auth: {
        session: {
          $credential: "text"
          $verify: "token.verify($credential)"
          $session: "/sessions[$proof.session]"
          $actor: "/accounts[$session.account]"
          $check: ["$proof.auth == $auth_name", "!$session.revoked", "$actor.enabled"]
        }
      }
      $public: {
        setup: { $mut: { bootstrap: ".bootstrap" } }
        login: { $mut: { passkey: ".passkey_login" } }
      }
      $roles: {
        account: {
          $auth: "session"
          $members: ".accounts[:a | a.enabled]"
          profile: { $view: "$actor { id, name }" }
          sessions: {
            $view: ".sessions.$all[:s | s.account == $actor] { id, device, revoked }"
            $mut: { revoke: ".sessions[@id].revoke()" }
          }
        }
      }
    }
  }

  hosts: {
    webauthn: { $namespace: "test.webauthn@1", responses: { "resp-alice": { rp: "example.com", credential: "cred-alice" } } }
    token: { $namespace: "test.token@1", tokens: {} }
  }

  steps: [
    { call: "public.setup.bootstrap", args: { name: "alice", rp: "example.com", credential: "cred-alice" }
      expect: { outcome: ok, value: { account: "$bind:alice" } } }
    { call: "public.login.passkey", args: { response: "resp-alice", account: "$ref:alice", device: "laptop" }
      expect: { outcome: ok, value: { token: "$bind:tok1", "...": true } } }
    { connect: "c1", authenticate: { auth: "session", credential: "$ref:tok1" } }
    // valid now
    { watch: "account.profile", on: "c1", id: "w1", expect_init: { value: { id: "$ref:alice", name: "alice" } } }
    // clock moves past the 30-day expiry
    { advance_time: "P31D" }
    // replay the captured token on a fresh connection -> session inactive -> denied
    { connect: "c2", authenticate: { auth: "session", credential: "$ref:tok1" } }
    { call: "account.sessions.revoke", args: { id: "aaaaaaaa-0000-4000-8000-0000000000ff" }, on: "c2"
      expect: { outcome: denied, violates: ["§11.7"], detail: "session no longer active at replay time" } }
  ]
}

{
  format: 1
  name: w4-install-exposes-enabled-template-to-parent
  suite: scenario
  spec: ["W4", "#modules", "§13.4", "§13.8", "§13.9"]
  tags: [modules]
  note: '''
    W4 end-to-end install path. Installing acme.fr_sales_templates under a
    company binds #company to that company's parent-exposed surface (§13.4). The
    seed field enabled = "= #company.plan == 'fr-pcg'" therefore resolves against
    the company's plan; Acme's plan is "fr-pcg", so the template is enabled. The
    module's $expose templates = ".templates[:t | t.enabled] { id, label,
    journal, lines }" satisfies the module-space `templates` interface (§13.8),
    and the parent aggregates it through .modules::templates (§13.9). The
    installed template thus appears in available_templates with its inherited
    (module instance + row) identity.
  '''

  packages: {
    host: {
      $liasse: 1
      $app: "t.company.host@1.0.0"
      $model: {
        companies: {
          $key: "id"
          id: "text"
          name: "text"
          plan: "text"
          templates: {
            $key: ["module", "template"]
            module: "text", template: "text", label: "text", journal: "text", lines: "json"
          }
          $mut: {
            rename: ".name = @name"
            set_plan: ".plan = @plan"
            import_template: [
              "source = .modules[@module]::templates[@template]"
              '''.templates + {
                module: @module, template: @template,
                label: source.label, journal: source.journal, lines: source.lines
              }'''
            ]
          }
          modules: {
            $modules: {
              $expose: {
                company: { $view: ". { id, name, plan }", $mut: { rename: ".rename" } }
              }
              $interfaces: {
                templates: {
                  $view: { $key: "id", id: "text", label: "text", journal: "text", lines: "json" }
                }
              }
            }
          }
          available_templates: {
            $view: '''.modules::templates {
              module: modules.$key, template: templates.$key,
              id, label, journal, lines, $sort: [label, module, template]
            }'''
          }
        }
        $public: {
          companies: {
            $params: { company: "text" }
            $view: "/companies[@company].available_templates"
          }
        }
      }
      $data: { companies: { acme: { name: "Acme", plan: "fr-pcg" } } }
    }

    frsales: {
      $liasse: 1
      $module: "acme.fr_sales_templates@1.0.0"
      $use: { company: "$parent" }
      $model: {
        templates: {
          $key: "id", id: "text", label: "text", journal: "text", enabled: "bool = true", lines: "json"
        }
      }
      $data: {
        templates: {
          sale_invoice: {
            label: "Facture de vente"
            journal: "VE"
            enabled: "= #company.plan == 'fr-pcg'"
            lines: [
              { account: "411", side: "debit",  amount: "'= total_ttc" }
              { account: "707", side: "credit", amount: "'= total_ht" }
            ]
          }
        }
      }
      $expose: {
        templates: { $view: ".templates[:t | t.enabled] { id, label, journal, lines }" }
      }
    }
  }
  root: host

  steps: [
    { module_install: { space: "/companies/acme/modules"
        request: { $name: "fr_sales", $module: "acme.fr_sales_templates@1.0.0" } }
      expect: { outcome: ok } }
    { watch: "public.companies", args: { company: "acme" }, id: "w1"
      expect_init: { value: [
        { module: "fr_sales", template: "sale_invoice", id: "sale_invoice", label: "Facture de vente", journal: "VE", lines: "$any" }
      ] } }
  ]
}

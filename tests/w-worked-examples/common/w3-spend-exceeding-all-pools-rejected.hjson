{
  format: 1
  name: w3-spend-exceeding-all-pools-rejected
  suite: scenario
  spec: ["W3", "#meters", "§15.2"]
  tags: [meters]
  note: '''
    Ordinary error path of W3. §15.2 step 6: the engine "rejects the complete
    transition when eligible capacity is insufficient." The account's only pool
    is a weekly subscription worth 30 credits. A spend of 31 exceeds total
    eligible capacity and is rejected with no partial effect; the balance is
    unchanged at 30, and a subsequent spend of exactly 30 still succeeds.
  '''

  package: {
    $liasse: 1
    $app: "example.credits@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      plans: { $key: "id", id: "text", credits: "decimal", period: "period?", price: "decimal" }
      subscriptions: {
        $key: "id", id: "text"
        account: { $ref: "/accounts" }
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp? = none"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
        price: "= /plans[$source.plan].price"
      }
      accounts: {
        $key: "id", id: "text"
        $limits: {
          credits: {
            $sources: { subscription: "/credit_periods[:p | p.$source.account == .] { $quantity: .credits, price }" }
            $order: ["$until", "price"]
          }
        }
        spends: {
          $key: "id", $consumes: "credits"
          id: "uuid = uuid()", amount: "decimal", occurred_at: "timestamp = now()"
        }
        $mut: { consume: [ "spend = .spends + { amount: @amount }", "return spend { id, amount }" ] }
      }
      $public: {
        wallet: {
          $view: ".accounts { id, balance: .credits.balance }"
          $mut: { consume: ".accounts[@account].consume" }
        }
      }
    }
    $data: {
      plans: { weekly: { credits: "30", price: "9" } }
      accounts: { a1: {} }
      subscriptions: { sw: { account: "a1", plan: "weekly", starts_at: "1767225600" } }
    }
  }

  steps: [
    { watch: "public.wallet", id: "w1", expect_init: { value: [ { id: "a1", balance: "30" } ] } }
    { call: "public.wallet.consume", args: { account: "a1", amount: "31" }
      expect: { outcome: rejected, violates: ["§15.2"], detail: "31 exceeds eligible capacity 30" } }
    { expect_view: { watch: "w1", value: [ { id: "a1", balance: "30" } ] } }
    { call: "public.wallet.consume", args: { account: "a1", amount: "30" }, expect: { outcome: ok, value: { id: "$any:uuid", amount: "30" } } }
    { expect_view: { watch: "w1", value: [ { id: "a1", balance: "0" } ] } }
  ]
}

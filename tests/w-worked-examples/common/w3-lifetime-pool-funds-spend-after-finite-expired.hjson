{
  format: 1
  name: w3-lifetime-pool-funds-spend-after-finite-expired
  suite: scenario
  spec: ["W3", "#meters", "§15.2", "#buckets", "§14.1"]
  tags: [temporal, meters]
  note: '''
    W3 end-to-end across time. An account holds one finite weekly subscription and
    one unbounded lifetime subscription. §15.2: a spend "collects every reachable
    pool active at the spend time"; §14.1: a bucketed pool is inactive at/after
    its half-open upper bound. Initially both pools are active (balance 30+1000).
    After the clock passes the weekly expiry the weekly pool is inactive, so the
    balance is the lifetime 1000, and a later spend of 500 is funded entirely by
    the still-active lifetime pool, leaving 500. Timestamps use s precision:
    2026-01-01=1767225600, +7d=1767830400.
  '''

  package: {
    $liasse: 1
    $app: "example.credits@1.0.0"
    $semantics: { timestamp_precision: "s" }
    $model: {
      plans: { $key: "id", id: "text", credits: "decimal", period: "period?", price: "decimal" }
      subscriptions: {
        $key: "id", id: "text"
        account: { $ref: "/accounts" }
        plan: { $ref: "/plans" }
        starts_at: "timestamp"
        ends_at: "timestamp? = none"
      }
      credit_periods: {
        $bucket: {
          $source: ".subscriptions"
          $from: "$source.starts_at"
          $until: "$source.ends_at"
          $repeat: "/plans[$source.plan].period"
        }
        credits: "= /plans[$source.plan].credits"
        price: "= /plans[$source.plan].price"
      }
      accounts: {
        $key: "id", id: "text"
        $limits: {
          credits: {
            $sources: {
              subscription: '''/credit_periods[:p | p.$source.account == .] {
                $quantity: .credits,
                price
              }'''
            }
            $order: ["$until", "price"]
          }
        }
        spends: {
          $key: "id", $consumes: "credits"
          id: "uuid = uuid()", amount: "decimal", occurred_at: "timestamp = now()"
        }
        $mut: { consume: [ "spend = .spends + { amount: @amount }", "return spend { id, amount }" ] }
      }
      $public: {
        wallet: {
          $view: ".accounts { id, balance: .credits.balance }"
          $mut: { consume: ".accounts[@account].consume" }
        }
      }
    }
    $data: {
      plans: {
        weekly:   { credits: "30",   period: "P7D", price: "9" }
        lifetime: { credits: "1000", price: "200" }
      }
      accounts: { a1: {} }
      subscriptions: {
        sw: { account: "a1", plan: "weekly",   starts_at: "1767225600", ends_at: "1767830400" }
        sl: { account: "a1", plan: "lifetime", starts_at: "1767225600" }
      }
    }
  }

  steps: [
    { watch: "public.wallet", id: "w1", expect_init: { value: [ { id: "a1", balance: "1030" } ] } }
    // clock passes the weekly expiry -> only lifetime remains active
    { advance_time: "P8D" }
    { expect_view: { watch: "w1", value: [ { id: "a1", balance: "1000" } ] } }
    { call: "public.wallet.consume", args: { account: "a1", amount: "500" }
      expect: { outcome: ok, value: { id: "$any:uuid", amount: "500" } } }
    { expect_view: { watch: "w1", value: [ { id: "a1", balance: "500" } ] } }
  ]
}

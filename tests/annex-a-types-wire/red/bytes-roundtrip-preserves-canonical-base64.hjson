{
  format: 1
  name: bytes-roundtrip-preserves-canonical-base64
  suite: scenario
  spec: ["§A.1", "§D.2"]
  tags: ["wire", "bytes"]
  note: '''Attack: an implementation stores bytes but re-encodes the wire form with a
different-yet-equivalent base64 flavour — the URL-safe alphabet (`-`/`_` instead of
`+`/`/`) or padding stripped. That breaks byte-for-byte descriptor identity and any
consumer that expects the canonical form. The seed "/++/" is 4 base64 characters (3
bytes: 0xFF 0xEF 0xBF) that exercise BOTH alphabet-sensitive symbols `/` and `+`; the
URL-safe re-encoding of the same bytes would be "_--_" (the same 3 bytes 0xFF 0xEF 0xBF).
Annex A.1 requires
`{ "$bytes": "<canonical base64>" }` and Annex D.2 requires canonical *padded* standard
base64, so the value MUST round-trip byte-identically as "/++/".'''

  package: {
    $liasse: 1
    $app: "t.bytesrt@1.0.0"
    $model: {
      b: "bytes"
      $public: {
        v: { $view: ". { b }" }
      }
    }
    $data: {
      // 3 bytes 0xFF 0xEF 0xBF; standard-alphabet base64 uses both '/' and '+'
      b: { $bytes: "/++/" }
    }
  }

  steps: [
    { watch: "public.v", id: "w1",
      // must NOT come back as URL-safe "_--_"
      expect_init: { value: { b: { $bytes: "/++/" } } } }
  ]
}

{
  format: 1
  name: json-array-order-preserved-not-sorted
  suite: scenario
  spec: ["§A.7"]
  tags: ["wire", "json"]
  note: '''Attack: an over-eager "canonicalizer" sorts EVERY container. Annex A.7 sorts
only object *keys* ('sorts object keys by the Liasse text order') while it separately
'preserves array order'. A json array is an ordered value, not a set: canonicalization
MUST NOT reorder its elements. The seeded array [3, 1, 2] is deliberately not ascending;
its projected wire value MUST remain [3, 1, 2] in source order. An implementation that
sorts array elements would emit [1, 2, 3] and fail. (Distinct from the Annex B.3 sort
order *between* arrays used as sort keys — this is intra-value element-order preservation
of a single json value on the wire.)'''

  package: {
    $liasse: 1
    $app: "t.jsonarrord@1.0.0"
    $model: {
      a: "json"
      $public: {
        v: { $view: ". { a }" }
      }
    }
    $data: {
      a: [3, 1, 2]
    }
  }

  steps: [
    { watch: "public.v", id: "w1",
      expect_init: { value: { a: [3, 1, 2] } } }
  ]
}

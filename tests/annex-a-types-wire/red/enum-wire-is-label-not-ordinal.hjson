{
  format: 1
  name: enum-wire-is-label-not-ordinal
  suite: scenario
  spec: ["§A.1", "§B.1"]
  tags: ["wire", "enum"]
  note: '''Attack: an implementation stores enums compactly as their declaration index
(Annex B.1 orders enum by declaration order, tempting an ordinal representation) and
leaks that ordinal onto the wire. The seeded value is the SECOND declared label, so an
ordinal leak surfaces as the JSON number 1 instead of the label string. Annex A.1 fixes
the canonical wire value of an enum as a JSON string — the declared label. The
expectation is the string "sent"; the JSON number 1 is a different wire type and fails.'''

  package: {
    $liasse: 1
    $app: "t.enumord@1.0.0"
    $model: {
      status: { $enum: ["draft", "sent", "paid"] }
      $public: {
        v: { $view: ". { status }" }
      }
    }
    $data: {
      // index 1 in declaration order
      status: "sent"
    }
  }

  steps: [
    { watch: "public.v", id: "w1",
      expect_init: { value: { status: "sent" } } }
  ]
}

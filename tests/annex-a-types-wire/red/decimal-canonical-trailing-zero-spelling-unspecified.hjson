{
  format: 1
  name: decimal-canonical-trailing-zero-spelling-unspecified
  suite: scenario
  spec: ["§A.1", "§A.6", "§B.1"]
  tags: ["decimal", "wire"]
  note: '''Genuinely unspecified: the exact canonical *spelling* of a decimal that has
trailing fractional zeros. Annex A.1 says the decimal wire value uses 'canonical sign and
trailing-zero form' but never defines what that form IS — whether it strips trailing
zeros to the shortest exact spelling ("1"), preserves the scale produced by the operation
("1.00"), or something else. Annex A.6 fixes the exact *value* (1.50 - 0.50 = 1.00, i.e. exactly 1)
and Annex B.1 makes numerically equal canonical decimals compare EQUAL, but neither pins
the emitted digit string. So the wire spelling of this subtraction result is not
externally deducible. (The 05-state-model decimal-key case likewise avoided asserting the
trailing-zero spelling for the same reason.) Recorded as a spec gap in Annex A.1: the
phrase 'canonical trailing-zero form' is used without a definition.'''

  package: {
    $liasse: 1
    $app: "t.dectz@1.0.0"
    $model: {
      a: "decimal"
      b: "decimal"
      $mut: {
        diff: "return .a - .b"
      }
      $public: {
        calc: {
          $mut: {
            diff: ".diff"
          }
        }
      }
    }
    $data: {
      a: "1.50"
      b: "0.50"
    }
  }

  steps: [
    // exact value is 1, but whether the wire string is "1", "1.0", "1.00", ... is undefined
    { call: "public.calc.diff", args: {},
      expect: { outcome: unspecified } }
  ]
}

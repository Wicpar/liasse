{
  format: 1
  name: decimal-wire-has-no-exponent
  suite: scenario
  spec: ["§A.1", "§A.6"]
  tags: ["wire", "decimal"]
  note: "Annex A.1: the canonical strict-JSON value of `decimal` is a 'JSON string, no exponent'. The product 0.0001 * 0.0001 is exact (A.6) = 0.00000001; its canonical wire form is the plain-notation string \"0.00000001\". An implementation rendering it as \"1e-8\" / \"1E-8\" or as a JSON number violates A.1. Arithmetic (not an echo) produces the value."

  package: {
    $liasse: 1
    $app: "t.decexp@1.0.0"
    $model: {
      a: "decimal"
      sq: "= .a * .a"
      $public: {
        v: { $view: ". { sq }" }
      }
    }
    $data: {
      a: "0.0001"
    }
  }

  steps: [
    { watch: "public.v", id: "w1",
      expect_init: { value: { sq: "0.00000001" } } }
  ]
}

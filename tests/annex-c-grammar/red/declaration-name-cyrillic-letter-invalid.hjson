{
  format: 1
  name: declaration-name-cyrillic-letter-invalid
  suite: static
  tags: [grammar, unicode, identity, confusable]
  // Identity attack: a model declaration name that LOOKS like ASCII "task" but
  // whose third character is Cyrillic small letter A (U+0430), written with a
  // \u escape so the confusable survives every tool. §2.5: "Application
  // declaration names MUST begin with an ASCII letter and contain only ASCII
  // letters, digits, and _." A Cyrillic letter is outside the ASCII letter set,
  // so the declaration must fail static validation regardless of visual
  // identity with a legal name.
  spec: ["#conformance", "§2.5"]

  package: {
    $liasse: 1
    $app: "t.cyrillicname@1.0.0"
    $model: {
      "t\u0430sk": "text"
    }
  }

  expect: {
    outcome: invalid
    violates: ["#conformance", "§2.5"]
    detail: "declaration name contains U+0430 (Cyrillic 'а'), which is not an ASCII letter"
  }
}

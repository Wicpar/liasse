{
  format: 1
  name: bare-equals-empty-expression-in-data-invalid
  suite: static
  tags: [grammar, escaping, boundary]
  // SPEC-ISSUES #25 (pinned): the escape's mirror image. Annex C.4 makes a $data
  // string beginning with '=' an expression ("= expr"), and §4.2 confirms it. The
  // value "=" is '=' followed by an EMPTY expression body — the expression marker
  // with nothing after it. That degenerate form is now a static (load-time) error:
  // the expression after '=' MUST be non-empty. A literal '=' is written "'=".
  note: "SPEC-ISSUES #25: a `$data` (or expanded `$default`) value of `=` alone is the expression marker with an empty body; §4.2 / Annex C.4 make it a static load error (the expression after `=` must be non-empty), not a silently-coerced literal or empty value."
  spec: ["#annex-c", "§C.4", "#package-structure", "§4.2"]

  package: {
    $liasse: 1
    $app: "t.bareequals@1.0.0"
    $model: {
      doc: { label: "text" }
      view_doc: { $view: ".doc { label }" }
      $public: {
        doc: { $view: ".view_doc" }
      }
    }
    $data: {
      doc: { label: "=" }
    }
  }

  expect: {
    outcome: invalid
    violates: ["#annex-c", "§C.4", "#package-structure", "§4.2"]
    detail: "the `$data` value `=` is the expression marker with an empty body; the expression after `=` must be non-empty"
  }
}

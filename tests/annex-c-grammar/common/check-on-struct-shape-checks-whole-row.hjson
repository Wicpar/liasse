{
  format: 1
  name: check-on-struct-shape-checks-whole-row
  suite: scenario
  spec: ["#annex-c", "§C.3", "#state-model", "§5.10"]
  note: "Annex C.3: 'A $check on an expanded field checks that field; on a struct or collection shape it checks the complete prospective struct or row.' §5.10: a $check on a struct shape sees '.' as the prospective struct after defaults/normalization, so it may reference several members. The insert that violates the cross-field predicate is rejected at admission."

  package: {
    $liasse: 1
    $app: "t.structcheck@1.0.0"
    $model: {
      periods: {
        $key: "id"
        id: "uuid = uuid()"
        starts_at: "timestamp"
        ends_at: "timestamp"
        $check: [".ends_at > .starts_at", "The period must advance"]
      }
      $mut: {
        add: [
          "p = .periods + { starts_at: @starts_at, ends_at: @ends_at }"
          "return p { id }"
        ]
      }
      all: { $view: ".periods { id }" }
      $public: {
        periods: {
          $view: ".all"
          $mut: { add: ".add" }
        }
      }
    }
  }

  steps: [
    // `@starts_at`/`@ends_at` are `timestamp` operands, whose canonical wire form
    // is a base-10 count of the declared precision (default us), not an RFC-3339
    // rendering (Annex A.1, pinned by `timestamp-wire-is-base10-string`). The
    // counts below are 2026-02-01 (1769904000000000us) and 2026-01-01
    // (1767225600000000us): step 0 has ends_at < starts_at and violates the
    // cross-field `$check`; step 1 advances and is admitted.
    { call: "public.periods.add",
      args: { starts_at: "1769904000000000", ends_at: "1767225600000000" },
      expect: { outcome: rejected, violates: ["#state-model", "§5.10"] } }
    { call: "public.periods.add",
      args: { starts_at: "1767225600000000", ends_at: "1769904000000000" },
      expect: { outcome: ok, value: { id: "$any:uuid" } } }
  ]
}

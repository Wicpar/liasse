{
  format: 1
  name: integer-remainder-sign-unspecified
  suite: scenario
  spec: ["#expressions", "§6.1", "§A.6"]
  tags: ["boundary"]
  note: "Pinned (SPEC-ISSUES #3). Annex A.6 now makes `%` part of the arithmetic surface for int and decimal, defined as a - trunc(a / b) * b with the quotient truncated toward zero, so the remainder takes the dividend's sign: -7 % 2 = -1 (matches PostgreSQL mod). The computed field r reads the sign back through a keyed-collection view."

  package: {
    $liasse: 1
    $app: "t.intmod@1.0.0"
    $model: {
      calc: {
        $key: "id"
        id: "text"
        a: "int"
        b: "int"
        r: "= .a % .b"
      }
      $public: {
        calc: { $view: ".calc { id, r }" }
      }
    }
    $data: {
      calc: {
        x: { a: "-7", b: "2" }
      }
    }
  }

  steps: [
    // -7 % 2 = -1: the remainder follows the dividend's sign (truncated division).
    { watch: "public.calc", id: "w1",
      expect_init: { value: [ { id: "x", r: "-1" } ] } }
  ]
}

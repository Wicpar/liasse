{
  format: 1
  name: division-by-zero-unspecified
  suite: scenario
  spec: ["#expressions", "§6.5", "§A.6"]
  tags: ["boundary"]
  note: "Spec gap. Annex A.6 defines exact decimal/integer arithmetic and division scale selection but no behavior for a zero divisor, and no other chapter mandates one. Dividing by a zero read from state cannot be excluded statically. Whether the call errors, rejects the transition with a diagnostic, or produces some value is unpinned; only the load of the package (statically well-typed) is uncontroversial."

  package: {
    $liasse: 1
    $app: "t.divzero@1.0.0"
    $model: {
      a: "int"
      b: "int"
      $mut: {
        read: "return .a / .b"
      }
      $public: {
        math: {
          $mut: { read: ".read" }
        }
      }
    }
    $data: {
      a: "1"
      b: "0"
    }
  }

  steps: [
    { call: "public.math.read", args: {},
      expect: { outcome: "unspecified", violates: ["#expressions"] } }
  ]
}

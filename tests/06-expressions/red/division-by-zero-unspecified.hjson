{
  format: 1
  name: division-by-zero-unspecified
  suite: scenario
  spec: ["#expressions", "§A.6"]
  tags: ["boundary"]
  note: "Pinned (SPEC-ISSUES #3). Annex A.6 now states that a zero divisor in `/` or `%` produces no value: it is a typed evaluation error that rejects the containing evaluation with a diagnostic and never panics, yields none, or yields a non-finite value. Because the divisor is read from state (b = 0 in $data), the fault is detected at evaluation, so the call is rejected."

  package: {
    $liasse: 1
    $app: "t.divzero@1.0.0"
    $model: {
      a: "int"
      b: "int"
      $mut: {
        read: "return .a / .b"
      }
      $public: {
        math: {
          $mut: { read: ".read" }
        }
      }
    }
    $data: {
      a: "1"
      b: "0"
    }
  }

  steps: [
    { call: "public.math.read", args: {},
      expect: { outcome: rejected, violates: ["#expressions", "§A.6"] } }
  ]
}

{
  format: 1
  name: decimal-arithmetic-exact
  suite: scenario
  spec: ["#expressions", "§6.5", "§A.6", "§B.1"]
  note: "Annex A.6: 'Decimals are exact base-10 values. Addition, subtraction, and multiplication are exact.' Annex B.1: numerically equal canonical decimal values compare equal. Therefore 0.1 + 0.2 == 0.3 and 0.1 * 0.1 == 0.01 exactly — there is no binary-float drift. Comparisons are done against seeded decimal fields to avoid pinning any literal or canonical-scale form."

  package: {
    $liasse: 1
    $app: "t.decimal@1.0.0"
    $model: {
      a: "decimal"
      b: "decimal"
      c: "decimal"
      d: "decimal"
      exact_sum: "= .a + .b == .c"
      exact_product: "= .a * .a == .d"
      $public: {
        check: { $view: ". { exact_sum, exact_product }" }
      }
    }
    $data: {
      a: "0.1"
      b: "0.2"
      c: "0.3"
      d: "0.01"
    }
  }

  steps: [
    { watch: "public.check", id: "w1",
      expect_init: { value: { exact_sum: true, exact_product: true } } }
  ]
}

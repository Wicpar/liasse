{
  format: 1
  name: unique-none-component-does-not-conflict
  suite: scenario
  spec: ["#state-model", "§5.7", "§A.8", "§B.5"]
  note: "§5.7: 'A candidate key containing optional fields enforces uniqueness among rows for which every component is present. A row with none in any component does not conflict through that candidate key.' Candidate-key fields MAY be optional (§A.8)."

  package: {
    $liasse: 1
    $app: "t.unique_none@1.0.0"
    $model: {
      taxpayers: {
        $key: "id"
        $unique: [["country", "tax_id"]]
        id: "text"
        country: "text"
        tax_id: "text?"
      }
      $public: {
        taxpayers: {
          $view: ".taxpayers { id, country, tax_id }"
          $mut: {
            add: ".taxpayers + { id: @id, country: @country }"
            add_with_tax_id: ".taxpayers + { id: @id, country: @country, tax_id: @tax_id }"
          }
        }
      }
    }
  }

  steps: [
    // two rows with none in one component never conflict through this candidate key
    { call: "public.taxpayers.add", args: { id: "t1", country: "FR" }, expect: { outcome: ok } }
    { call: "public.taxpayers.add", args: { id: "t2", country: "FR" }, expect: { outcome: ok } }
    // all components present -> uniqueness enforced
    { call: "public.taxpayers.add_with_tax_id", args: { id: "t3", country: "FR", tax_id: "123" },
      expect: { outcome: ok } }
    { call: "public.taxpayers.add_with_tax_id", args: { id: "t4", country: "FR", tax_id: "123" },
      expect: { outcome: rejected, violates: ["§5.7"] } }
    { watch: "public.taxpayers", id: "w1", expect_init: { value: [
      { id: "t1", country: "FR", tax_id: "$absent" }
      { id: "t2", country: "FR", tax_id: "$absent" }
      { id: "t3", country: "FR", tax_id: "123" }
    ] } }
  ]
}

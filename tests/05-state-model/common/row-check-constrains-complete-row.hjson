{
  format: 1
  name: row-check-constrains-complete-row
  suite: scenario
  spec: ["#state-model", "§5.10", "§8.8"]
  note: "§5.10: $check on a keyed collection shape constrains the complete row; '.' is the prospective row after defaults and normalization. A row violating the check rejects the complete transition (§8.8)."

  package: {
    $liasse: 1
    $app: "t.rowcheck@1.0.0"
    $model: {
      bookings: {
        $key: "id"
        id: "text"
        starts: "int"
        ends: "int"
        $check: [".ends > .starts", "The booking must end after it starts"]
      }
      $public: {
        bookings: {
          $view: ".bookings { id, starts, ends }"
          $mut: {
            add: ".bookings + { id: @id, starts: @starts, ends: @ends }"
          }
        }
      }
    }
  }

  steps: [
    { call: "public.bookings.add", args: { id: "b1", starts: 10, ends: 10 },
      expect: { outcome: "rejected", violates: ["§5.10"], detail: "row check failed: The booking must end after it starts" } }
    { call: "public.bookings.add", args: { id: "b1", starts: 10, ends: 20 },
      expect: { outcome: "ok" } }
    { watch: "public.bookings", id: "w1",
      expect_init: { value: [ { id: "b1", starts: 10, ends: 20 } ] } }
  ]
}

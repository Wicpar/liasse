{
  format: 1
  name: rekey-updates-inbound-refs
  suite: scenario
  spec: ["#state-model", "§5.4", "§5.6"]
  note: "Assigning a new value to a key field performs an atomic rekey; the runtime MUST update every ref that targets the row in the same transition (§5.4). The ref stays attached to the row incarnation, so its visible value becomes the new key (§5.6)."

  package: {
    $liasse: 1
    $app: "t.rekey_refs@1.0.0"
    $model: {
      companies: {
        $key: "id"
        id: "text"
        name: "text"
      }
      contacts: {
        $key: "id"
        id: "text"
        company: { $ref: "/companies" }
      }
      $public: {
        contacts: {
          $view: ".contacts { id, company }"
          $mut: {
            add_company: ".companies + { id: @id, name: @name }"
            add_contact: ".contacts + { id: @id, company: @company }"
            rekey_company: ".companies[@old].id = @new"
          }
        }
      }
    }
  }

  steps: [
    { call: "public.contacts.add_company", args: { id: "acme", name: "Acme" },
      expect: { outcome: "ok" } }
    { call: "public.contacts.add_contact", args: { id: "c1", company: "acme" },
      expect: { outcome: "ok" } }
    { watch: "public.contacts", id: "w1",
      expect_init: { value: [ { id: "c1", company: "acme" } ] } }
    { call: "public.contacts.rekey_company", args: { old: "acme", new: "newco" },
      expect: { outcome: "ok" } }
    // the ref's application-visible value is the target's *current* typed key
    { expect_view: { watch: "w1", value: [ { id: "c1", company: "newco" } ] } }
  ]
}

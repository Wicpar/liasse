{
  format: 1
  name: seed-default-sibling-visibility-unspecified
  suite: scenario
  spec: ["#state-model", "§5.1", "§9.1"]
  tags: ["ordering"]
  note: '''Pinned (SPEC-ISSUES #23). §9.1 now states that within the single atomic seed
load every seeded row identity and supplied value is visible to every seed default:
`count(/items) + 1` observes all sibling seeded rows. §5.1's become-selectable-only-after-
resolution rule sequences external reads across separate mutation statements; it does not
subdivide the genesis seed load. With two seeded rows a and b, count(/items) sees both, so
each row's pos resolves to 3 (the (3, 3) reading).'''

  package: {
    $liasse: 1
    $app: "t.st.seeddefaults@1.0.0"
    $model: {
      items: {
        $key: "id"
        id: "text"
        pos: "int = count(/items) + 1"
      }
      $public: {
        items: {
          $view: ".items { id, pos }"
        }
      }
    }
    $data: {
      items: {
        a: {}
        b: {}
      }
    }
  }

  steps: [
    // Each seed default count(/items) + 1 observes both sibling seeded rows -> pos = 3.
    { watch: "public.items", id: "w1",
      expect_init: { value: { $unordered: [ { id: "a", pos: "3" }, { id: "b", pos: "3" } ] } } }
  ]
}

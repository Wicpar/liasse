{
  format: 1
  name: composite-key-separator-injection
  suite: scenario
  spec: ["#state-model", "§5.4", "§D.2", "§9.1", "§B.4", "§B.5"]
  tags: ["identity", "unicode"]
  note: '''Attack: smuggle the composite-join separator into a component so that
("a:b", "c") and ("a", "b:c") canonicalize to the same joined text and collide.
§D.2: each original ':' inside a scalar key component is encoded as %3A *before*
components are joined with ':', so the canonical texts are "a%3Ab:c" and "a:b%3Ac" —
distinct. Seed member names use exactly this encoding (§9.1 map form), so the seeded
member "a%3Ab:c" must decode to components ("a:b", "c") and agree with its repeated
key fields.'''

  package: {
    $liasse: 1
    $app: "t.sepinject@1.0.0"
    $model: {
      routes: {
        $key: ["ns", "name"]
        ns: "text"
        name: "text"
        target: "text"
      }
      $public: {
        routes: {
          $view: ".routes { ns, name, target }"
          $mut: {
            add: ".routes + { ns: @ns, name: @name, target: @target }"
            get: "return .routes[{ ns: @ns, name: @name }].target"
          }
        }
      }
    }
    $data: {
      routes: {
        // canonical encoded key text for components ("a:b", "c")
        "a%3Ab:c": { ns: "a:b", name: "c", target: "seeded" }
      }
    }
  }

  steps: [
    // the seeded member name decoded to the intended components
    { call: "public.routes.get", args: { ns: "a:b", name: "c" },
      expect: { outcome: ok, value: "seeded" } }
    // ("a", "b:c") is a different composite key -> must not collide with the seeded row
    { call: "public.routes.add", args: { ns: "a", name: "b:c", target: "mutated" },
      expect: { outcome: ok } }
    { call: "public.routes.get", args: { ns: "a", name: "b:c" },
      expect: { outcome: ok, value: "mutated" } }
    { call: "public.routes.get", args: { ns: "a:b", name: "c" },
      expect: { outcome: ok, value: "seeded" } }
    // composite order: ("a","b:c") sorts before ("a:b","c")
    { watch: "public.routes", id: "w1", expect_init: { value: [
      { ns: "a", name: "b:c", target: "mutated" }
      { ns: "a:b", name: "c", target: "seeded" }
    ] } }
  ]
}

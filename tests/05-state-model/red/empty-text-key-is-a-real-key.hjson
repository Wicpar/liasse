{
  format: 1
  name: empty-text-key-is-a-real-key
  suite: scenario
  spec: ["#state-model", "§5.4", "§A.1", "§A.8"]
  tags: ["boundary"]
  note: '''Boundary abuse: the empty string as a row key. Deduction chain: text is a
'Unicode scalar sequence, preserved exactly' (§A.1) — the empty sequence is a text
value; text is key-eligible (§A.8); the field declares no $check, and no rule in §5
imposes a minimum key length. A conforming runtime must therefore accept "" as an
ordinary key: addressable, and colliding with itself on re-insert (§5.4) — proving it
is a real key rather than a sentinel for "missing".'''

  package: {
    $liasse: 1
    $app: "t.emptykey@1.0.0"
    $model: {
      codes: {
        $key: "id"
        id: "text"
        label: "text"
      }
      $public: {
        codes: {
          $view: ".codes { id, label }"
          $mut: {
            add: ".codes + { id: @id, label: @label }"
            get: "return .codes[@id].label"
          }
        }
      }
    }
  }

  steps: [
    { call: "public.codes.add", args: { id: "", label: "empty" },
      expect: { outcome: "ok" } }
    { call: "public.codes.get", args: { id: "" },
      expect: { outcome: "ok", value: "empty" } }
    // "" collides with "" like any other key value
    { call: "public.codes.add", args: { id: "", label: "again" },
      expect: { outcome: "rejected", violates: ["§5.4"] } }
    { watch: "public.codes", id: "w1",
      expect_init: { value: [ { id: "", label: "empty" } ] } }
  ]
}
